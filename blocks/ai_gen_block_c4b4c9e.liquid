{% doc %}
  @prompt
    White background section. Width 100%.
    Padding top: 48px bottom: 48px
    Padding left: 20px right: 20px desktop
    Padding left: 10px right: 10px mobile
    Max width: 1200px
    Centered
    
    Heading:
    - Text: "COLLECTIONS"
    - Font: sans-serif bold
    - Size: 42px desktop / 28px mobile
    - Color: #111111
    - Align: left
    - Text transform: uppercase
    - Letter spacing: 2px
    - Margin bottom: 32px
    
    Collection Card:
    - Width: 100%
    - Border: 1px solid #e0e0e0
    - Border radius: 0px
    - Overflow: hidden
    - Background: transparent
    
    Image block inside card:
    - Image placeholder: [NEAPOLITAN-COLLECTION.png]
    - This is the second image provided
    - Width: 100%
    - Height: auto
    - Display: block
    - Object fit: cover
    -  border radius: 8px
    - No padding
    - No margin
    
    Below image — product info:
    - Padding top: 16px
    - Padding bottom: 8px
    - Background: #ffffff
    
      Product Title:
      - Text: "NEAPOLITAN HASH HOLE"
      - Font: sans-serif bold
      - Size: 18px
      - Color: #111111
      - Text transform: uppercase
      - Letter spacing: 1px
      - Margin bottom: 4px
    
      Product Price:
      - Text: "$60.00"
      - Font: sans-serif regular
      - Size: 18px
      - Color: #111111
      - Margin top: 4px, add some scrolling animation
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-card-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding-top: {{ block.settings.padding_top_desktop }}px;
    padding-bottom: {{ block.settings.padding_bottom_desktop }}px;
    padding-left: {{ block.settings.padding_left_desktop }}px;
    padding-right: {{ block.settings.padding_right_desktop }}px;
  }

  .ai-collection-card-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-collection-card-heading-{{ ai_gen_id }} {
    font-family: sans-serif;
    font-weight: bold;
    font-size: {{ block.settings.heading_size_desktop }}px;
    color: {{ block.settings.heading_color }};
    text-align: {{ block.settings.heading_alignment }};
    text-transform: uppercase;
    letter-spacing: {{ block.settings.heading_letter_spacing }}px;
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px 0;
    opacity: 0;
    transform: translateY(30px);
  }

  .ai-collection-card-heading-{{ ai_gen_id }}.ai-animate-in-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }

  .ai-collection-card-{{ ai_gen_id }} {
    width: 100%;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    background: {{ block.settings.card_background }};
    opacity: 0;
    transform: translateY(50px);
  }

  .ai-collection-card-{{ ai_gen_id }}.ai-animate-in-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.8s ease-out 0.2s, transform 0.8s ease-out 0.2s;
  }

  .ai-collection-card-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    display: block;
    margin: 0;
    padding: 0;
    overflow: hidden;
  }

  .ai-collection-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    border-radius: {{ block.settings.image_border_radius }}px;
    transform: scale(1.1);
    transition: transform 0.6s ease-out;
  }

  .ai-collection-card-{{ ai_gen_id }}.ai-animate-in-{{ ai_gen_id }} .ai-collection-card-image-{{ ai_gen_id }} {
    transform: scale(1);
  }

  .ai-collection-card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-collection-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-collection-card-info-{{ ai_gen_id }} {
    padding-top: {{ block.settings.info_padding_top }}px;
    padding-bottom: {{ block.settings.info_padding_bottom }}px;
    background: {{ block.settings.info_background }};
  }

  .ai-collection-card-title-{{ ai_gen_id }} {
    font-family: sans-serif;
    font-weight: bold;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    text-transform: uppercase;
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
    margin: 0 0 {{ block.settings.title_margin_bottom }}px 0;
    opacity: 0;
    transform: translateX(-20px);
  }

  .ai-collection-card-{{ ai_gen_id }}.ai-animate-in-{{ ai_gen_id }} .ai-collection-card-title-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateX(0);
    transition: opacity 0.6s ease-out 0.4s, transform 0.6s ease-out 0.4s;
  }

  .ai-collection-card-price-{{ ai_gen_id }} {
    font-family: sans-serif;
    font-weight: normal;
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    margin: {{ block.settings.price_margin_top }}px 0 0 0;
    opacity: 0;
    transform: translateX(-20px);
  }

  .ai-collection-card-{{ ai_gen_id }}.ai-animate-in-{{ ai_gen_id }} .ai-collection-card-price-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateX(0);
    transition: opacity 0.6s ease-out 0.5s, transform 0.6s ease-out 0.5s;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-card-section-{{ ai_gen_id }} {
      padding-left: {{ block.settings.padding_left_mobile }}px;
      padding-right: {{ block.settings.padding_right_mobile }}px;
    }

    .ai-collection-card-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-collection-card-heading-{{ ai_gen_id }},
    .ai-collection-card-{{ ai_gen_id }},
    .ai-collection-card-image-{{ ai_gen_id }},
    .ai-collection-card-title-{{ ai_gen_id }},
    .ai-collection-card-price-{{ ai_gen_id }} {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
{% endstyle %}

<collection-card-{{ ai_gen_id }} class="ai-collection-card-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collection-card-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-collection-card-heading-{{ ai_gen_id }}" data-animate>{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-collection-card-{{ ai_gen_id }}" data-animate>
      <div class="ai-collection-card-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.product_image %}
          <img
            src="{{ block.settings.product_image | image_url: width: 2000 }}"
            alt="{{ block.settings.product_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.product_image.width }}"
            height="{{ block.settings.product_image.height }}"
            class="ai-collection-card-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-collection-card-image-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="ai-collection-card-info-{{ ai_gen_id }}">
        {% if block.settings.product_title != blank %}
          <h3 class="ai-collection-card-title-{{ ai_gen_id }}">{{ block.settings.product_title }}</h3>
        {% endif %}

        {% if block.settings.product_price != blank %}
          <div class="ai-collection-card-price-{{ ai_gen_id }}">{{ block.settings.product_price }}</div>
        {% endif %}
      </div>
    </div>
  </div>
</collection-card-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionCard{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.observer = null;
      }

      connectedCallback() {
        this.setupScrollAnimation();
      }

      setupScrollAnimation() {
        const animateElements = this.querySelectorAll('[data-animate]');
        
        const observerOptions = {
          root: null,
          rootMargin: '0px 0px -100px 0px',
          threshold: 0.1
        };

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('ai-animate-in-{{ ai_gen_id }}');
              this.observer.unobserve(entry.target);
            }
          });
        }, observerOptions);

        animateElements.forEach((element) => {
          this.observer.observe(element);
        });
      }

      disconnectedCallback() {
        if (this.observer) {
          this.observer.disconnect();
        }
      }
    }

    customElements.define('collection-card-{{ ai_gen_id }}', CollectionCard{{ ai_gen_id }});
  })();
</script>

