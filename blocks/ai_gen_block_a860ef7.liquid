        </div>
        <div class="ai-mob-nav-row-{{ ai_gen_id }}">
          <a href="/pages/faq" class="ai-header-mobile-nav-link-{{ ai_gen_id }}">FAQ</a>
        </div>

      </nav>
    </div>
  </div>

</header-{{ ai_gen_id }}>

<!-- ── HEADER WISHLIST DRAWER (lives outside <header> so it can overlay full page) ── -->
<div class="ai-hdrawer-overlay-{{ ai_gen_id }}" id="aiHdrawerOverlay{{ ai_gen_id }}"></div>
<div class="ai-hdrawer-{{ ai_gen_id }}" id="aiHdrawer{{ ai_gen_id }}" role="dialog" aria-modal="true" aria-label="Wishlist">
  <div class="ai-hdrawer-header-{{ ai_gen_id }}">
    <p class="ai-hdrawer-title-{{ ai_gen_id }}">💗 Wishlist</p>
    <button class="ai-hdrawer-close-{{ ai_gen_id }}" id="aiHdrawerClose{{ ai_gen_id }}" aria-label="Close wishlist">✕</button>
  </div>
  <div class="ai-hdrawer-list-{{ ai_gen_id }}" id="aiHdrawerList{{ ai_gen_id }}"></div>
</div>

<script>
(function() {
  const WISH_KEY = 'sundaze_wishlist_v1';
  const GEN_ID   = '{{ ai_gen_id }}';

  /* ── Read wishlist count from localStorage ── */
  function getWishCount() {
    try { return JSON.parse(localStorage.getItem(WISH_KEY) || '[]').length; }
    catch(e) { return 0; }
  }

  /* ── Update all wishlist bubbles + heart fill in the header ── */
  function syncAllWishBubbles() {
    const count = getWishCount();
    document.querySelectorAll('.ai-header-wish-bubble-' + GEN_ID).forEach(function(bubble) {
      bubble.textContent = count > 0 ? count : '';
      bubble.classList.toggle('visible', count > 0);
    });
    document.querySelectorAll('.ai-header-wish-toggle-' + GEN_ID + ' svg').forEach(function(svg) {
      svg.setAttribute('fill', count > 0 ? 'currentColor' : 'none');
    });
  }

  /* ── Patch localStorage.setItem to fire custom event on wishlist change ── */
  (function() {
    const _orig = Storage.prototype.setItem;
    Storage.prototype.setItem = function(key, value) {
      _orig.apply(this, arguments);
      if (key === WISH_KEY) {
        document.dispatchEvent(new CustomEvent('wishlist:updated'));
      }
    };
  })();

  document.addEventListener('wishlist:updated', syncAllWishBubbles);
  window.addEventListener('storage', function(e) {
    if (e.key === WISH_KEY) syncAllWishBubbles();
  });

  syncAllWishBubbles();
  document.addEventListener('DOMContentLoaded', syncAllWishBubbles);
  setTimeout(syncAllWishBubbles, 300);
  setTimeout(syncAllWishBubbles, 800);
  setTimeout(syncAllWishBubbles, 1500);

  window.SundazeHeaderSyncWish = syncAllWishBubbles;

  /* ══════════════════════════════════════════════════════
     HEADER-NATIVE WISHLIST DRAWER
     Always available on every page. If a page-level drawer
     (NbpWish / NeoWish) is also present, we delegate to it.
     Otherwise we open our own built-in drawer.
  ══════════════════════════════════════════════════════ */
  const overlay    = document.getElementById('aiHdrawerOverlay' + GEN_ID);
  const drawer     = document.getElementById('aiHdrawer'        + GEN_ID);
  const closeBtn   = document.getElementById('aiHdrawerClose'   + GEN_ID);
  const listEl     = document.getElementById('aiHdrawerList'    + GEN_ID);

  function _loadList() {
    try { return JSON.parse(localStorage.getItem(WISH_KEY) || '[]'); } catch { return []; }
  }

  function _saveList(list) {
    localStorage.setItem(WISH_KEY, JSON.stringify(list));
  }

  function _renderDrawer() {
    const list = _loadList();
    if (list.length === 0) {
      listEl.innerHTML =
        '<div class="ai-hdrawer-empty-' + GEN_ID + '">' +
          '<div style="font-size:48px">🤍</div>' +
          '<p>Your wishlist is empty</p>' +
          '<p style="font-size:12px;opacity:.6">Tap a heart on any product to save it here</p>' +
        '</div>';
      return;
    }
    listEl.innerHTML = list.map(function(item) {
      const imgHtml = item.img
        ? '<img class="ai-hdrawer-item-img-' + GEN_ID + '" src="' + item.img + '" alt="' + item.name + '">'
        : '<div class="ai-hdrawer-item-placeholder-' + GEN_ID + '">🛍️</div>';
      return (
        '<div class="ai-hdrawer-item-' + GEN_ID + '">' +
          imgHtml +
          '<div class="ai-hdrawer-item-info-' + GEN_ID + '">' +
            '<p class="ai-hdrawer-item-name-' + GEN_ID + '">'  + item.name  + '</p>' +
            '<p class="ai-hdrawer-item-price-' + GEN_ID + '">' + (item.price || '') + '</p>' +
            '<div class="ai-hdrawer-item-actions-' + GEN_ID + '">' +
              '<button class="ai-hdrawer-add-btn-' + GEN_ID + '" ' +
                'onclick="window._AiHDrawer' + GEN_ID + '.addToCart(\'' + item.id + '\',\'' + item.name.replace(/'/g,"&#39;") + '\',this)">' +
                'Add to cart' +
              '</button>' +
              '<button class="ai-hdrawer-remove-btn-' + GEN_ID + '" ' +
                'onclick="window._AiHDrawer' + GEN_ID + '.remove(\'' + item.id + '\')">' +
                'Remove' +
              '</button>' +
            '</div>' +
          '</div>' +
        '</div>'
      );
    }).join('');
  }

  function openHeaderDrawer() {
    _renderDrawer();
    overlay.classList.add('active');
    drawer.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeHeaderDrawer() {
    overlay.classList.remove('active');
    drawer.classList.remove('active');
    document.body.style.overflow = '';
  }

  /* Public API for inline onclick handlers inside the drawer */
  window['_AiHDrawer' + GEN_ID] = {
    addToCart: function(id, name, btn) {
      btn.textContent = 'Adding…';
      btn.disabled = true;
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: parseInt(id, 10), quantity: 1 })
      })
      .then(function(r) { if (!r.ok) throw new Error(); return r.json(); })
      .then(function() {
        btn.textContent = '✓ Added!';
        document.dispatchEvent(new CustomEvent('cart:refresh'));
        setTimeout(function() { btn.textContent = 'Add to cart'; btn.disabled = false; }, 2000);
      })
      .catch(function() { btn.textContent = 'Error'; btn.disabled = false; });
    },
    remove: function(id) {
      _saveList(_loadList().filter(function(i) { return i.id !== id; }));
      syncAllWishBubbles();
      _renderDrawer();
    }
  };

  if (closeBtn) closeBtn.addEventListener('click', closeHeaderDrawer);
  if (overlay)  overlay.addEventListener('click',  closeHeaderDrawer);
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeHeaderDrawer();
  });

  /* Expose globally so the custom element can call it */
  window.SdzHeaderWish = { openDrawer: openHeaderDrawer };

  /* ══════════════════════════════════════════════════════
     CUSTOM ELEMENT
  ══════════════════════════════════════════════════════ */
  class Header extends HTMLElement {
    connectedCallback() {
      /* Use setTimeout(0) so the element is fully parsed before we query it */
      setTimeout(() => this._init(), 0);
    }

    _init() {
      this.menuToggle    = this.querySelector('.ai-header-mobile-menu-toggle-' + GEN_ID);
      this.navDrawer     = this.querySelector('.ai-header-mobile-drawer-'      + GEN_ID);
      this.navClose      = this.querySelector('.ai-header-mobile-drawer-close-' + GEN_ID);
      this.navOverlay    = this.querySelector('.ai-mob-overlay-'               + GEN_ID);
      this.searchDrawer  = this.querySelector('.ai-search-drawer-'             + GEN_ID);
      this.searchInput   = this.querySelector('.ai-search-input-'              + GEN_ID);
      this.searchClose   = this.querySelector('.ai-search-close-'              + GEN_ID);
      this.searchToggles = this.querySelectorAll('.ai-search-toggle-'          + GEN_ID);
      this.suggestions   = this.querySelector('.ai-search-suggestions-'        + GEN_ID);
      this.wishToggles   = this.querySelectorAll('.ai-header-wish-toggle-'     + GEN_ID);

      this._debounceTimer   = null;
      this._highlightIndex  = -1;
      this._suggestionItems = [];

      syncAllWishBubbles();

      /* ── DESKTOP PRODUCTS DROPDOWN ── */
      const prodWrap     = this.querySelector('.ai-products-dropdown-wrap-' + GEN_ID);
      const subWraps     = this.querySelectorAll('.ai-sub-dropdown-wrap-'   + GEN_ID);
      let   prodCloseTimer = null;

      if (prodWrap) {
        prodWrap.addEventListener('mouseenter', () => {
          clearTimeout(prodCloseTimer);
          prodWrap.classList.add('open');
        });
        prodWrap.addEventListener('mouseleave', () => {
          prodCloseTimer = setTimeout(() => {
            prodWrap.classList.remove('open');
            subWraps.forEach(sw => sw.classList.remove('open'));
          }, 120);
        });
      }

      subWraps.forEach(subWrap => {
        let subCloseTimer = null;
        const subDropdown = subWrap.querySelector('.ai-sub-dropdown-' + GEN_ID);

        subWrap.addEventListener('mouseenter', () => {
          clearTimeout(subCloseTimer);
          clearTimeout(prodCloseTimer);
          subWraps.forEach(sw => { if (sw !== subWrap) sw.classList.remove('open'); });
          subWrap.classList.add('open');
        });
        subWrap.addEventListener('mouseleave', () => {
          subCloseTimer = setTimeout(() => subWrap.classList.remove('open'), 100);
        });

        if (subDropdown) {
          subDropdown.addEventListener('mouseenter', () => {
            clearTimeout(subCloseTimer);
            clearTimeout(prodCloseTimer);
          });
          subDropdown.addEventListener('mouseleave', () => {
            subCloseTimer = setTimeout(() => subWrap.classList.remove('open'), 100);
          });
        }
      });

      /* ── MOBILE MENU ── */
      if (this.menuToggle) this.menuToggle.addEventListener('click', () => this.toggleNavDrawer());
      if (this.navClose)   this.navClose.addEventListener('click',   () => this.closeNavDrawer());
      if (this.navOverlay) this.navOverlay.addEventListener('click', () => this.closeNavDrawer());

      /* ── MOBILE ACCORDION ── */
      this.querySelectorAll('.ai-mob-accordion-toggle-' + GEN_ID).forEach(btn => {
        btn.addEventListener('click', () => {
          const targetId = btn.getAttribute('data-target');
          if (!targetId) return;
          const panel = document.getElementById(targetId);
          if (!panel) return;
          const isOpen = panel.classList.contains('open');
          panel.classList.toggle('open', !isOpen);
          this.querySelectorAll('.ai-mob-accordion-toggle-' + GEN_ID + '[data-target="' + targetId + '"]').forEach(b => {
            b.classList.toggle('open', !isOpen);
            b.setAttribute('aria-expanded', String(!isOpen));
          });
        });
      });

      /* ── SEARCH ── */
      this.searchToggles.forEach(btn => btn.addEventListener('click', () => this.toggleSearchDrawer()));
      if (this.searchClose) this.searchClose.addEventListener('click', () => this.closeSearchDrawer());
      if (this.searchInput) {
        this.searchInput.addEventListener('input',   () => this.onSearchInput());
        this.searchInput.addEventListener('keydown', (e) => this.onSearchKeydown(e));
      }

      /* ── WISHLIST TOGGLE ──
         Priority: NbpWish (bucket page) → NeoWish (hash holes page) → built-in header drawer
      ── */
      this.wishToggles.forEach(btn => {
        btn.addEventListener('click', () => {
          if (typeof window.NbpWish !== 'undefined' && typeof window.NbpWish.openDrawer === 'function') {
            window.NbpWish.openDrawer();
          } else if (typeof window.NeoWish !== 'undefined' && typeof window.NeoWish.openDrawer === 'function') {
            window.NeoWish.openDrawer();
          } else {
            openHeaderDrawer();
          }
        });
      });

      /* ── GLOBAL CLOSE ── */
      document.addEventListener('click', (e) => {
        if (!this.contains(e.target)) this.hideSuggestions();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          this.closeSearchDrawer();
          this.closeNavDrawer();
        }
      });
    }

    toggleNavDrawer() {
      this.navDrawer && this.navDrawer.classList.contains('active')
        ? this.closeNavDrawer()
        : this.openNavDrawer();
    }
    openNavDrawer() {
      this.closeSearchDrawer();
      this.navDrawer  && this.navDrawer.classList.add('active');
      this.navOverlay && this.navOverlay.classList.add('active');
      this.menuToggle && this.menuToggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    closeNavDrawer() {
      this.navDrawer  && this.navDrawer.classList.remove('active');
      this.navOverlay && this.navOverlay.classList.remove('active');
      this.menuToggle && this.menuToggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    toggleSearchDrawer() {
      this.searchDrawer && this.searchDrawer.classList.contains('active')
        ? this.closeSearchDrawer()
        : this.openSearchDrawer();
    }
    openSearchDrawer() {
      this.closeNavDrawer();
      this.searchDrawer && this.searchDrawer.classList.add('active');
      this.searchToggles.forEach(btn => btn.classList.add('active'));
      setTimeout(() => this.searchInput && this.searchInput.focus(), 50);
    }
    closeSearchDrawer() {
      this.searchDrawer && this.searchDrawer.classList.remove('active');
      this.searchToggles.forEach(btn => btn.classList.remove('active'));
      this.hideSuggestions();
    }

    onSearchInput() {
      const query = this.searchInput.value.trim();
      clearTimeout(this._debounceTimer);
      if (query.length < 2) { this.hideSuggestions(); return; }
      this._debounceTimer = setTimeout(() => this.fetchSuggestions(query), 200);
    }

    async fetchSuggestions(query) {
      try {
        const url = `/search/suggest.json?q=${encodeURIComponent(query)}&resources[type]=product,query&resources[limit]=5&resources[options][unavailable_products]=last`;
        const res = await fetch(url);
        if (!res.ok) return;
        const data = await res.json();
        this.renderSuggestions(query, data.resources.results);
      } catch(err) {
        console.error('Predictive search error:', err);
      }
    }

    renderSuggestions(query, results) {
      const products = results.products || [];
      const queries  = results.queries  || [];
      this.suggestions.innerHTML = '';
      this._highlightIndex = -1;

      if (products.length === 0 && queries.length === 0) {
        this.suggestions.innerHTML = `<div class="ai-search-no-results-${GEN_ID}">No results found for "${query}"</div>`;
        this.showSuggestions();
        return;
      }

      queries.slice(0, 3).forEach(q => {
        const el = document.createElement('div');
        el.className = 'ai-search-suggestion-query-' + GEN_ID;
        el.innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <span>${this.highlight(q.text, query)}</span>`;
        el.addEventListener('mousedown', (e) => {
          e.preventDefault();
          this.searchInput.value = q.text;
          this.searchInput.closest('form').submit();
        });
        this.suggestions.appendChild(el);
      });

      products.slice(0, 5).forEach(product => {
        const a = document.createElement('a');
        a.className = 'ai-search-suggestion-item-' + GEN_ID;
        a.href = product.url;
        const imgHtml = product.featured_image?.url
          ? `<img src="${product.featured_image.url}&width=80" alt="${product.title}" class="ai-search-suggestion-img-${GEN_ID}">`
          : `<div class="ai-search-suggestion-img-placeholder-${GEN_ID}">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(196,96,122,0.5)" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
              </svg>
            </div>`;
        const price = product.price
          ? `<span class="ai-search-suggestion-price-${GEN_ID}">${this.formatMoney(product.price)}</span>`
          : '';
        a.innerHTML = `${imgHtml}
          <div class="ai-search-suggestion-info-${GEN_ID}">
            <span class="ai-search-suggestion-title-${GEN_ID}">${this.highlight(product.title, query)}</span>
            ${price}
          </div>`;
        this.suggestions.appendChild(a);
      });

      this._suggestionItems = Array.from(
        this.suggestions.querySelectorAll(
          '.ai-search-suggestion-item-' + GEN_ID + ', .ai-search-suggestion-query-' + GEN_ID
        )
      );
      this.showSuggestions();
    }

    highlight(text, query) {
      const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      return text.replace(
        new RegExp(`(${escaped})`, 'gi'),
        '<mark style="background:transparent;color:#c4607a;font-weight:600;">$1</mark>'
      );
    }

    formatMoney(cents) {
      const symbol = {{ shop.money_format | json }};
      const amount = (cents / 100).toFixed(2);
      if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
        return Shopify.formatMoney(cents, symbol);
      }
      return '{{ shop.currency }} ' + amount;
    }

    showSuggestions() {
      this.suggestions.classList.add('visible');
      this.searchInput.setAttribute('aria-expanded', 'true');
    }

    hideSuggestions() {
      this.suggestions && this.suggestions.classList.remove('visible');
      this.searchInput && this.searchInput.setAttribute('aria-expanded', 'false');
      this._highlightIndex  = -1;
      this._suggestionItems = [];
    }

    onSearchKeydown(e) {
      if (!this.suggestions.classList.contains('visible')) return;
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        this._highlightIndex = Math.min(this._highlightIndex + 1, this._suggestionItems.length - 1);
        this.updateHighlight();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        this._highlightIndex = Math.max(this._highlightIndex - 1, -1);
        this.updateHighlight();
      } else if (e.key === 'Enter' && this._highlightIndex >= 0) {
        const item = this._suggestionItems[this._highlightIndex];
        if (item) { e.preventDefault(); item.dispatchEvent(new MouseEvent('mousedown')); }
      }
    }

    updateHighlight() {
      this._suggestionItems.forEach((item, i) => {
        item.classList.toggle('highlighted', i === this._highlightIndex);
      });
    }
  }

  /* Register the custom element using the generated ID as tag suffix */
  customElements.define('header-' + GEN_ID, Header);

})();
</script>

{% schema %}
