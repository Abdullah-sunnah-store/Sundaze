{% doc %}
  @prompt
    Sundaze Dawn theme header — gradient background updated to warm sunrise palette
    matching the About Us page and banner colors (#fff8e8 → #fde8f0).
    Products dropdown with sublinks. Predictive search drawer.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | replace: '-', '' | downcase %}

{% style %}
  .ai-header-{{ ai_gen_id }} {
    display: block;
    position: sticky;
    top: 0;
    z-index: 1100;
    background: linear-gradient(180deg,
      #fff8e8 0%,
      #fef0e4 35%,
      #fde8f0 100%
    );
    border-bottom: 1px solid rgba(196, 96, 122, 0.20);
    width: 100%;
    padding: 0px 0 10px;
    box-shadow: 0 2px 24px rgba(196, 96, 122, 0.08);
  }

  .ai-header-container-{{ ai_gen_id }} {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-header-gradient-line-{{ ai_gen_id }} {
    height: 1px;
    background: linear-gradient(90deg,
      transparent 0%,
      rgba(196, 96, 122, 0.30) 25%,
      rgba(212, 146, 110, 0.25) 50%,
      rgba(196, 96, 122, 0.30) 75%,
      transparent 100%
    );
    margin-top: 8px;
  }

  /* ── SEARCH DRAWER ── */
  .ai-search-drawer-{{ ai_gen_id }} {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background: linear-gradient(180deg, #fff8e8 0%, #fde8f0 100%);
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.3s ease;
    z-index: 998;
    border-top: 1px solid rgba(196, 96, 122, 0.15);
    box-shadow: 0 8px 24px rgba(196, 96, 122, 0.10);
  }

  .ai-search-drawer-{{ ai_gen_id }}.active {
    max-height: 120px;
  }

  .ai-search-drawer-inner-{{ ai_gen_id }} {
    max-width: 1100px;
    margin: 0 auto;
    padding: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-search-input-{{ ai_gen_id }} {
    flex: 1;
    background: rgba(255,255,255,0.72);
    border: 1px solid rgba(196, 96, 122, 0.28);
    border-radius: 8px;
    color: #1e1118;
    font-size: 15px;
    padding: 10px 16px;
    outline: none;
    font-family: 'DM Sans', sans-serif;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    width: 100%;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .ai-search-input-{{ ai_gen_id }}::placeholder {
    color: rgba(30, 17, 24, 0.40);
  }

  .ai-search-input-{{ ai_gen_id }}:focus {
    border-color: rgba(196, 96, 122, 0.55);
    box-shadow: 0 0 0 3px rgba(196, 96, 122, 0.10);
    background: rgba(255,255,255,0.92);
  }

  .ai-search-submit-{{ ai_gen_id }} {
    background: linear-gradient(135deg, #d4926e, #c4607a, #a84f6a);
    color: #ffffff;
    border: none;
    border-radius: 8px;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 600;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
    letter-spacing: 0.04em;
  }

  .ai-search-submit-{{ ai_gen_id }}:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  .ai-search-close-{{ ai_gen_id }} {
    background: none;
    border: none;
    color: rgba(30,17,24,0.45);
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s ease;
  }

  .ai-search-close-{{ ai_gen_id }}:hover { color: #c4607a; }

  .ai-search-close-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  /* ── SEARCH SUGGESTIONS ── */
  .ai-search-suggestions-{{ ai_gen_id }} {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    background: linear-gradient(180deg, #fff8e8 0%, #fef0e4 100%);
    border: 1px solid rgba(196, 96, 122, 0.22);
    border-radius: 12px;
    display: none;
    z-index: 9999;
    box-shadow: 0 12px 32px rgba(196, 96, 122, 0.14);
    max-height: 400px;
    overflow-y: auto;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .ai-search-suggestions-{{ ai_gen_id }}.visible { display: block; }

  .ai-search-suggestion-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    cursor: pointer;
    text-decoration: none;
    color: #1e1118;
    transition: background 0.15s ease;
    border-bottom: 1px solid rgba(196, 96, 122, 0.08);
  }

  .ai-search-suggestion-item-{{ ai_gen_id }}:last-child { border-bottom: none; }

  .ai-search-suggestion-item-{{ ai_gen_id }}:hover,
  .ai-search-suggestion-item-{{ ai_gen_id }}.highlighted {
    background: rgba(196, 96, 122, 0.08);
  }

  .ai-search-suggestion-img-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    object-fit: cover;
    border-radius: 6px;
    flex-shrink: 0;
    background: rgba(232,160,180,0.20);
  }

  .ai-search-suggestion-img-placeholder-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    background: rgba(232,160,180,0.20);
    border-radius: 6px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-search-suggestion-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }

  .ai-search-suggestion-title-{{ ai_gen_id }} {
    font-size: 14px;
    font-family: 'DM Sans', sans-serif;
    color: #1e1118;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ai-search-suggestion-price-{{ ai_gen_id }} {
    font-size: 12px;
    color: #c4607a;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
  }

  .ai-search-suggestion-query-{{ ai_gen_id }} {
    font-size: 14px;
    font-family: 'DM Sans', sans-serif;
    color: rgba(30,17,24,0.70);
    padding: 10px 14px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid rgba(196, 96, 122, 0.08);
    transition: background 0.15s ease;
  }

  .ai-search-suggestion-query-{{ ai_gen_id }}:hover,
  .ai-search-suggestion-query-{{ ai_gen_id }}.highlighted {
    background: rgba(196, 96, 122, 0.08);
    color: #1e1118;
  }

  .ai-search-suggestion-query-{{ ai_gen_id }} svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    color: rgba(30,17,24,0.35);
  }

  .ai-search-no-results-{{ ai_gen_id }} {
    padding: 16px 14px;
    font-size: 14px;
    color: rgba(30,17,24,0.45);
    font-family: 'DM Sans', sans-serif;
    text-align: center;
  }

  /* ── PRODUCTS DROPDOWN ── */
  .ai-products-dropdown-wrap-{{ ai_gen_id }} {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .ai-products-dropdown-wrap-{{ ai_gen_id }} > .ai-header-nav-link-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .ai-products-chevron-{{ ai_gen_id }} {
    width: 11px;
    height: 11px;
    transition: transform 0.22s ease;
    flex-shrink: 0;
  }

  .ai-products-dropdown-wrap-{{ ai_gen_id }}.open .ai-products-chevron-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-products-dropdown-{{ ai_gen_id }} {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    min-width: 190px;
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
    transition: opacity 0.2s ease, visibility 0.2s ease;
    z-index: 1999;
    overflow: visible;
    padding-top: 8px;
  }

  .ai-products-dropdown-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 8px;
    background: transparent;
  }

  .ai-products-dropdown-inner-{{ ai_gen_id }} {
    background: linear-gradient(180deg, #fff8e8 0%, #fef0e4 100%);
    border: 1px solid rgba(196, 96, 122, 0.22);
    border-radius: 12px;
    box-shadow: 0 12px 32px rgba(196, 96, 122, 0.15);
    overflow: visible;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .ai-products-dropdown-wrap-{{ ai_gen_id }}.open .ai-products-dropdown-{{ ai_gen_id }} {
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
  }

  .ai-dropdown-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 11px 16px;
    color: rgba(30,17,24,0.80);
    font-family: 'DM Sans', sans-serif;
    font-size: 13.5px;
    font-weight: 400;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
    white-space: nowrap;
    border-bottom: 1px solid rgba(196, 96, 122, 0.08);
    position: relative;
    cursor: pointer;
    border-radius: 0;
  }

  .ai-dropdown-item-{{ ai_gen_id }}:first-child { border-radius: 12px 12px 0 0; }
  .ai-dropdown-item-{{ ai_gen_id }}:last-child  { border-bottom: none; border-radius: 0 0 12px 12px; }
  .ai-dropdown-item-{{ ai_gen_id }}:only-child  { border-radius: 12px; }

  .ai-dropdown-item-{{ ai_gen_id }}:hover {
    background: rgba(196, 96, 122, 0.10);
    color: #c4607a;
  }

  .ai-sub-arrow-{{ ai_gen_id }} {
    font-size: 14px;
    color: rgba(196, 96, 122, 0.55);
    line-height: 1;
  }

  /* ── NESTED FLYOUT ── */
  .ai-sub-dropdown-wrap-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-sub-dropdown-{{ ai_gen_id }} {
    position: absolute;
    left: 100%;
    top: -4px;
    min-width: 165px;
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
    transition: opacity 0.18s ease, visibility 0.18s ease;
    z-index: 2000;
    padding-left: 0;
  }

  .ai-sub-dropdown-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    right: 100%;
    width: 4px;
    height: 100%;
    background: transparent;
  }

  .ai-sub-dropdown-inner-{{ ai_gen_id }} {
    background: linear-gradient(180deg, #fff8e8 0%, #fde8f0 100%);
    border: 1px solid rgba(196, 96, 122, 0.20);
    border-radius: 12px;
    box-shadow: 0 12px 32px rgba(196, 96, 122, 0.14);
    overflow: hidden;
    margin-left: 0;
  }

  .ai-sub-dropdown-wrap-{{ ai_gen_id }}.open .ai-sub-dropdown-{{ ai_gen_id }} {
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
  }

  /* ── WISHLIST BUBBLE — shared base ── */
  .ai-header-wish-bubble-{{ ai_gen_id }} {
    position: absolute;
    top: -6px;
    right: -6px;
    background: linear-gradient(135deg, #e8a0bf, #c4607a);
    color: #ffffff;
    border-radius: 50%;
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 600;
    line-height: 1;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
    transform: scale(0.6);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .ai-header-wish-bubble-{{ ai_gen_id }}.visible {
    opacity: 1;
    pointer-events: none;
    transform: scale(1);
  }

  /* ── DESKTOP ── */
  @media screen and (min-width: 990px) {
    .ai-header-content-{{ ai_gen_id }} {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    .ai-header-logo-row-{{ ai_gen_id }} { margin-bottom: 0px; }

    .ai-header-logo-{{ ai_gen_id }} {
      width: 180px;
      height: auto;
      display: block;
      margin-top: -10px;
    }

    .ai-header-nav-row-{{ ai_gen_id }} {
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: center;
      margin-top: -30px;
    }

    .ai-header-nav-{{ ai_gen_id }} {
      display: inline-flex;
      flex-direction: row;
      gap: 32px;
      align-items: center;
    }

    .ai-header-nav-link-{{ ai_gen_id }} {
      font-family: 'DM Sans', sans-serif;
      font-weight: 500;
      font-size: 15px;
      color: rgba(30,17,24,0.82);
      text-decoration: none;
      letter-spacing: 0.02em;
      transition: color 0.2s ease;
    }

    .ai-header-nav-link-{{ ai_gen_id }}:hover { color: #c4607a; }

    .ai-header-icons-{{ ai_gen_id }} {
      display: inline-flex;
      flex-direction: row;
      gap: 8px;
      margin-left: 32px;
      align-items: center;
    }

    .ai-header-icon-{{ ai_gen_id }} {
      width: 22px;
      height: 22px;
      color: rgba(30,17,24,0.72);
      cursor: pointer;
      transition: color 0.2s ease;
      background: none;
      border: none;
      padding: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
    }

    .ai-header-icon-{{ ai_gen_id }}:hover,
    .ai-header-icon-{{ ai_gen_id }}.active { color: #c4607a; }

    .ai-header-icon-{{ ai_gen_id }} svg { width: 22px; height: 22px; }

    .ai-header-wish-link-{{ ai_gen_id }} {
      position: relative;
      width: 22px;
      height: 22px;
      color: rgba(30,17,24,0.72);
      cursor: pointer;
      transition: color 0.2s ease;
      background: none;
      border: none;
      padding: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .ai-header-wish-link-{{ ai_gen_id }}:hover { color: #c4607a; }

    .ai-header-wish-link-{{ ai_gen_id }} svg {
      width: 22px;
      height: 22px;
      flex-shrink: 0;
      transition: fill 0.2s ease;
    }

    .ai-header-cart-link-{{ ai_gen_id }} {
      position: relative;
      width: 22px;
      height: 22px;
      color: rgba(30,17,24,0.72);
      transition: color 0.2s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
    }

    .ai-header-cart-link-{{ ai_gen_id }}:hover { color: #c4607a; }

    .ai-header-cart-link-{{ ai_gen_id }} svg {
      width: 22px;
      height: 22px;
      flex-shrink: 0;
    }

    .ai-header-cart-bubble-{{ ai_gen_id }} {
      position: absolute;
      top: -6px;
      right: -6px;
      background: linear-gradient(135deg, #d4926e, #c4607a);
      color: #ffffff;
      border-radius: 50%;
      width: 16px;
      height: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      font-weight: 600;
    }

    .ai-header-mobile-menu-toggle-{{ ai_gen_id }},
    .ai-header-mobile-drawer-{{ ai_gen_id }},
    .ai-mob-overlay-{{ ai_gen_id }} {
      display: none !important;
    }

    .ai-header-content-{{ ai_gen_id }} > .ai-header-icons-{{ ai_gen_id }} {
      display: none;
    }
  }

  /* ── MOBILE ── */
  @media screen and (max-width: 989px) {

    .ai-header-content-{{ ai_gen_id }} {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      grid-template-areas: 'menu logo icons';
      align-items: center;
    }

    .ai-header-mobile-menu-toggle-{{ ai_gen_id }} {
      grid-area: menu;
      justify-self: start;
      background: none;
      border: none;
      padding: 4px;
      cursor: pointer;
      color: rgba(30,17,24,0.72);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: color 0.2s ease;
      -webkit-tap-highlight-color: transparent;
    }

    .ai-header-mobile-menu-toggle-{{ ai_gen_id }}:hover { color: #c4607a; }
    .ai-header-mobile-menu-toggle-{{ ai_gen_id }} svg { width: 24px; height: 24px; }

    .ai-header-logo-row-{{ ai_gen_id }} {
      grid-area: logo;
      justify-self: center;
    }

    .ai-header-logo-{{ ai_gen_id }} {
      width: 130px;
      height: auto;
      display: block;
    }

    .ai-header-content-{{ ai_gen_id }} > .ai-header-icons-{{ ai_gen_id }} {
      grid-area: icons;
      justify-self: end;
      display: flex;
      flex-direction: row;
      gap: 4px;
      align-items: center;
      flex-wrap: nowrap;
    }

    .ai-header-icon-{{ ai_gen_id }} {
      width: 22px;
      height: 22px;
      color: rgba(30,17,24,0.72);
      cursor: pointer;
      background: none;
      border: none;
      padding: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      transition: color 0.2s ease;
      -webkit-tap-highlight-color: transparent;
      flex-shrink: 0;
    }

    .ai-header-icon-{{ ai_gen_id }}:hover,
    .ai-header-icon-{{ ai_gen_id }}.active { color: #c4607a; }

    .ai-header-icon-{{ ai_gen_id }} svg { width: 22px; height: 22px; }

    .ai-header-wish-link-{{ ai_gen_id }} {
      position: relative;
      width: 22px;
      height: 22px;
      color: rgba(30,17,24,0.72);
      cursor: pointer;
      background: none;
      border: none;
      padding: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: color 0.2s ease;
      -webkit-tap-highlight-color: transparent;
      flex-shrink: 0;
    }

    .ai-header-wish-link-{{ ai_gen_id }}:hover { color: #c4607a; }

    .ai-header-wish-link-{{ ai_gen_id }} svg {
      width: 22px;
      height: 22px;
      flex-shrink: 0;
      transition: fill 0.2s ease;
    }

    .ai-header-cart-link-{{ ai_gen_id }} {
      position: relative;
      width: 22px;
      height: 22px;
      color: rgba(30,17,24,0.72);
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      transition: color 0.2s ease;
      flex-shrink: 0;
    }

    .ai-header-cart-link-{{ ai_gen_id }}:hover { color: #c4607a; }

    .ai-header-cart-link-{{ ai_gen_id }} svg {
      width: 22px;
      height: 22px;
      flex-shrink: 0;
    }

    .ai-header-cart-bubble-{{ ai_gen_id }} {
      position: absolute;
      top: -6px;
      right: -6px;
      background: linear-gradient(135deg, #d4926e, #c4607a);
      color: #ffffff;
      border-radius: 50%;
      width: 16px;
      height: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      font-weight: 600;
    }

    .ai-header-nav-row-{{ ai_gen_id }},
    .ai-header-nav-{{ ai_gen_id }},
    .ai-products-dropdown-wrap-{{ ai_gen_id }},
    .ai-products-dropdown-{{ ai_gen_id }},
    .ai-sub-dropdown-{{ ai_gen_id }} {
      display: none !important;
    }

    /* ── OVERLAY ── */
    .ai-mob-overlay-{{ ai_gen_id }} {
      display: block;
      position: fixed;
      inset: 0;
      background: rgba(30,17,24,0.35);
      z-index: 9998;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
    }

    .ai-mob-overlay-{{ ai_gen_id }}.active {
      opacity: 1;
      pointer-events: auto;
    }

    /* ── MOBILE DRAWER ── */
    .ai-header-mobile-drawer-{{ ai_gen_id }} {
      position: fixed;
      top: 0;
      left: 0;
      width: 280px;
      height: 100vh;
      max-height: 100vh;
      background: linear-gradient(180deg, #fff8e8 0%, #fde8f0 100%);
      overflow-y: auto;
      transition: transform 0.3s ease, opacity 0.3s ease;
      z-index: 9999;
      transform: translateX(-100%);
      opacity: 0;
      border-right: 1px solid rgba(196, 96, 122, 0.18);
      box-shadow: 4px 0 32px rgba(196, 96, 122, 0.18);
    }

    .ai-header-mobile-drawer-{{ ai_gen_id }}.active {
      transform: translateX(0);
      opacity: 1;
    }

    .ai-header-mobile-drawer-content-{{ ai_gen_id }} {
      padding: 20px 20px 40px;
    }

    .ai-header-mobile-drawer-header-{{ ai_gen_id }} {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 20px;
    }

    .ai-header-mobile-drawer-close-{{ ai_gen_id }} {
      background: none;
      border: none;
      color: rgba(30,17,24,0.60);
      cursor: pointer;
      padding: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: color 0.2s ease;
      -webkit-tap-highlight-color: transparent;
    }

    .ai-header-mobile-drawer-close-{{ ai_gen_id }}:hover { color: #c4607a; }
    .ai-header-mobile-drawer-close-{{ ai_gen_id }} svg { width: 24px; height: 24px; }

    .ai-header-mobile-nav-{{ ai_gen_id }} {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .ai-mob-nav-row-{{ ai_gen_id }} {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 0;
      border-bottom: 1px solid rgba(196, 96, 122, 0.10);
    }

