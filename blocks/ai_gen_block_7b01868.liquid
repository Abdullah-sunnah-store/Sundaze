{% doc %}
  @prompt
    Light gray background section: #f7f7f7
    Width: 100%
    Padding top: 48px bottom: 48px
    Padding left: 20px right: 20px desktop
    Padding left: 10px right: 10px mobile
    Border radius on entire section: 20px
    
    Heading:
    - Text: "Premium Rosin-Infused"
    - Font: Georgia bold (or Playfair Display bold)
    - NOT italic
    - Size: 34px desktop / 24px mobile
    - Color: #111111
    - Align: center
    - Margin bottom: 14px
    
    Paragraph:
    - Text: "Crafted with 1.5G of whole bud flower and 0.5G of cold
      cure 90u–120u rosin derived from bubble hash, every Sundaze
      hand roll is made for smooth flavor, proper airflow, and a
      premium burn from first spark to final pull."
    - Font: system sans-serif regular
    - Size: 15px
    - Color: #555555
    - Align: center
    - Line height: 1.7
    - Max width: 500px
    - Centered horizontally
    - Margin bottom: 32px
    
    4 Badge Cards in ONE horizontal row:
    - Width: 100%
    - Layout: 4 equal columns desktop / 2 columns mobile
    - Gap: 12px
    - No outer border on row
    
    Card 1 — No Smalls:
    - Background: #ffffff
    - Border radius: 14px
    - Padding: 24px 16px
    - Box shadow: 0px 1px 6px rgba(0,0,0,0.07)
    - Align: center
    - Icon: [NO-SMALLS-ICON.png]
    - Icon size: 64px x 64px
    - Icon margin bottom: 10px
    - Label: "No Smalls"
    - Label font: sans-serif semi-bold
    - Label size: 13px
    - Label color: #111111
    - Label align: center
    
    Card 2 — No Trim:
    - Background: #ffffff
    - Border radius: 14px
    - Padding: 24px 16px
    - Box shadow: 0px 1px 6px rgba(0,0,0,0.07)
    - Align: center
    - Icon: [NO-TRIM-ICON.png]
    - Icon size: 64px x 64px
    - Icon margin bottom: 10px
    - Label: "No Trim"
    - Label font: sans-serif semi-bold
    - Label size: 13px
    - Label color: #111111
    - Label align: center
    
    Card 3 — Cold Cure Rosin:
    - Background: #ffffff
    - Border radius: 14px
    - Padding: 24px 16px
    - Box shadow: 0px 1px 6px rgba(0,0,0,0.07)
    - Align: center
    - Icon: [COLD-CURE-ICON.png]
    - Icon size: 64px x 64px
    - Icon margin bottom: 10px
    - Label: "Cold Cure" line break "Rosin"
    - Label font: sans-serif semi-bold
    - Label size: 13px
    - Label color: #111111
    - Label align: center
    
    Card 4 — Fully Flushed:
    - Background: #ffffff
    - Border radius: 14px
    - Padding: 24px 20px
    - Box shadow: 0px 1px 6px rgba(0,0,0,0.07)
    - Text align: left
    
      Top row — icon + title side by side:
      - Icon: [FULLY-FLUSHED-ICON.png]
      - Icon size: 24px x 24px
      - Icon color: teal/mint #4db8a4
      - Gap between icon and title: 8px
      - Title: "Fully Flushed"
      - Title font: sans-serif bold
      - Title size: 14px
      - Title color: #111111
    
      Below top row:
      - Subtext: "Flushed before harvest to support white ash
        and a cleaner, smoother burn."
      - Font: sans-serif regular
      - Size: 12px
      - Color: #777777
      - Line height: 1.6
      - Margin top: 8px
      - Text align: left, Light gray background section: #f7f7f7
