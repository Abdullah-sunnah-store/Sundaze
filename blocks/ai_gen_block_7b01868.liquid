{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-rosin-section-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.section_bg_color }};
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_desktop }}px {{ block.settings.section_padding_bottom }}px {{ block.settings.section_padding_desktop }}px;
    border-radius: 0;
  }

  .ai-rosin-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: normal;
    font-size: {{ block.settings.heading_size_desktop }}px;
    color: {{ block.settings.heading_color }};
    text-align: center;
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px 0;
  }

  .ai-rosin-paragraph-{{ ai_gen_id }} {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    font-weight: 400;
    font-size: {{ block.settings.paragraph_size }}px;
    color: {{ block.settings.paragraph_color }};
    text-align: center;
    line-height: {{ block.settings.paragraph_line_height }};
    max-width: {{ block.settings.paragraph_max_width }}px;
    margin: 0 auto {{ block.settings.paragraph_margin_bottom }}px auto;
  }

  .ai-rosin-badges-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    gap: {{ block.settings.badge_gap }}px;
    width: 100%;
  }

  .ai-rosin-badge-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
    border-radius: {{ block.settings.badge_border_radius }}px;
    padding: {{ block.settings.badge_padding_vertical }}px {{ block.settings.badge_padding_horizontal }}px;
    text-align: center;
  }

  .ai-rosin-badge-1-{{ ai_gen_id }} {
    background-color: {{ block.settings.badge_1_bg_color }};
    box-shadow: {{ block.settings.badge_1_shadow }};
  }

  .ai-rosin-badge-2-{{ ai_gen_id }} {
    background-color: {{ block.settings.badge_2_bg_color }};
    box-shadow: {{ block.settings.badge_2_shadow }};
  }

  .ai-rosin-badge-3-{{ ai_gen_id }} {
    background-color: {{ block.settings.badge_3_bg_color }};
    box-shadow: {{ block.settings.badge_3_shadow }};
  }

  .ai-rosin-badge-4-{{ ai_gen_id }} {
    background-color: {{ block.settings.badge_4_bg_color }};
    box-shadow: {{ block.settings.badge_4_shadow }};
    padding: {{ block.settings.badge_padding_vertical }}px {{ block.settings.badge_4_padding_horizontal }}px;
  }

  .ai-rosin-badge-icon-{{ ai_gen_id }} {
    width: {{ block.settings.badge_icon_size }}px;
    height: {{ block.settings.badge_icon_size }}px;
    margin: 0 auto {{ block.settings.badge_icon_margin_bottom }}px auto;
    display: block;
  }

  .ai-rosin-badge-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-rosin-badge-label-{{ ai_gen_id }} {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    font-weight: 600;
    font-size: {{ block.settings.badge_label_size }}px;
    color: {{ block.settings.badge_label_color }};
    text-align: center;
    margin: 0;
    white-space: pre-line;
  }

  .ai-rosin-badge-flushed-{{ ai_gen_id }} {
    text-align: left;
  }

  .ai-rosin-badge-flushed-top-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: {{ block.settings.flushed_icon_gap }}px;
    margin-bottom: {{ block.settings.flushed_subtext_margin_top }}px;
  }

  .ai-rosin-badge-flushed-icon-{{ ai_gen_id }} {
    width: {{ block.settings.flushed_icon_size }}px;
    height: {{ block.settings.flushed_icon_size }}px;
    flex-shrink: 0;
  }

  .ai-rosin-badge-flushed-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-rosin-badge-flushed-title-{{ ai_gen_id }} {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    font-weight: 700;
    font-size: {{ block.settings.flushed_title_size }}px;
    color: {{ block.settings.badge_label_color }};
    margin: 0;
  }

  .ai-rosin-badge-flushed-subtext-{{ ai_gen_id }} {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    font-weight: 400;
    font-size: {{ block.settings.flushed_subtext_size }}px;
    color: {{ block.settings.flushed_subtext_color }};
    line-height: {{ block.settings.flushed_subtext_line_height }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-rosin-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_mobile }}px {{ block.settings.section_padding_bottom }}px {{ block.settings.section_padding_mobile }}px;
    }

    .ai-rosin-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-rosin-badges-{{ ai_gen_id }} {
      flex-wrap: wrap;
    }

    .ai-rosin-badge-{{ ai_gen_id }} {
      flex: 0 0 calc(50% - 6px);
    }
  }
{% endstyle %}

<div class="ai-rosin-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <h2 class="ai-rosin-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  
  <p class="ai-rosin-paragraph-{{ ai_gen_id }}">{{ block.settings.paragraph }}</p>

  <div class="ai-rosin-badges-{{ ai_gen_id }}">
    <div class="ai-rosin-badge-{{ ai_gen_id }} ai-rosin-badge-1-{{ ai_gen_id }}">
      {% if block.settings.badge_1_icon %}
        <div class="ai-rosin-badge-icon-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.badge_1_icon | image_url: width: 128 }}"
            alt="{{ block.settings.badge_1_label }}"
            loading="lazy"
            width="64"
            height="64"
          >
        </div>
      {% endif %}
      <p class="ai-rosin-badge-label-{{ ai_gen_id }}">{{ block.settings.badge_1_label }}</p>
    </div>

    <div class="ai-rosin-badge-{{ ai_gen_id }} ai-rosin-badge-2-{{ ai_gen_id }}">
      {% if block.settings.badge_2_icon %}
        <div class="ai-rosin-badge-icon-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.badge_2_icon | image_url: width: 128 }}"
            alt="{{ block.settings.badge_2_label }}"
            loading="lazy"
            width="64"
            height="64"
          >
        </div>
      {% endif %}
      <p class="ai-rosin-badge-label-{{ ai_gen_id }}">{{ block.settings.badge_2_label }}</p>
    </div>

    <div class="ai-rosin-badge-{{ ai_gen_id }} ai-rosin-badge-3-{{ ai_gen_id }}">
      {% if block.settings.badge_3_icon %}
        <div class="ai-rosin-badge-icon-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.badge_3_icon | image_url: width: 128 }}"
            alt="{{ block.settings.badge_3_label }}"
            loading="lazy"
            width="64"
            height="64"
          >
        </div>
      {% endif %}
      <p class="ai-rosin-badge-label-{{ ai_gen_id }}">{{ block.settings.badge_3_label }}</p>
    </div>

    <div class="ai-rosin-badge-{{ ai_gen_id }} ai-rosin-badge-4-{{ ai_gen_id }} ai-rosin-badge-flushed-{{ ai_gen_id }}">
      <div class="ai-rosin-badge-flushed-top-{{ ai_gen_id }}">
        {% if block.settings.badge_4_icon %}
          <div class="ai-rosin-badge-flushed-icon-{{ ai_gen_id }}">
            <img
              src="{{ block.settings.badge_4_icon | image_url: width: 48 }}"
              alt="{{ block.settings.badge_4_title }}"
              loading="lazy"
              width="24"
              height="24"
            >
          </div>
        {% endif %}
        <p class="ai-rosin-badge-flushed-title-{{ ai_gen_id }}">{{ block.settings.badge_4_title }}</p>
      </div>
      <p class="ai-rosin-badge-flushed-subtext-{{ ai_gen_id }}">{{ block.settings.badge_4_subtext }}</p>
    </div>
  </div>
</div>

