{% doc %}
  @prompt
    Full black background section. Width 100%.
    Background: #000000
    Padding top: 0px bottom: 0px
    No padding left or right
    
    Image block:
    - Image placeholder: [HASH-HOLE-CROSSSECTION.png]
    - This is the top view cross section product image
    - Width: 100%
    - Height: auto
    - Display: block
    - Object fit: cover
    - No border radius
    - No padding
    - No margin
    - Background behind image: 
      linear-gradient(
      to bottom,
      #ffffff top 0%,
      #000000 bottom 100%
      )
    - Fade effect top: white fades into black
    - Fade effect bottom: fully black
    
    Below image — text content:
    - Background: #000000
    - Padding top: 48px bottom: 48px
    - Padding left: 20px right: 20px desktop
    - Padding left: 10px right: 10px mobile
    - Text align: center
    
    Main Heading:
    - Text: "WHATS INSIDE"
    - Font: sans-serif black / extrabold
    - Size: 64px desktop / 40px mobile
    - Color: #ffffff
    - Text transform: uppercase
    - Letter spacing: 4px
    - Margin bottom: 40px
    
    Block 1 — Cold Cure Rosin:
    - Heading text: "90U-120U COLD CURE ROSIN"
    - Font: sans-serif bold
    - Size: 16px
    - Color: #ffffff
    - Text transform: uppercase
    - Letter spacing: 2px
    - Margin bottom: 8px
    
    - Subtext: "MADE FROM OUR FRESH FROZEN WHOLE
      PLANT CANNABIS FLOWER"
    - Font: sans-serif regular
    - Size: 14px
    - Color: #aaaaaa
    - Text transform: uppercase
    - Letter spacing: 1px
    - Align: center
    - Margin bottom: 40px
    
    Block 2 — Rosin Worm:
    - Heading text: "OUR ROSIN WORM"
    - Font: sans-serif bold
    - Size: 16px
    - Color: #ffffff
    - Text transform: uppercase
    - Letter spacing: 2px
    - Margin bottom: 8px
    
    - Subtext: "PERFECTLY CURATED DIRECTLY IN THE
      MIDDLE. EACH OF OUR HAND ROLLED HASH
      HOLES IS OUR ROSIN WORM EVENLY PLACED
      TO GIVE A PERFECT EVEN HIT WITH ZERO
      CLOG AND EVEN BURN."
    - Font: sans-serif regular
    - Size: 14px
    - Color: #aaaaaa
    - Text transform: uppercase
    - Letter spacing: 1px
    - Align: center
    - Margin bottom: 40px
    
    Block 3 — How To Smoke:
    - Heading text: "HOW TO SMOKE"
    - Font: sans-serif bold
    - Size: 16px
    - Color: #ffffff
    - Text transform: uppercase
    - Letter spacing: 2px
    - Margin bottom: 32px
    
    Tip 1 — Start Slow:
    - Icon: pause symbol ⏸
    - Icon size: 48px
    - Icon color: #ffffff
    - Margin bottom: 12px
    - Title: "START SLOW"
    - Font: sans-serif black italic
    - Size: 28px
    - Color: #ffffff
    - Letter spacing: 2px
    - Margin bottom: 12px
    - Body text: "Due to their potency, take a few gentle
      puffs and pause to appreciate the complex
      flavors and effects."
    - Font: sans-serif regular
    - Size: 15px
    - Color: #cccccc
    - Align: center
    - Line height: 1.7
    - Margin bottom: 48px
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hash-hole-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: #000000;
    padding: 0;
  }

  .ai-hash-hole-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    background: linear-gradient(to bottom, #ffffff 0%, #000000 100%);
  }

  .ai-hash-hole-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-hash-hole-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    background: linear-gradient(to bottom, #ffffff 0%, #000000 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 400px;
  }

  .ai-hash-hole-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 600px;
  }

  .ai-hash-hole-content-{{ ai_gen_id }} {
    background-color: #000000;
    padding: 48px 20px;
    text-align: center;
  }

  .ai-hash-hole-main-heading-{{ ai_gen_id }} {
    font-family: sans-serif;
    font-weight: 900;
    font-size: 64px;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 4px;
    margin: 0 0 40px 0;
  }

  .ai-hash-hole-block-{{ ai_gen_id }} {
    margin-bottom: 40px;
  }

  .ai-hash-hole-block-heading-{{ ai_gen_id }} {
    font-family: sans-serif;
    font-weight: 700;
    font-size: 16px;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin: 0 0 8px 0;
  }

  .ai-hash-hole-block-subtext-{{ ai_gen_id }} {
    font-family: sans-serif;
    font-weight: 400;
    font-size: 14px;
    color: #aaaaaa;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-align: center;
    margin: 0;
  }

  .ai-hash-hole-how-to-heading-{{ ai_gen_id }} {
    font-family: sans-serif;
    font-weight: 700;
    font-size: 16px;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin: 0 0 32px 0;
  }

  .ai-hash-hole-tip-{{ ai_gen_id }} {
    margin-bottom: 48px;
  }

  .ai-hash-hole-tip-icon-{{ ai_gen_id }} {
    font-size: 48px;
    color: #ffffff;
    margin-bottom: 12px;
  }

  .ai-hash-hole-tip-title-{{ ai_gen_id }} {
    font-family: sans-serif;
    font-weight: 900;
    font-style: italic;
    font-size: 28px;
    color: #ffffff;
    letter-spacing: 2px;
    margin: 0 0 12px 0;
  }

  .ai-hash-hole-tip-body-{{ ai_gen_id }} {
    font-family: sans-serif;
    font-weight: 400;
    font-size: 15px;
    color: #cccccc;
    text-align: center;
    line-height: 1.7;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-hash-hole-content-{{ ai_gen_id }} {
      padding: 48px 10px;
    }

    .ai-hash-hole-main-heading-{{ ai_gen_id }} {
      font-size: 40px;
    }
  }
{% endstyle %}

<hash-hole-section-{{ ai_gen_id }} class="ai-hash-hole-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hash-hole-image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.product_image %}
      <img
        src="{{ block.settings.product_image | image_url: width: 2000 }}"
        alt="{{ block.settings.product_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.product_image.width }}"
        height="{{ block.settings.product_image.height }}"
        class="ai-hash-hole-image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-hash-hole-image-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-hash-hole-content-{{ ai_gen_id }}">
    <h2 class="ai-hash-hole-main-heading-{{ ai_gen_id }}">{{ block.settings.main_heading }}</h2>

    <div class="ai-hash-hole-block-{{ ai_gen_id }}">
      <h3 class="ai-hash-hole-block-heading-{{ ai_gen_id }}">{{ block.settings.block_1_heading }}</h3>
      <p class="ai-hash-hole-block-subtext-{{ ai_gen_id }}">{{ block.settings.block_1_subtext }}</p>
    </div>

    <div class="ai-hash-hole-block-{{ ai_gen_id }}">
      <h3 class="ai-hash-hole-block-heading-{{ ai_gen_id }}">{{ block.settings.block_2_heading }}</h3>
      <p class="ai-hash-hole-block-subtext-{{ ai_gen_id }}">{{ block.settings.block_2_subtext }}</p>
    </div>

    <div class="ai-hash-hole-block-{{ ai_gen_id }}">
      <h3 class="ai-hash-hole-how-to-heading-{{ ai_gen_id }}">{{ block.settings.how_to_heading }}</h3>

      <div class="ai-hash-hole-tip-{{ ai_gen_id }}">
        <div class="ai-hash-hole-tip-icon-{{ ai_gen_id }}">{{ block.settings.tip_1_icon }}</div>
        <h4 class="ai-hash-hole-tip-title-{{ ai_gen_id }}">{{ block.settings.tip_1_title }}</h4>
        <p class="ai-hash-hole-tip-body-{{ ai_gen_id }}">{{ block.settings.tip_1_body }}</p>
      </div>
    </div>
  </div>
</hash-hole-section-{{ ai_gen_id }}>

<script>
  (function() {
    class HashHoleSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('hash-hole-section-{{ ai_gen_id }}', HashHoleSection{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Hash hole cross section",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product cross section image"
    },
    {
      "type": "header",
      "content": "Main heading"
    },
    {
      "type": "text",
      "id": "main_heading",
      "label": "Heading text",
      "default": "WHATS INSIDE"
    },
    {
      "type": "header",
      "content": "Cold cure rosin"
    },
    {
      "type": "text",
      "id": "block_1_heading",
      "label": "Heading",
      "default": "90U-120U COLD CURE ROSIN"
    },
    {
      "type": "textarea",
      "id": "block_1_subtext",
      "label": "Subtext",
      "default": "MADE FROM OUR FRESH FROZEN WHOLE PLANT CANNABIS FLOWER"
    },
    {
      "type": "header",
      "content": "Rosin worm"
    },
    {
      "type": "text",
      "id": "block_2_heading",
      "label": "Heading",
      "default": "OUR ROSIN WORM"
    },
    {
      "type": "textarea",
      "id": "block_2_subtext",
      "label": "Subtext",
      "default": "PERFECTLY CURATED DIRECTLY IN THE MIDDLE. EACH OF OUR HAND ROLLED HASH HOLES IS OUR ROSIN WORM EVENLY PLACED TO GIVE A PERFECT EVEN HIT WITH ZERO CLOG AND EVEN BURN."
    },
    {
      "type": "header",
      "content": "How to smoke"
    },
    {
      "type": "text",
      "id": "how_to_heading",
      "label": "Section heading",
      "default": "HOW TO SMOKE"
    },
    {
      "type": "text",
      "id": "tip_1_icon",
      "label": "Tip icon",
      "default": "⏸"
    },
    {
      "type": "text",
      "id": "tip_1_title",
      "label": "Tip title",
      "default": "START SLOW"
    },
    {
      "type": "textarea",
      "id": "tip_1_body",
      "label": "Tip description",
      "default": "Due to their potency, take a few gentle puffs and pause to appreciate the complex flavors and effects."
    }
  ],
  "presets": [
    {
      "name": "Hash hole cross section"
    }
  ]
}
{% endschema %}
