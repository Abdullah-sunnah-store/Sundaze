{% doc %}
  @prompt
    Sundaze Dawn theme footer — warm sunrise palette matching header.
    Hardcoded logo. Full schema inputs for social media URLs, category links, quick links.
    Forces background override on Shopify section wrapper.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | replace: '-', '' | downcase %}

{% style %}

  /* ── FORCE OVERRIDE SHOPIFY SECTION WRAPPER BACKGROUND ── */
  .shopify-section:has(.ai-footer-{{ ai_gen_id }}),
  section:has(.ai-footer-{{ ai_gen_id }}) {
    background: linear-gradient(180deg, #fde8f0 0%, #fef0e4 50%, #fff8e8 100%) !important;
    background-color: #fde8f0 !important;
  }

  /* ── WRAPPER ── */
  .ai-footer-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: linear-gradient(180deg, #fde8f0 0%, #fef0e4 50%, #fff8e8 100%) !important;
    background-color: #fde8f0 !important;
    border-top: 1px solid rgba(196, 96, 122, 0.20);
    padding: 60px 0 0;
    font-family: 'DM Sans', sans-serif;
    box-shadow: 0 -2px 24px rgba(196, 96, 122, 0.06);
  }

  .ai-footer-inner-{{ ai_gen_id }} {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* ── MAIN ROW ── */
  .ai-footer-main-row-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    gap: 40px;
    padding-bottom: 52px;
  }

  /* ── COLUMN 1 — BRAND ── */
  .ai-footer-column-brand-{{ ai_gen_id }} {
    max-width: 340px;
    flex-shrink: 0;
  }

  .ai-footer-logo-{{ ai_gen_id }} {
    width: 180px;
    height: auto;
    display: block;
  }

  .ai-footer-brand-text-{{ ai_gen_id }} {
    margin-top: 20px;
    font-size: 12.5px;
    line-height: 1.8;
    color: rgba(30, 17, 24, 0.55);
  }

  /* ── COLUMN HEADINGS ── */
  .ai-footer-column-heading-{{ ai_gen_id }} {
    font-size: 11px;
    font-weight: 700;
    color: rgba(30, 17, 24, 0.40);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin: 0 0 20px;
  }

  /* ── SOCIAL LINKS ── */
  .ai-footer-social-links-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .ai-footer-social-link-{{ ai_gen_id }} {
    display: inline-flex;
    flex-direction: row;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: rgba(30, 17, 24, 0.78);
    transition: color 0.2s ease;
  }

  .ai-footer-social-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    transition: color 0.2s ease;
  }

  .ai-footer-social-text-{{ ai_gen_id }} {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }

  .ai-footer-social-link-{{ ai_gen_id }}:hover { color: #c4607a; }

  /* ── NAV LINKS ── */
  .ai-footer-nav-links-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-footer-nav-link-{{ ai_gen_id }} {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(30, 17, 24, 0.78);
    transition: color 0.2s ease;
  }

  .ai-footer-nav-link-{{ ai_gen_id }}:hover { color: #c4607a; }

  /* ── GRADIENT ACCENT LINE ── */
  .ai-footer-gradient-line-{{ ai_gen_id }} {
    height: 1px;
    background: linear-gradient(90deg,
      transparent 0%,
      rgba(196, 96, 122, 0.30) 25%,
      rgba(212, 146, 110, 0.25) 50%,
      rgba(196, 96, 122, 0.30) 75%,
      transparent 100%
    );
    margin: 0;
  }

  /* ── BOTTOM BAR ── */
  .ai-footer-bottom-bar-{{ ai_gen_id }} {
    background: transparent;
    padding: 18px 0;
    text-align: center;
  }

  .ai-footer-copyright-{{ ai_gen_id }} {
    font-size: 12px;
    color: rgba(30, 17, 24, 0.38);
    font-family: 'DM Sans', sans-serif;
    margin: 0;
    letter-spacing: 0.2px;
  }

  /* ── MOBILE ── */
  @media screen and (max-width: 767px) {
    .ai-footer-{{ ai_gen_id }} { padding: 40px 0 0; }

    .ai-footer-main-row-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 36px;
      padding-bottom: 40px;
    }

    .ai-footer-column-brand-{{ ai_gen_id }} { max-width: 100%; }
    .ai-footer-logo-{{ ai_gen_id }} { width: 140px; }
    .ai-footer-brand-text-{{ ai_gen_id }} { font-size: 12px; }
    .ai-footer-column-heading-{{ ai_gen_id }} { margin-bottom: 14px; }
    .ai-footer-copyright-{{ ai_gen_id }} { font-size: 11px; }
  }

{% endstyle %}

<footer-block-{{ ai_gen_id }} class="ai-footer-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-footer-inner-{{ ai_gen_id }}">
    <div class="ai-footer-main-row-{{ ai_gen_id }}">

      <!-- ── COLUMN 1: BRAND ── -->
      <div class="ai-footer-column-brand-{{ ai_gen_id }}">
        <a href="/">
          <img
            src="https://cdn.shopify.com/s/files/1/0723/7949/8657/files/SUNDAZE_WEB_LOGO.png?v=1778389375"
            alt="{{ shop.name }}"
            class="ai-footer-logo-{{ ai_gen_id }}"
            loading="lazy"
            width="180"
          >
        </a>

        {% if block.settings.brand_description != blank %}
          <p class="ai-footer-brand-text-{{ ai_gen_id }}">
            {{ block.settings.brand_description }}
          </p>
        {% endif %}
      </div>

      <!-- ── COLUMN 2: FOLLOW US ── -->
      <div>
        <p class="ai-footer-column-heading-{{ ai_gen_id }}">Follow Us</p>
        <div class="ai-footer-social-links-{{ ai_gen_id }}">

          <!-- Instagram -->
          <a href="{{ block.settings.instagram_url | default: '#' }}" class="ai-footer-social-link-{{ ai_gen_id }}" {% if block.settings.instagram_url != blank %}target="_blank" rel="noopener noreferrer"{% endif %} aria-label="Instagram">
            <svg class="ai-footer-social-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
            <span class="ai-footer-social-text-{{ ai_gen_id }}">{{ block.settings.instagram_label | default: 'Instagram' }}</span>
          </a>

          <!-- YouTube
          <a href="{{ block.settings.youtube_url | default: '#' }}" class="ai-footer-social-link-{{ ai_gen_id }}" {% if block.settings.youtube_url != blank %}target="_blank" rel="noopener noreferrer"{% endif %} aria-label="YouTube">
            <svg class="ai-footer-social-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/>
              <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/>
            </svg>
            <span class="ai-footer-social-text-{{ ai_gen_id }}">{{ block.settings.youtube_label | default: 'YouTube' }}</span>
          </a> -->

          <!-- TikTok -->
          <a href="{{ block.settings.tiktok_url | default: '#' }}" class="ai-footer-social-link-{{ ai_gen_id }}" {% if block.settings.tiktok_url != blank %}target="_blank" rel="noopener noreferrer"{% endif %} aria-label="TikTok">
            <svg class="ai-footer-social-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/>
            </svg>
            <span class="ai-footer-social-text-{{ ai_gen_id }}">{{ block.settings.tiktok_label | default: 'TikTok' }}</span>
          </a>

          <!-- X / Twitter -->
          <a href="{{ block.settings.x_url | default: '#' }}" class="ai-footer-social-link-{{ ai_gen_id }}" {% if block.settings.x_url != blank %}target="_blank" rel="noopener noreferrer"{% endif %} aria-label="X.com">
            <svg class="ai-footer-social-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
            <span class="ai-footer-social-text-{{ ai_gen_id }}">{{ block.settings.x_label | default: 'X.com' }}</span>
          </a>

          <!-- Facebook
          <a href="{{ block.settings.facebook_url | default: '#' }}" class="ai-footer-social-link-{{ ai_gen_id }}" {% if block.settings.facebook_url != blank %}target="_blank" rel="noopener noreferrer"{% endif %} aria-label="Facebook">
            <svg class="ai-footer-social-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
            <span class="ai-footer-social-text-{{ ai_gen_id }}">{{ block.settings.facebook_label | default: 'Facebook' }}</span>
          </a>
 -->
        </div>
      </div>

      <!-- ── COLUMN 3: CATEGORY ── -->
      <div>
        <p class="ai-footer-column-heading-{{ ai_gen_id }}">
          {{ block.settings.category_heading | default: 'Category' }}
        </p>
        <div class="ai-footer-nav-links-{{ ai_gen_id }}">
          {% if block.settings.cat_link_1_label != blank and block.settings.cat_link_1_url != blank %}
            <a href="{{ block.settings.cat_link_1_url }}" class="ai-footer-nav-link-{{ ai_gen_id }}">{{ block.settings.cat_link_1_label }}</a>
          {% endif %}
          {% if block.settings.cat_link_2_label != blank and block.settings.cat_link_2_url != blank %}
            <a href="{{ block.settings.cat_link_2_url }}" class="ai-footer-nav-link-{{ ai_gen_id }}">{{ block.settings.cat_link_2_label }}</a>
          {% endif %}
          {% if block.settings.cat_link_3_label != blank and block.settings.cat_link_3_url != blank %}
            <a href="{{ block.settings.cat_link_3_url }}" class="ai-footer-nav-link-{{ ai_gen_id }}">{{ block.settings.cat_link_3_label }}</a>
          {% endif %}
          {% if block.settings.cat_link_4_label != blank and block.settings.cat_link_4_url != blank %}
            <a href="{{ block.settings.cat_link_4_url }}" class="ai-footer-nav-link-{{ ai_gen_id }}">{{ block.settings.cat_link_4_label }}</a>
          {% endif %}
          {% if block.settings.cat_link_5_label != blank and block.settings.cat_link_5_url != blank %}
            <a href="{{ block.settings.cat_link_5_url }}" class="ai-footer-nav-link-{{ ai_gen_id }}">{{ block.settings.cat_link_5_label }}</a>
          {% endif %}
        </div>
      </div>

      <!-- ── COLUMN 4: QUICK LINKS ── -->
      <div>
        <p class="ai-footer-column-heading-{{ ai_gen_id }}">
          {{ block.settings.quicklinks_heading | default: 'Quick Links' }}
        </p>
        <div class="ai-footer-nav-links-{{ ai_gen_id }}">
          {% if block.settings.ql_link_1_label != blank and block.settings.ql_link_1_url != blank %}
            <a href="{{ block.settings.ql_link_1_url }}" class="ai-footer-nav-link-{{ ai_gen_id }}">{{ block.settings.ql_link_1_label }}</a>
          {% endif %}
          {% if block.settings.ql_link_2_label != blank and block.settings.ql_link_2_url != blank %}
            <a href="{{ block.settings.ql_link_2_url }}" class="ai-footer-nav-link-{{ ai_gen_id }}">{{ block.settings.ql_link_2_label }}</a>
          {% endif %}
          {% if block.settings.ql_link_3_label != blank and block.settings.ql_link_3_url != blank %}
            <a href="{{ block.settings.ql_link_3_url }}" class="ai-footer-nav-link-{{ ai_gen_id }}">{{ block.settings.ql_link_3_label }}</a>
          {% endif %}
          {% if block.settings.ql_link_4_label != blank and block.settings.ql_link_4_url != blank %}
            <a href="{{ block.settings.ql_link_4_url }}" class="ai-footer-nav-link-{{ ai_gen_id }}">{{ block.settings.ql_link_4_label }}</a>
          {% endif %}
          {% if block.settings.ql_link_5_label != blank and block.settings.ql_link_5_url != blank %}
            <a href="{{ block.settings.ql_link_5_url }}" class="ai-footer-nav-link-{{ ai_gen_id }}">{{ block.settings.ql_link_5_label }}</a>
          {% endif %}

          {% for link in block.settings.policy.links %}
          <a href="{{ link.url }}" class="ai-footer-nav-link-{{ ai_gen_id }}"> {{ link.title }}</a>
          {% endfor %}
        </div>
      </div>

    </div><!-- /.ai-footer-main-row -->
  </div><!-- /.ai-footer-inner -->

  <!-- ── GRADIENT ACCENT LINE ── -->
  <div class="ai-footer-gradient-line-{{ ai_gen_id }}"></div>

  <!-- ── BOTTOM BAR ── -->
  <div class="ai-footer-inner-{{ ai_gen_id }}">
    <div class="ai-footer-bottom-bar-{{ ai_gen_id }}">
      <p class="ai-footer-copyright-{{ ai_gen_id }}">
        {% if block.settings.copyright_text != blank %}
          {{ block.settings.copyright_text }}
        {% else %}
          Copyright &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
        {% endif %}
      </p>
    </div>
  </div>

</footer-block-{{ ai_gen_id }}>

<script>
(function() {
  var footerEl = document.querySelector('.ai-footer-{{ ai_gen_id }}');
  if (footerEl) {
    var sectionEl = footerEl.closest('.shopify-section') || footerEl.parentElement;
    if (sectionEl) {
      sectionEl.style.setProperty('background', 'linear-gradient(180deg, #fde8f0 0%, #fef0e4 50%, #fff8e8 100%)', 'important');
      sectionEl.style.setProperty('background-color', '#fde8f0', 'important');
      sectionEl.style.setProperty('--color-background', 'transparent', 'important');
      sectionEl.style.setProperty('--gradient-base-background-1', 'transparent', 'important');
    }
  }
})();
</script>

