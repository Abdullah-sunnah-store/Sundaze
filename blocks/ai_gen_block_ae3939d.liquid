{% doc %}
  @prompt
    Full black background section. Width 100%.
    Background: #000000
    Padding top: 64px bottom: 64px
    Padding left: 20px right: 20px desktop
    Padding left: 10px right: 10px mobile
    
    IMAGE BLOCK:
    - Image placeholder: [HASH-HOLE-CROSSSECTION.png]
    - Width: 100%
    - Height: auto
    - Display: block
    - Object fit: cover
    - Border radius: 16px
    - Padding: 20px desktop / 10px mobile
    - Cursor: pointer
    
    Image Hover Animation:
    - On mouse hover: rotate 360 degrees
    - Transition: transform 0.8s ease-in-out
    - CSS:
      .product-image {
        transition: transform 0.8s ease-in-out;
      }
      .product-image:hover {
        transform: rotate(360deg);
      }
    
    Image fade effect:
    - Top fade: white to transparent
    - Bottom fade: transparent to black
    - CSS overlay:
      background: linear-gradient(
        to bottom,
        #ffffff 0%,
        transparent 30%,
        transparent 70%,
        #000000 100%
      );
    
    TEXT CONTENT BLOCK:
    - Background: #000000
    - Padding top: 48px bottom: 48px
    - Padding left: 20px right: 20px desktop
    - Padding left: 10px right: 10px mobile
    - Text align: center
    - Max width: 700px
    - Centered horizontally
    
    Scroll Animation on ALL text elements:
    - Animation: fade up on scroll
    - Start state: opacity 0, translateY 40px
    - End state: opacity 1, translateY 0px
    - Duration: 0.7s
    - Easing: ease-out
    - Trigger: when element enters viewport
    - Each text block has 0.1s delay after previous
    - CSS:
      .animate-on-scroll {
        opacity: 0;
        transform: translateY(40px);
        transition: opacity 0.7s ease-out,
                    transform 0.7s ease-out;
      }
      .animate-on-scroll.visible {
        opacity: 1;
        transform: translateY(0);
      }
    - JavaScript IntersectionObserver:
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry, index) => {
          if (entry.isIntersecting) {
            setTimeout(() => {
              entry.target.classList.add('visible');
            }, index * 100);
          }
        });
      });
      document.querySelectorAll('.animate-on-scroll')
      .forEach(el => observer.observe(el));
    
    Main Heading:
    - Text: "WHATS INSIDE"
    - Font: sans-serif black extrabold
    - Size: 64px desktop / 40px mobile
    - Color: #ffffff
    - Text transform: uppercase
    - Letter spacing: 4px
    - Margin bottom: 40px
    - Animation: animate-on-scroll
    - Animation delay: 0s
    
    Block 1 — Cold Cure Rosin:
    - Animation: animate-on-scroll
    - Animation delay: 0.1s
    
    - Heading: "90U-120U COLD CURE ROSIN"
    - Font: sans-serif bold
    - Size: 16px
    - Color: #ffffff
    - Text transform: uppercase
    - Letter spacing: 2px
    - Margin bottom: 8px
    
    - Subtext: "MADE FROM OUR FRESH FROZEN WHOLE
      PLANT CANNABIS FLOWER"
    - Font: sans-serif regular
    - Size: 14px
    - Color: #aaaaaa
    - Text transform: uppercase
    - Letter spacing: 1px
    - Align: center
    - Margin bottom: 40px
    
    Block 2 — Rosin Worm:
    - Animation: animate-on-scroll
    - Animation delay: 0.2s
    
    - Heading: "OUR ROSIN WORM"
    - Font: sans-serif bold
    - Size: 16px
    - Color: #ffffff
    - Text transform: uppercase
    - Letter spacing: 2px
    - Margin bottom: 8px
    
    - Subtext: "PERFECTLY CURATED DIRECTLY IN THE
      MIDDLE. EACH OF OUR HAND ROLLED HASH
      HOLES IS OUR ROSIN WORM EVENLY PLACED
      TO GIVE A PERFECT EVEN HIT WITH ZERO
      CLOG AND EVEN BURN."
    - Font: sans-serif regular
    - Size: 14px
    - Color: #aaaaaa
    - Text transform: uppercase
    - Letter spacing: 1px
    - Align: center
    - Margin bottom: 40px
    
    Block 3 — How To Smoke:
    - Animation: animate-on-scroll
    - Animation delay: 0.3s
    
    - Heading: "HOW TO SMOKE"
    - Font: sans-serif bold
    - Size: 16px
    - Color: #ffffff
    - Text transform: uppercase
    - Letter spacing: 2px
    - Margin bottom: 32px
    
    Tip 1 — Start Slow:
    - Animation: animate-on-scroll
    - Animation delay: 0.4s
    - Icon: ⏸ pause symbol
    - Icon size: 48px
    - Icon color: #ffffff
    - Margin bottom: 12px
    - Title: "START SLOW"
    - Font: sans-serif black italic
    - Size: 28px
    - Color: #ffffff
    - Letter spacing: 2px
    - Margin bottom: 12px
    - Body: "Due to their potency, take a few gentle
      puffs and pause to appreciate the complex
      flavors and effects."
    - Font: sans-serif regular
    - Size: 15px
    - Color: #cccccc
    - Line height: 1.7
    - Margin bottom: 48px, White gradient at the very TOP of the black section
    NOT on the image itself.
    
    Position: absolute
    Top: 0
    Left: 0
    Width: 100%
    Height: 150px
    Z-index: 1
    Pointer events: none
    
    Background: linear-gradient(
      to bottom,
      #ffffff 0%,
      rgba(255,255,255,0.6) 40%,
      rgba(255,255,255,0.1) 70%,
      transparent 100%
    )
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hash-hole-section-{{ ai_gen_id }} {
    display: block;
    background-color: #000000;
    padding: 64px 20px;
    max-width:1100px;
    margin: 0 auto;
    {% comment %} width: 100%; {% endcomment %}
    position: relative;
  }

  .ai-hash-hole-top-gradient-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 150px;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      to bottom,
      #ffffff 0%,
      rgba(255,255,255,0.6) 40%,
      rgba(255,255,255,0.1) 70%,
      transparent 100%
    );
  }

  @media screen and (max-width: 749px) {
    .ai-hash-hole-section-{{ ai_gen_id }} {
      padding: 64px 10px;
    }
  }

  .ai-hash-hole-image-wrapper-{{ ai_gen_id }} {
    padding: 20px;
    width: 100%;
    position: relative;
    z-index: 2;
  }

  @media screen and (max-width: 749px) {
    .ai-hash-hole-image-wrapper-{{ ai_gen_id }} {
      padding: 10px;
    }
  }

  .ai-hash-hole-image-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: 16px;
  }

  .ai-hash-hole-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    cursor: pointer;
    transition: transform 0.8s ease-in-out;
  }

  .ai-hash-hole-image-{{ ai_gen_id }}:hover {
    transform: rotate(360deg);
  }

  .ai-hash-hole-image-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      #ffffff 0%,
      transparent 30%,
      transparent 70%,
      #000000 100%
    );
    pointer-events: none;
  }

  .ai-hash-hole-placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 400px;
    border-radius: 16px;
  }

  .ai-hash-hole-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
    opacity: 0.3;
  }

  .ai-hash-hole-content-{{ ai_gen_id }} {
    background-color: #000000;
    padding: 48px 20px;
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  @media screen and (max-width: 749px) {
    .ai-hash-hole-content-{{ ai_gen_id }} {
      padding: 48px 10px;
    }
  }

  .ai-hash-hole-animate-{{ ai_gen_id }} {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }

  .ai-hash-hole-animate-{{ ai_gen_id }}.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-hash-hole-main-heading-{{ ai_gen_id }} {
    font-family: sans-serif;
    font-weight: 900;
    font-size: 64px;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 4px;
    margin: 0 0 40px 0;
  }

  @media screen and (max-width: 749px) {
    .ai-hash-hole-main-heading-{{ ai_gen_id }} {
      font-size: 40px;
    }
  }

  .ai-hash-hole-block-{{ ai_gen_id }} {
    margin-bottom: 40px;
  }

  .ai-hash-hole-heading-{{ ai_gen_id }} {
    font-family: sans-serif;
    font-weight: 700;
    font-size: 16px;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin: 0 0 8px 0;
  }

  .ai-hash-hole-subtext-{{ ai_gen_id }} {
    font-family: sans-serif;
    font-weight: 400;
    font-size: 14px;
    color: #aaaaaa;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0;
    line-height: 1.6;
  }

  .ai-hash-hole-how-to-heading-{{ ai_gen_id }} {
    font-family: sans-serif;
    font-weight: 700;
    font-size: 16px;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin: 0 0 32px 0;
  }

  .ai-hash-hole-tip-{{ ai_gen_id }} {
    margin-bottom: 48px;
  }

  .ai-hash-hole-tip-icon-{{ ai_gen_id }} {
    font-size: 48px;
    color: #ffffff;
    margin-bottom: 12px;
  }

  .ai-hash-hole-tip-title-{{ ai_gen_id }} {
    font-family: sans-serif;
    font-weight: 900;
    font-style: italic;
    font-size: 28px;
    color: #ffffff;
    letter-spacing: 2px;
    margin: 0 0 12px 0;
  }

  .ai-hash-hole-tip-body-{{ ai_gen_id }} {
    font-family: sans-serif;
    font-weight: 400;
    font-size: 15px;
    color: #cccccc;
    line-height: 1.7;
    margin: 0;
  }
{% endstyle %}

<hash-hole-section-{{ ai_gen_id }} class="ai-hash-hole-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hash-hole-top-gradient-{{ ai_gen_id }}"></div>
  
  <div class="ai-hash-hole-image-wrapper-{{ ai_gen_id }}">
    <div class="ai-hash-hole-image-container-{{ ai_gen_id }}">
      {% if block.settings.product_image %}
        <img
          src="{{ block.settings.product_image | image_url: width: 2000 }}"
          alt="{{ block.settings.product_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.product_image.width }}"
          height="{{ block.settings.product_image.height }}"
          class="ai-hash-hole-image-{{ ai_gen_id }}"
        >
        <div class="ai-hash-hole-image-overlay-{{ ai_gen_id }}"></div>
      {% else %}
        <div class="ai-hash-hole-placeholder-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>
  </div>

  <div class="ai-hash-hole-content-{{ ai_gen_id }}">
    <h2 class="ai-hash-hole-main-heading-{{ ai_gen_id }} ai-hash-hole-animate-{{ ai_gen_id }}" data-delay="0">
      {{ block.settings.main_heading }}
    </h2>

    <div class="ai-hash-hole-block-{{ ai_gen_id }} ai-hash-hole-animate-{{ ai_gen_id }}" data-delay="100">
      <h3 class="ai-hash-hole-heading-{{ ai_gen_id }}">{{ block.settings.block1_heading }}</h3>
      <p class="ai-hash-hole-subtext-{{ ai_gen_id }}">{{ block.settings.block1_subtext }}</p>
    </div>

    <div class="ai-hash-hole-block-{{ ai_gen_id }} ai-hash-hole-animate-{{ ai_gen_id }}" data-delay="200">
      <h3 class="ai-hash-hole-heading-{{ ai_gen_id }}">{{ block.settings.block2_heading }}</h3>
      <p class="ai-hash-hole-subtext-{{ ai_gen_id }}">{{ block.settings.block2_subtext }}</p>
    </div>

    <div class="ai-hash-hole-animate-{{ ai_gen_id }}" data-delay="300">
      <h3 class="ai-hash-hole-how-to-heading-{{ ai_gen_id }}">{{ block.settings.how_to_heading }}</h3>
    </div>

    <div class="ai-hash-hole-tip-{{ ai_gen_id }} ai-hash-hole-animate-{{ ai_gen_id }}" data-delay="400">
      <div class="ai-hash-hole-tip-icon-{{ ai_gen_id }}">{{ block.settings.tip1_icon }}</div>
      <h4 class="ai-hash-hole-tip-title-{{ ai_gen_id }}">{{ block.settings.tip1_title }}</h4>
      <p class="ai-hash-hole-tip-body-{{ ai_gen_id }}">{{ block.settings.tip1_body }}</p>
    </div>
  </div>
</hash-hole-section-{{ ai_gen_id }}>

<script>
  (function() {
    class HashHoleSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupScrollAnimation();
      }

      setupScrollAnimation() {
        const animatedElements = this.querySelectorAll('.ai-hash-hole-animate-{{ ai_gen_id }}');
        
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const delay = parseInt(entry.target.getAttribute('data-delay')) || 0;
              setTimeout(() => {
                entry.target.classList.add('visible');
              }, delay);
              observer.unobserve(entry.target);
            }
          });
        }, {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        });

        animatedElements.forEach((el) => {
          observer.observe(el);
        });
      }
    }

    customElements.define('hash-hole-section-{{ ai_gen_id }}', HashHoleSection{{ ai_gen_id }});
  })();
</script>

