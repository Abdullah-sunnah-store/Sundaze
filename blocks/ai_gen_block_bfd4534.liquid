<style>
/* =============================================
   AGE GATE — Sundaze
   ============================================= */

.age-gate {
  position: fixed;
  top: 0; left: 0;
  width: 100vw;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: radial-gradient(
    ellipse at center,
    #f5e6c8 0%,
    #f0d4a8 40%,
    #e8c89a 100%
  );
  overflow: hidden;
  z-index: 99999;
}

.age-gate.hidden {
  display: none !important;
}

/* ---- Tubes Container ---- */
.tubes-container {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 1;
  overflow: hidden;
}

/* ---- Falling Tube Base ---- */
.falling-tube {
  position: absolute;
  top: -420px;
  left: var(--col, 6%);
  width: var(--tw, 100px);
  height: var(--th, 300px);
  object-fit: contain;
  object-position: center;
  filter: drop-shadow(0 4px 10px rgba(0,0,0,0.10));
  animation:
    tubeFall var(--fd, 8s) linear var(--fdd, 0s) infinite,
    tubeWobble var(--wd, 2.5s) ease-in-out var(--wdd, 0s) infinite;
  transform-origin: center center;
  will-change: top, transform, opacity;
}

/* ---- Size Classes ---- */
.falling-tube--sm { --tw: 78px;  --th: 234px; }
.falling-tube--md { --tw: 95px;  --th: 285px; }
.falling-tube--lg { --tw: 112px; --th: 336px; }
.falling-tube--xl { --tw: 122px; --th: 366px; }

/* ---- Depth Classes ---- */
.falling-tube--far {
  filter: blur(0.6px) drop-shadow(0 2px 6px rgba(0,0,0,0.06));
}
.falling-tube--near {
  filter: drop-shadow(0 6px 18px rgba(0,0,0,0.18));
}

/* ---- Fall Animation ---- */
@keyframes tubeFall {
  0% {
    top: -420px;
    opacity: 0;
  }
  5% {
    opacity: 1;
  }
  88% {
    opacity: 1;
  }
  100% {
    top: 110vh;
    opacity: 0;
  }
}

/* ---- Wobble — horizontal drift + rotation ---- */
@keyframes tubeWobble {
  0%   { transform: translateX(-22px) rotate(-9deg); }
  25%  { transform: translateX(22px)  rotate(9deg);  }
  50%  { transform: translateX(-22px) rotate(-9deg); }
  75%  { transform: translateX(22px)  rotate(9deg);  }
  100% { transform: translateX(-22px) rotate(-9deg); }
}

/* ---- Center Content ---- */
.age-gate__content {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 20px;
  padding: 0 24px;
}

.age-gate__logo {
  width: 520px;
  max-width: 85vw;
  margin-bottom: 4px;
  filter: drop-shadow(0px 4px 12px rgba(0,0,0,0.15));
}

.age-gate__tagline {
  font-family: Georgia, serif;
  font-style: normal;
  font-weight: 400;
  font-size: 18px;
  color: #5a3a2a;
  margin-bottom: 4px;
  letter-spacing: 0.3px;
}

.age-gate__row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12px;
  width: 100%;
  justify-content: center;
}

.age-gate__select {
  width: 220px;
  padding: 14px 20px;
  border-radius: 50px;
  border: 1px solid #e0d0b8;
  background: #ffffff;
  font-size: 15px;
  color: #5a3a2a;
  outline: none;
  cursor: pointer;
  appearance: none;
  font-family: Georgia, serif;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.age-gate__btn {
  padding: 14px 28px;
  background: #3d2314;
  color: #ffffff;
  border: none;
  border-radius: 50px;
  font-size: 15px;
  font-weight: 600;
  letter-spacing: 0.5px;
  cursor: pointer;
  transition: opacity 0.2s ease;
  font-family: Georgia, serif;
  white-space: nowrap;
  display: flex;
  align-items: center;
  gap: 8px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.2);
}

.age-gate__btn:hover {
  opacity: 0.85;
}

.age-gate__btn::after {
  content: '›';
  font-size: 20px;
  line-height: 1;
}

.age-gate__error {
  color: #cc0000;
  font-size: 13px;
  font-family: Georgia, serif;
  margin-top: -8px;
  display: none;
}

.age-gate__error.show {
  display: block;
}

/* ---- Mobile ---- */
@media (max-width: 768px) {
  .falling-tube--sm { --tw: 58px;  --th: 174px; }
  .falling-tube--md { --tw: 72px;  --th: 216px; }
  .falling-tube--lg { --tw: 84px;  --th: 252px; }
  .falling-tube--xl { --tw: 92px;  --th: 276px; }

  .age-gate__logo { width: 260px; }
  .age-gate__tagline { font-size: 15px; }

  .age-gate__row {
    flex-direction: column;
    gap: 10px;
  }

  .age-gate__select,
  .age-gate__btn {
    width: 240px;
    justify-content: center;
  }
}
</style>

<div class="age-gate" id="sundazeAgeGate">

  <!-- =============================================
       FALLING TUBES — 4 columns × 3 tubes each
       Key: same fall-duration per column, delays
       spaced at duration÷3 so tubes NEVER overlap
       ============================================= -->

  <div class="tubes-container">

    <!-- ── Column 1 · left ~6% · fall 7.5s · delays 0 / 2.5 / 5 ── -->

    {% if section.settings.tube_1 != blank %}
    <img class="falling-tube falling-tube--xl falling-tube--near"
      src="{{ section.settings.tube_1 | img_url: '400x' }}"
      style="--col:6%;--fd:7.5s;--fdd:0s;--wd:2.6s;--wdd:0s"
      alt="">
    {% endif %}

    {% if section.settings.tube_3 != blank %}
    <img class="falling-tube falling-tube--sm falling-tube--far"
      src="{{ section.settings.tube_3 | img_url: '400x' }}"
      style="--col:8%;--fd:7.5s;--fdd:2.5s;--wd:2.8s;--wdd:0.5s"
      alt="">
    {% endif %}

    {% if section.settings.tube_2 != blank %}
    <img class="falling-tube falling-tube--md"
      src="{{ section.settings.tube_2 | img_url: '400x' }}"
      style="--col:5%;--fd:7.5s;--fdd:5s;--wd:2.4s;--wdd:1s"
      alt="">
    {% endif %}

    <!-- ── Column 2 · left ~30% · fall 8s · delays 0.8 / 3.5 / 6.2 ── -->

    {% if section.settings.tube_2 != blank %}
    <img class="falling-tube falling-tube--sm falling-tube--far"
      src="{{ section.settings.tube_2 | img_url: '400x' }}"
      style="--col:30%;--fd:8s;--fdd:0.8s;--wd:2.4s;--wdd:0.2s"
      alt="">
    {% endif %}

    {% if section.settings.tube_4 != blank %}
    <img class="falling-tube falling-tube--lg falling-tube--near"
      src="{{ section.settings.tube_4 | img_url: '400x' }}"
      style="--col:28%;--fd:8s;--fdd:3.5s;--wd:2.7s;--wdd:0.7s"
      alt="">
    {% endif %}

    {% if section.settings.tube_1 != blank %}
    <img class="falling-tube falling-tube--md"
      src="{{ section.settings.tube_1 | img_url: '400x' }}"
      style="--col:31%;--fd:8s;--fdd:6.2s;--wd:2.5s;--wdd:1.2s"
      alt="">
    {% endif %}

    <!-- ── Column 3 · left ~57% · fall 8.5s · delays 1.7 / 4.5 / 7.3 ── -->

    {% if section.settings.tube_3 != blank %}
    <img class="falling-tube falling-tube--md"
      src="{{ section.settings.tube_3 | img_url: '400x' }}"
      style="--col:57%;--fd:8.5s;--fdd:1.7s;--wd:2.5s;--wdd:0.4s"
      alt="">
    {% endif %}

    {% if section.settings.tube_1 != blank %}
    <img class="falling-tube falling-tube--sm falling-tube--far"
      src="{{ section.settings.tube_1 | img_url: '400x' }}"
      style="--col:59%;--fd:8.5s;--fdd:4.5s;--wd:2.3s;--wdd:0.9s"
      alt="">
    {% endif %}

    {% if section.settings.tube_4 != blank %}
    <img class="falling-tube falling-tube--xl falling-tube--near"
      src="{{ section.settings.tube_4 | img_url: '400x' }}"
      style="--col:56%;--fd:8.5s;--fdd:7.3s;--wd:2.6s;--wdd:0.3s"
      alt="">
    {% endif %}

    <!-- ── Column 4 · left ~82% · fall 7.8s · delays 2.3 / 4.9 / 7.5 ── -->

    {% if section.settings.tube_4 != blank %}
    <img class="falling-tube falling-tube--md"
      src="{{ section.settings.tube_4 | img_url: '400x' }}"
      style="--col:82%;--fd:7.8s;--fdd:2.3s;--wd:2.3s;--wdd:0.6s"
      alt="">
    {% endif %}

    {% if section.settings.tube_2 != blank %}
    <img class="falling-tube falling-tube--lg falling-tube--near"
      src="{{ section.settings.tube_2 | img_url: '400x' }}"
      style="--col:80%;--fd:7.8s;--fdd:4.9s;--wd:2.8s;--wdd:0.1s"
      alt="">
    {% endif %}

    {% if section.settings.tube_3 != blank %}
    <img class="falling-tube falling-tube--sm falling-tube--far"
      src="{{ section.settings.tube_3 | img_url: '400x' }}"
      style="--col:83%;--fd:7.8s;--fdd:7.5s;--wd:2.5s;--wdd:0.8s"
      alt="">
    {% endif %}

  </div>

  <!-- =============================================
       CENTER CONTENT
       ============================================= -->

  <div class="age-gate__content">

    {% if section.settings.logo != blank %}
    <img class="age-gate__logo"
      src="{{ section.settings.logo | img_url: '1000x' }}"
      alt="Sundaze">
    {% endif %}

    <p class="age-gate__tagline">
      {{ section.settings.tagline }}
    </p>

    <div class="age-gate__row">

      <select class="age-gate__select" id="stateSelect">
        <option value="" disabled selected>Select Your State</option>
        <option value="AL">Alabama</option>
        <option value="AK">Alaska</option>
        <option value="AZ">Arizona</option>
        <option value="AR">Arkansas</option>
        <option value="CA">California</option>
        <option value="CO">Colorado</option>
        <option value="CT">Connecticut</option>
        <option value="DE">Delaware</option>
        <option value="FL">Florida</option>
        <option value="GA">Georgia</option>
        <option value="HI">Hawaii</option>
        <option value="ID">Idaho</option>
        <option value="IL">Illinois</option>
        <option value="IN">Indiana</option>
        <option value="IA">Iowa</option>
        <option value="KS">Kansas</option>
        <option value="KY">Kentucky</option>
        <option value="LA">Louisiana</option>
        <option value="ME">Maine</option>
        <option value="MD">Maryland</option>
        <option value="MA">Massachusetts</option>
        <option value="MI">Michigan</option>
        <option value="MN">Minnesota</option>
        <option value="MS">Mississippi</option>
        <option value="MO">Missouri</option>
        <option value="MT">Montana</option>
        <option value="NE">Nebraska</option>
        <option value="NV">Nevada</option>
        <option value="NH">New Hampshire</option>
        <option value="NJ">New Jersey</option>
        <option value="NM">New Mexico</option>
        <option value="NY">New York</option>
        <option value="NC">North Carolina</option>
        <option value="ND">North Dakota</option>
        <option value="OH">Ohio</option>
        <option value="OK">Oklahoma</option>
        <option value="OR">Oregon</option>
        <option value="PA">Pennsylvania</option>
        <option value="RI">Rhode Island</option>
        <option value="SC">South Carolina</option>
        <option value="SD">South Dakota</option>
        <option value="TN">Tennessee</option>
        <option value="TX">Texas</option>
        <option value="UT">Utah</option>
        <option value="VT">Vermont</option>
        <option value="VA">Virginia</option>
        <option value="WA">Washington</option>
        <option value="WV">West Virginia</option>
        <option value="WI">Wisconsin</option>
        <option value="WY">Wyoming</option>
      </select>

      <button class="age-gate__btn" id="enterSiteBtn">
        {{ section.settings.button_text }}
      </button>

    </div>

    <p class="age-gate__error" id="ageGateError">
      Please select your state to continue.
    </p>

  </div>
</div>

<script>
  if (sessionStorage.getItem('sundaze_verified')) {
    document.getElementById('sundazeAgeGate')
      .classList.add('hidden');
  }

  document.getElementById('enterSiteBtn')
    .addEventListener('click', function() {
      const state =
        document.getElementById('stateSelect').value;
      const error =
        document.getElementById('ageGateError');

      if (!state) {
        error.classList.add('show');
      } else {
        error.classList.remove('show');
        sessionStorage.setItem('sundaze_verified', 'true');
        sessionStorage.setItem('sundaze_state', state);
        window.location.href =
          '{{ section.settings.redirect_url }}';
      }
  });
</script>

{% schema %}
{
  "name": "Age Gate",
  "tag": "div",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Sundaze Logo"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline Text",
      "default": "Dont You Just Love Sundaze?"
