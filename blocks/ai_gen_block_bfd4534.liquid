      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "21+ to Explore"
    },
    {
      "type": "url",
      "id": "redirect_url",
      "label": "Redirect URL after verification"
    },
    {
      "type": "image_picker",
      "id": "tube_1",
      "label": "Falling Product Image 1"
    },
    {
      "type": "image_picker",
      "id": "tube_2",
      "label": "Falling Product Image 2"
    },
    {
      "type": "image_picker",
      "id": "tube_3",
      "label": "Falling Product Image 3"
    },
    {
      "type": "image_picker",
      "id": "tube_4",
      "label": "Falling Product Image 4"
    }
  ],
  "presets": [
    {
      "name": "Age Gate"
    }
  ]
}
{% endschema %}