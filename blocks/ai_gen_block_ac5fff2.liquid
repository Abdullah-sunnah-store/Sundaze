      "default": "Products"
    },
    {
      "type": "url",
      "id": "nav_link_2_url",
      "label": "Link 2 URL"
    },
    {
      "type": "text",
      "id": "nav_link_3_text",
      "label": "Link 3 text",
      "default": "About Us"
    },
    {
      "type": "url",
      "id": "nav_link_3_url",
      "label": "Link 3 URL"
    },
    {
      "type": "text",
      "id": "nav_link_4_text",
      "label": "Link 4 text",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "nav_link_4_url",
      "label": "Link 4 URL"
    },
    {
      "type": "text",
      "id": "nav_link_5_text",
      "label": "Link 5 text",
      "default": "Verification"
    },
    {
      "type": "url",
      "id": "nav_link_5_url",
      "label": "Link 5 URL"
    },
    {
      "type": "text",
      "id": "nav_link_6_text",
