<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500&display=swap');

.sf-banner *::before,
.sf-banner *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

.sf-banner {
  background: {{ section.settings.section_bg | default: '#f7f3ee' }};
  font-family: 'DM Sans', sans-serif;
  position: relative;
  overflow: hidden;
  padding: 20px 8px;
}

@media (min-width: 768px) {
  .sf-banner { padding: 40px 8px; }
}

/* ── Animated Pastel Background Shapes ── */
.sf-shape {
  position: absolute;
  border-radius: 50%;
  filter: blur(100px);
  opacity: 0.45;
  z-index: 0;
  pointer-events: none;
  animation: floatShape 8s ease-in-out infinite alternate;
}

@keyframes floatShape {
  0% { transform: translate(0, 0) scale(1); }
  100% { transform: translate(30px, -20px) scale(1.05); }
}

/* ── Content Container ── */
.sf-container {
  position: relative;
  z-index: 2;
  max-width: 800px;
  margin: 0 auto;
  text-align: center;
}

/* ── Base Animation Styles ── */
.sf-anim {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.8s cubic-bezier(0.25, 0.8, 0.25, 1), 
              transform 0.8s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.sf-anim.is-visible {
  opacity: 1;
  transform: translateY(0);
}

/* Staggered Delays */
.sf-anim-1 { transition-delay: 0.1s; }
.sf-anim-2 { transition-delay: 0.25s; }
.sf-anim-3 { transition-delay: 0.4s; }
.sf-anim-4 { transition-delay: 0.55s; }

/* ── Typography ── */
.sf-eyebrow {
  display: inline-block;
  font-family: 'DM Sans', sans-serif;
  font-weight: 500;
  font-size: 11px;
  letter-spacing: 0.38em;
  text-transform: uppercase;
  color: #E8326A;
  background: rgba(232, 50, 106, 0.1);
  padding: 8px 20px;
  border-radius: 999px;
  margin-bottom: 22px;
}

.sf-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(3rem, 6vw, 5rem);
  font-weight: 900;
  line-height: 1.08;
  color: #1a1a1a;
  margin-bottom: 0px;
}

.sf-title span {
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-weight: 700;
  background: linear-gradient(135deg, #E8326A, #9b59b6);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.sf-desc {
  font-family: 'DM Sans', sans-serif;
  font-size: clamp(15px, 2vw, 18px);
  font-weight: 300;
  line-height: 1.82;
  color: #555;
  margin-bottom: 18px;
  white-space: pre-line;
}

/* ── Badges ── */
.sf-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  justify-content: center;
}

.sf-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: 'DM Sans', sans-serif;
  font-weight: 500;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.10em;
  padding: 10px 22px;
  border-radius: 999px;
  background: #fff;
  color: #111;
  box-shadow: 0 8px 24px rgba(0,0,0,0.06);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.sf-badge:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 28px rgba(0,0,0,0.1);
}

.sf-badge svg {
  width: 16px;
  height: 16px;
  stroke: currentColor;
  fill: none;
  stroke-width: 2.5;
  stroke-linecap: round;
  stroke-linejoin: round;
  flex-shrink: 0;
}
</style>

<section
  class="sf-banner"
  id="sf-banner-{{ section.id }}"
  aria-label="3.5 Flower Collection Banner"
>

  <!-- Vibrant Pastel Background Shapes -->
  <div class="sf-shape" style="width: 500px; height: 500px; background: #fce4ec; top: -150px; left: -100px; animation-delay: 0s;"></div>
  <div class="sf-shape" style="width: 400px; height: 400px; background: #fff9c4; bottom: -100px; right: -100px; animation-delay: 2s;"></div>
  <div class="sf-shape" style="width: 300px; height: 300px; background: #e8f5e9; top: 30%; left: 60%; animation-delay: 4s;"></div>
  <div class="sf-shape" style="width: 250px; height: 250px; background: #ffe0b2; top: 60%; left: 10%; animation-delay: 3s;"></div>

  <div class="sf-container">
    
    <div class="sf-anim sf-anim-1">
      <span class="sf-eyebrow">{{ section.settings.eyebrow }}</span>
    </div>
    
    <h2 class="sf-title sf-anim sf-anim-2">
      {{ section.settings.title }} <span>{{ section.settings.title_accent }}</span>
    </h2>
    
    <p class="sf-desc sf-anim sf-anim-3">
      {{ section.settings.description }}
    </p>
    
    <div class="sf-badges sf-anim sf-anim-4">
      <span class="sf-badge">
        <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Federally Legal
      </span>
      <span class="sf-badge">
        <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        Lab Tested
      </span>
      <span class="sf-badge">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        All 50 States
      </span>
    </div>

  </div>
</section>

<script>
(function() {
  const sectionEl = document.getElementById('sf-banner-{{ section.id }}');
  if (!sectionEl) return;

  const animEls = sectionEl.querySelectorAll('.sf-anim');
  if (animEls.length === 0) return;

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  animEls.forEach(el => {
    const rect = el.getBoundingClientRect();
    if (rect.top < window.innerHeight && rect.bottom > 0) {
      el.classList.add('is-visible');
    } else {
      observer.observe(el);
    }
  });
})();
</script>

{% schema %}
{
  "name": "Sundaze Text Banner",
  "tag": "section",
  "class": "sundaze-text-banner",
  "settings": [
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background color",
      "default": "#f7f3ee"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Premium Collection"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Main Title",
      "default": "3.5 Flower"
    },
    {
      "type": "text",
      "id": "title_accent",
      "label": "Title Accent (Gradient Text)",
      "default": "Collection"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "The Sundaze 3.5 Flower collection is crafted for those who refuse to settle. Each jar is packed with premium THCA hemp flower, hand-selected for dense trichome coverage, bold terpene profiles, and a smooth, flavorful burn from start to finish.\n\nEvery strain in the lineup is inspired by rich, indulgent flavors — from icy cool finishes to warm, buttery desserts — so every session feels like a treat. Federally legal, lab-tested, and available in all 50 states."
    }
  ],
  "presets": [
    {
      "name": "Sundaze Text Banner"
    }
  ]
}
{% endschema %}
