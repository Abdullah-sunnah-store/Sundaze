<script src="{{ 'product-recommendations.js' | asset_url }}" defer="defer"></script>

{{ 'component-price.css' | asset_url | stylesheet_tag }}

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600;700;800&display=swap');

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;

  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .section-{{ section.id }}-padding{
    background: radial-gradient(ellipse 80% 55% at 50% 50%,  rgba(255,225,235,0.70) 0%, transparent 70%),
      radial-gradient(ellipse 60% 40% at 50% 0%,   rgba(255,248,230,0.60) 0%, transparent 60%),
      linear-gradient(180deg, #fde8f0 0%, #fff8e8 100%);
  }

  /* ── Sundaze Related Products ── */

  .sdz-related__heading {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 900;
    font-style: italic;
    text-align: center;
    margin: 0 0 32px;
    color: #1e1118;
    background: linear-gradient(135deg, #d4926e 0%, #c4607a 55%, #a84f6a 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .sdz-related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media (min-width: 540px)  { .sdz-related-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 900px)  { .sdz-related-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1200px) { .sdz-related-grid { grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr); } }

  /* ── Card ── */
  .sdz-rc {
    background: #fff;
    border-radius: 28px;
    overflow: hidden;
    box-shadow: 0 12px 32px rgba(0,0,0,0.06);
    border: 1px solid rgba(255,255,255,0.8);
    opacity: 0;
    transform: scale(0.95) translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    cursor: pointer;
    text-decoration: none;
    color: #1e1118;
    position: relative;
  }

  .sdz-rc.is-visible {
    opacity: 1;
    transform: scale(1) translateY(0);
  }

  .sdz-rc:hover {
    box-shadow: 0 20px 52px rgba(0,0,0,0.13);
    transform: scale(1.025) translateY(-5px);
  }

  /* ── Image area ── */
  .sdz-rc__img-wrap {
    position: relative;
    height: 240px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 28px 28px 0 0;
    background: linear-gradient(135deg, #fde8f0 0%, #fff8e8 100%);
    text-decoration: none;
  }

  /* Single image — zoom only */
  .sdz-rc__img {
    width: 78%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 14px 14px rgba(0,0,0,0.14));
    transition: transform 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);
    z-index: 2;
    position: relative;
  }

  .sdz-rc:hover .sdz-rc__img {
    transform: scale(1.1);
  }

  /* Dual image stack — perspective + fan-out */
  .sdz-rc__img-stack {
    position: relative;
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    perspective: 1000px;
  }

  .sdz-rc__img-front,
  .sdz-rc__img-back {
    grid-area: 1 / 1;
    width: 78%;
    height: auto;
    max-height: 210px;
    object-fit: contain;
    filter: drop-shadow(0 14px 14px rgba(0,0,0,0.14));
    transition: transform 0.48s cubic-bezier(0.25, 0.8, 0.25, 1), opacity 0.38s ease;
    transform-origin: bottom center;
  }

  .sdz-rc__img-front { z-index: 2; }

  .sdz-rc__img-back {
    z-index: 1;
    opacity: 0;
  }

  /* Fan-out on hover — matches collection page exactly */
  .sdz-rc:hover .sdz-rc__img-front {
    transform: rotate(-13deg) scale(0.93) translateX(-8px);
  }

  .sdz-rc:hover .sdz-rc__img-back {
    opacity: 1;
    transform: rotate(13deg) scale(0.93) translateX(8px);
  }

  /* Zoom-only override for single-image products (e.g. flower) */
  .sdz-rc--zoom-only:hover .sdz-rc__img-front {
    transform: scale(1.1) !important;
  }

  .sdz-rc--zoom-only:hover .sdz-rc__img-back {
    opacity: 0 !important;
    transform: none !important;
  }

  /* ── Badge ── */
  .sdz-rc__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 10;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .sdz-rc__badge-pill {
    display: inline-block;
    padding: 4px 11px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(4px);
    color: #1e1118;
    box-shadow: 0 3px 8px rgba(0,0,0,0.1);
    font-family: 'DM Sans', sans-serif;
  }

  .sdz-rc__badge-pill--sale {
    background: linear-gradient(135deg, #d4926e 0%, #c4607a 55%, #a84f6a 100%);
    color: #fff;
  }
  .sdz-rc__badge-pill--sold { background: #c0392b; color: #fff; }

  /* ── Wishlist button ── */
  .sdz-rc__wish {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 10;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.8);
    background: rgba(255,255,255,0.88);
    backdrop-filter: blur(4px);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, background 0.2s, transform 0.15s;
    box-shadow: 0 3px 8px rgba(0,0,0,0.08);
  }

  .sdz-rc__wish:hover { border-color: #e8a0b4; background: #fde8f0; transform: scale(1.12); }
  .sdz-rc__wish:active { transform: scale(0.9); }

  .sdz-rc__wish svg {
    width: 16px; height: 16px;
    color: rgba(196,96,122,0.45);
    transition: fill 0.25s, color 0.25s, transform 0.2s;
  }

  .sdz-rc__wish.wished { border-color: #e8a0b4; background: #fde8f0; }
  .sdz-rc__wish.wished svg { fill: #c4607a; color: #c4607a; }
  .sdz-rc__wish.wish-pop svg { transform: scale(1.45); }

  /* ── Card content ── */
  .sdz-rc__body {
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .sdz-rc__vendor {
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.32em;
    color: #c4607a;
    font-family: 'DM Sans', sans-serif;
  }

  .sdz-rc__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(17px, 2vw, 21px);
    font-weight: 700;
    line-height: 1.25;
    color: #1e1118;
    margin: 0;
    text-decoration: none;
    transition: color 0.2s;
  }

  .sdz-rc:hover .sdz-rc__title { color: #c4607a; }

  .sdz-rc__price-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .sdz-rc__price {
    font-size: 17px;
    font-weight: 700;
    color: #1e1118;
    font-family: 'DM Sans', sans-serif;
  }

  .sdz-rc__price--compare {
    font-size: 13px;
    font-weight: 400;
    color: rgba(30,17,24,0.40);
    text-decoration: line-through;
    font-family: 'DM Sans', sans-serif;
  }

  /* ── Add to cart ── */
  .sdz-rc__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: linear-gradient(135deg, #d4926e 0%, #c4607a 55%, #a84f6a 100%);
    color: #fff;
    border: none;
    border-radius: 999px;
    padding: 12px 20px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    font-family: 'DM Sans', sans-serif;
    width: 100%;
    margin-top: auto;
    text-decoration: none;
    box-shadow: 0 4px 18px rgba(196,96,122,0.26);
  }

  .sdz-rc__btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(196,96,122,0.36); }
  .sdz-rc__btn:active:not(:disabled) { transform: scale(0.97); }
  .sdz-rc__btn:disabled { opacity: 0.65; cursor: not-allowed; }
  .sdz-rc__btn.loading { background: rgba(30,17,24,0.55); box-shadow: none; }
  .sdz-rc__btn.added   { background: #2d7a2d; box-shadow: none; }
  .sdz-rc__btn--sold   { background: rgba(30,17,24,0.18); cursor: not-allowed; box-shadow: none; }

  .sdz-rc__spinner {
    display: none;
    width: 13px; height: 13px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: sdz-rc-spin 0.7s linear infinite;
  }

  .sdz-rc__btn.loading .sdz-rc__spinner  { display: block; }
  .sdz-rc__btn.loading .sdz-rc__btn-icon,
  .sdz-rc__btn.loading .sdz-rc__btn-text { display: none; }

  @keyframes sdz-rc-spin { to { transform: rotate(360deg); } }

  /* ── Toast ── */
  .sdz-toast {
    position: fixed;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%) translateY(80px);
    z-index: 99999;
    display: flex;
    align-items: center;
    gap: 10px;
    background: #1e1118;
    color: #fff;
    border-radius: 50px;
    padding: 12px 22px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.06em;
    box-shadow: 0 8px 32px rgba(196,96,122,0.22);
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.4s ease;
    opacity: 0;
    white-space: nowrap;
    pointer-events: none;
    font-family: 'DM Sans', sans-serif;
  }

  .sdz-toast.show  { transform: translateX(-50%) translateY(0); opacity: 1; }
  .sdz-toast.error { background: #c0392b; }
  .sdz-toast.wish  { background: linear-gradient(135deg, #d4926e, #c4607a, #a84f6a); }
{%- endstyle -%}

<div class="sdz-toast" id="sdzToast" role="status" aria-live="polite">
  <span id="sdzToastIcon"></span>
  <span id="sdzToastMsg"></span>
</div>

<div class="color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding ">
  <product-recommendations
    class="related-products page-width section-{{ section.id }}-padding isolate{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ section.settings.products_to_show }}"
    data-section-id="{{ section.id }}"
    data-product-id="{{ product.id }}"
  >
    {% if recommendations.performed and recommendations.products_count > 0 %}
      <h2 class="sdz-related__heading">{{ section.settings.heading }}</h2>

      {%- assign palette = 'fde8f0,fff8e8,fde8f0,fff8e8,fde8f0,fff8e8,fde8f0,fff8e8,fde8f0,fff8e8,fde8f0,fff8e8' | split: ',' -%}

      <ul class="sdz-related-grid" role="list">
        {% for recommendation in recommendations.products %}

          {%- assign sold_out = false -%}
          {%- unless recommendation.available -%}{%- assign sold_out = true -%}{%- endunless -%}
          {%- assign first_variant = recommendation.first_available_variant | default: recommendation.variants.first -%}
          {%- assign color_index = forloop.index0 | modulo: 12 -%}
          {%- assign card_bg = palette[color_index] -%}

          {%- assign is_zoom_only = false -%}
          {%- if recommendation.images.size <= 1 -%}
            {%- assign is_zoom_only = true -%}
          {%- endif -%}
          {%- if recommendation.title contains '3.5G Flower' -%}
            {%- assign is_zoom_only = true -%}
          {%- endif -%}

          <li class="sdz-rc{% if is_zoom_only %} sdz-rc--zoom-only{% endif %}" style="--animation-order: {{ forloop.index }};">

            <a href="{{ recommendation.url }}"
               class="sdz-rc__img-wrap"
               aria-label="{{ recommendation.title | escape }}"
               tabindex="-1"
               style="background: linear-gradient(135deg, #{{ card_bg }}, #{{ card_bg }});">

              {%- if recommendation.images.size > 1 -%}
                <div class="sdz-rc__img-stack">
                  <img
                    class="sdz-rc__img-back"
                    src="{{ recommendation.images[1] | img_url: '600x' }}"
                    alt="{{ recommendation.title | escape }} secondary"
                    draggable="false"
                    loading="lazy"
                    width="600">
                  <img
                    class="sdz-rc__img-front"
                    src="{{ recommendation.featured_image | img_url: '600x' }}"
                    alt="{{ recommendation.title | escape }}"
                    draggable="false"
                    {%- if forloop.index > 2 %} loading="lazy"{% endif %}
                    width="600">
                </div>
              {%- elsif recommendation.featured_image -%}
                <img
                  class="sdz-rc__img"
                  src="{{ recommendation.featured_image | img_url: '600x' }}"
                  alt="{{ recommendation.title | escape }}"
                  draggable="false"
                  {%- if forloop.index > 2 %} loading="lazy"{% endif %}
                  width="600">
              {%- else -%}
                <div style="font-size:56px;opacity:0.4;">🍦</div>
              {%- endif -%}

              <div class="sdz-rc__badge">
                {%- if sold_out -%}
                  <span class="sdz-rc__badge-pill sdz-rc__badge-pill--sold">Sold Out</span>
                {%- elsif recommendation.compare_at_price > recommendation.price -%}
                  <span class="sdz-rc__badge-pill sdz-rc__badge-pill--sale">Sale</span>
                {%- endif -%}
                {%- if recommendation.tags contains 'new' or recommendation.tags contains 'New' -%}
                  <span class="sdz-rc__badge-pill">New</span>
                {%- endif -%}
              </div>

              <button
                class="sdz-rc__wish"
                aria-label="Add {{ recommendation.title | escape }} to wishlist"
                data-product-id="{{ recommendation.id }}"
                data-product-name="{{ recommendation.title | escape }}"
                data-product-price="{{ recommendation.price | money }}"
                data-product-image="{{ recommendation.featured_image | img_url: '200x' }}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
              </button>

            </a>

            <div class="sdz-rc__body">
              {%- if section.settings.show_vendor -%}
                <p class="sdz-rc__vendor">{{ recommendation.vendor }}</p>
              {%- endif -%}

              <a href="{{ recommendation.url }}" style="text-decoration:none;">
                <h3 class="sdz-rc__title">{{ recommendation.title }}</h3>
              </a>

              <div class="sdz-rc__price-row">
                <span class="sdz-rc__price">{{ recommendation.price | money }}</span>
                {%- if recommendation.compare_at_price > recommendation.price -%}
                  <span class="sdz-rc__price--compare">{{ recommendation.compare_at_price | money }}</span>
                {%- endif -%}
              </div>

              {%- if sold_out -%}
                <button class="sdz-rc__btn sdz-rc__btn--sold" disabled>Sold Out</button>
              {%- else -%}
                <button
                  class="sdz-rc__btn"
                  data-variant-id="{{ first_variant.id }}"
                  data-product-name="{{ recommendation.title | escape }}">
                  <div class="sdz-rc__spinner"></div>
                  <svg class="sdz-rc__btn-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                    <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                  </svg>
                  <span class="sdz-rc__btn-text">Add to Cart</span>
                </button>
              {%- endif -%}
            </div>

          </li>
        {% endfor %}
      </ul>
    {% endif %}
  </product-recommendations>

  {% if section.settings.image_shape == 'arch' %}
    {{ 'mask-arch.svg' | inline_asset_content }}
  {%- endif -%}
</div>

<script>
(function () {

  /* ── Toast: move to body, reuse if already there ── */
  const _toast = document.getElementById('sdzToast');
  if (_toast && _toast.parentNode !== document.body) document.body.appendChild(_toast);

  const Toast = window.SdzToast || {
    _t: null,
    show(msg, icon, type) {
      const t = document.getElementById('sdzToast');
      if (!t) return;
      t.className = 'sdz-toast ' + (type || '');
      document.getElementById('sdzToastMsg').textContent = msg;
      document.getElementById('sdzToastIcon').textContent = icon || '';
      t.classList.add('show');
      clearTimeout(this._t);
      this._t = setTimeout(() => t.classList.remove('show'), 3000);
    }
  };
  window.SdzToast = Toast;

  /* ── Wishlist helpers ── */
  const WISH_KEY = 'sundaze_wishlist_v1';
  function wishLoad()  { try { return JSON.parse(localStorage.getItem(WISH_KEY) || '[]'); } catch { return []; } }
  function wishSave(l) { localStorage.setItem(WISH_KEY, JSON.stringify(l)); }
  function wishHas(id) { return wishLoad().some(i => i.id === id); }

  /* ── Add to Cart ── */
  function rcAddToCart(btn) {
    const id   = btn.dataset.variantId;
    const name = btn.dataset.productName || 'Product';
    if (!id || id === 'nil' || id === '') {
      Toast.show('No variant available', '⚠️', 'error');
      return;
    }
    btn.disabled = true;
    btn.classList.add('loading');

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: parseInt(id, 10), quantity: 1 })
    })
    .then(r => {
      if (!r.ok) return r.json().then(e => { throw new Error(e.description || 'Error'); });
      return r.json();
    })
    .then(() => {
      btn.classList.remove('loading');
      btn.classList.add('added');
      btn.querySelector('.sdz-rc__btn-icon').outerHTML =
        '<svg class="sdz-rc__btn-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>';
      btn.querySelector('.sdz-rc__btn-text').textContent = 'Added!';
      Toast.show(name + ' added to cart', '🛒');
      document.dispatchEvent(new CustomEvent('cart:refresh'));
      setTimeout(() => {
        btn.disabled = false;
        btn.classList.remove('added');
        btn.querySelector('.sdz-rc__btn-text').textContent = 'Add to Cart';
        btn.querySelector('.sdz-rc__btn-icon').outerHTML =
          '<svg class="sdz-rc__btn-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>';
      }, 2600);
    })
    .catch(err => {
      btn.disabled = false;
      btn.classList.remove('loading');
      Toast.show(err.message || 'Could not add to cart', '❌', 'error');
    });
  }

  /* ── Wishlist toggle ── */
  function rcToggleWish(btn) {
    const id    = btn.dataset.productId;
    const name  = btn.dataset.productName  || 'Product';
    const price = btn.dataset.productPrice || '';
    const img   = btn.dataset.productImage || '';
    if (!id) return;
    const list = wishLoad();
    const idx  = list.findIndex(i => i.id === id);
    if (idx === -1) {
      list.push({ id, name, price, img });
      wishSave(list);
      btn.classList.add('wished');
      Toast.show(name + ' wishlisted', '💗', 'wish');
    } else {
      list.splice(idx, 1);
      wishSave(list);
      btn.classList.remove('wished');
      Toast.show('Removed from wishlist', '🤍');
    }
    btn.classList.add('wish-pop');
    setTimeout(() => btn.classList.remove('wish-pop'), 250);
    const wc = document.getElementById('sfWishBubbleCount');
    if (wc) wc.textContent = wishLoad().length;
  }

  /* ── Intersection Observer for card reveal ── */
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
    });
  }, { threshold: 0.08 });

  function initCards(root) {
    root.querySelectorAll('.sdz-rc').forEach(c => io.observe(c));
    root.querySelectorAll('.sdz-rc__wish').forEach(btn => {
      if (wishHas(btn.dataset.productId)) btn.classList.add('wished');
    });
  }

  initCards(document);

  const recEl = document.querySelector('product-recommendations');
  if (recEl) {
    const observer = new MutationObserver(() => {
      initCards(recEl);
      observer.disconnect();
    });
    observer.observe(recEl, { childList: true, subtree: true });
  }

  document.addEventListener('click', function (e) {
    const addBtn = e.target.closest('.sdz-rc__btn:not(:disabled):not(.sdz-rc__btn--sold)');
    if (addBtn) { e.preventDefault(); e.stopPropagation(); rcAddToCart(addBtn); return; }

    const wishBtn = e.target.closest('.sdz-rc__wish');
    if (wishBtn) { e.preventDefault(); e.stopPropagation(); rcToggleWish(wishBtn); return; }
  }, true);

})();
</script>

{% schema %}
{
  "name": "t:sections.related-products.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
