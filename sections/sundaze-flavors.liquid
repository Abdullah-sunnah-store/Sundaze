<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600;700&display=swap');

.sf-page *,
.sf-page *::before,
.sf-page *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

.sf-page {
  min-height: 100vh;
  width: 100%;
  background: linear-gradient(135deg, #f9f7f4 0%, #f5f2ee 40%, #fef0f5 100%);
  font-family: 'DM Sans', sans-serif;
  position: relative;
  overflow-x: hidden;
  color: #1a1a1a;
  padding: 30px 20px;
}

@media (min-width: 768px) { .sf-page { padding: 60px 40px; } }

/* ── Decorative Background Glow ── */
.sf-glow {
  pointer-events: none;
  position: fixed;
  left: -100px;
  top: 50%;
  height: 600px;
  width: 600px;
  opacity: 0.25;
  background: radial-gradient(circle at 20% 50%, #fff9c4 0%, #fce4ec 50%, transparent 80%);
  z-index: 0;
}

.sf-container {
  position: relative;
  max-width: 1200px;
  margin: 0 auto;
  z-index: 1;
}

/* ── Header ── */
.sf-header {
  text-align: center;
  margin-bottom: 48px;
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.8s ease, transform 0.8s ease;
}

.sf-header.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.sf-eyebrow {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.38em;
  text-transform: uppercase;
  color: #c4607a;
  margin-bottom: 20px;
}

.sf-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2.4rem, 6vw, 4rem);
  font-weight: 900;
  line-height: 1.08;
  color: #1a1a1a;
  margin-bottom: 16px;
}

.sf-title em {
  font-style: italic;
  background: linear-gradient(135deg, #d4926e 0%, #c4607a 55%, #a84f6a 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.sf-subtitle {
  font-size: 18px;
  font-weight: 300;
  line-height: 1.82;
  color: rgba(30,17,24,0.82);
  max-width: 600px;
  margin: 0 auto;
}

/* ── Interactive Filter Pills ── */
.sf-filters {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12px;
  margin-bottom: 56px;
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.8s ease 0.2s, transform 0.8s ease 0.2s;
}

.sf-filters.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.sf-pill {
  font-family: 'DM Sans', sans-serif;
  padding: 10px 24px;
  border-radius: 999px;
  border: 1px solid rgba(196,96,122,0.22);
  background: rgba(255,255,255,0.50);
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.10em;
  color: rgba(30,17,24,0.48);
  cursor: pointer;
  transition: all 0.3s ease;
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
}

.sf-pill:hover {
  background: rgba(255,255,255,0.72);
  border-color: rgba(196,96,122,0.40);
  color: #c4607a;
  transform: translateY(-2px);
}

.sf-pill.active {
  background: linear-gradient(135deg, #d4926e 0%, #c4607a 55%, #a84f6a 100%);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 4px 18px rgba(196,96,122,0.28);
}

/* ── Flavor Grid ── */
.sf-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 32px;
}

@media (min-width: 640px) { .sf-grid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 960px) { .sf-grid { grid-template-columns: repeat(3, 1fr); } }

/* ── Flavor Card ── */
.sf-card {
  background: #fff;
  border-radius: 28px;
  overflow: hidden;
  box-shadow: 0 12px 32px rgba(0,0,0,0.06);
  border: 1px solid rgba(255,255,255,0.8);
  opacity: 0;
  transform: scale(0.95) translateY(20px);
  transition: opacity 0.5s ease, transform 0.5s ease, box-shadow 0.3s ease;
  cursor: pointer;
  text-decoration: none;
  color: #1a1a1a;
}

.sf-card.is-visible {
  opacity: 1;
  transform: scale(1) translateY(0);
}

.sf-card.is-hidden {
  display: none;
}

.sf-card:hover {
  box-shadow: 0 20px 48px rgba(0,0,0,0.12);
  transform: scale(1.02) translateY(-4px);
}

/* ── Card Image Area ── */
.sf-card__img-wrap {
  position: relative;
  height: 280px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* ── Single Image (Default) ── */
.sf-card__img {
  width: 80%;
  height: auto;
  object-fit: contain;
  filter: drop-shadow(0 15px 15px rgba(0,0,0,0.15));
  transition: transform 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);
  z-index: 2;
}

.sf-card:hover .sf-card__img {
  transform: scale(1.1) ;
}

/* ── Image Stack (Hover Reveal Effect) ── */
.sf-card__img-stack {
  position: relative;
  width: 100%;
  height: 100%;
  display: grid;
  place-items: center; 
  perspective: 1000px; 
}

.sf-img-front, .sf-img-back {
  grid-area: 1 / 1; 
  width: 80%;
  height: auto;
  object-fit: contain;
  filter: drop-shadow(0 15px 15px rgba(0,0,0,0.15));
  transition: transform 0.5s cubic-bezier(0.25, 0.8, 0.25, 1), opacity 0.4s ease;
  transform-origin: bottom center; 
}

.sf-img-front {
  z-index: 2;
}

.sf-img-back {
  z-index: 1;
  opacity: 0;
  transform: rotate(0deg); 
}

.sf-card:hover .sf-img-front {
  transform: rotate(-12deg) scale(0.95);
}

.sf-card:hover .sf-img-back {
  opacity: 1;
  transform: rotate(12deg) scale(0.95);
}

.sf-card__vibe {
  position: absolute;
  top: 16px;
  right: 16px;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(4px);
  padding: 6px 14px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #333;
  z-index: 10; 
  box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}

/* ── Card Content ── */
.sf-card__content {
  padding: 24px;
  text-align: center;
}

.sf-card__title {
  font-family: 'Playfair Display', serif;
  font-size: 22px;
  font-weight: 700;
  margin-bottom: 8px;
}

.sf-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  justify-content: center;
  margin-bottom: 16px;
}

.sf-card__tag {
  font-size: 11px;
  font-weight: 500;
  padding: 4px 10px;
  border-radius: 999px;
  background: #f5f2ee;
  color: #6b4226;
}

.sf-card__price {
  font-size: 20px;
  font-weight: 600;
  margin-bottom: 20px;
}

/* ── Card Actions (Add + Wish) ── */
.sf-card__actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
}

.sf-add-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: linear-gradient(135deg, #d4926e 0%, #c4607a 55%, #a84f6a 100%);
  color: #fff;
  border: none;
  border-radius: 999px;
  padding: 12px 24px;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.10em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s ease, transform 0.1s ease, box-shadow 0.2s ease;
  font-family: 'DM Sans', sans-serif;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4px 18px rgba(196,96,122,0.26);
}

.sf-add-btn:hover:not(:disabled) { transform: scale(1.05); box-shadow: 0 8px 28px rgba(196,96,122,0.36); }
.sf-add-btn:active:not(:disabled) { transform: scale(0.97); }
.sf-add-btn:disabled { opacity: 0.7; cursor: not-allowed; }
.sf-add-btn.loading { background: linear-gradient(135deg, #b07858, #a04e68); }
.sf-add-btn.added { background: linear-gradient(135deg, #5a9a5a, #3d7a3d); }

.sf-add-btn .neo-spinner {
  display: none;
  width: 14px; height: 14px;
  border: 2px solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

.sf-add-btn.loading .neo-spinner { display: block; }
.sf-add-btn.loading .neo-btn-icon,
.sf-add-btn.loading .neo-btn-text { display: none; }

@keyframes spin { to { transform: rotate(360deg); } }

/* ── WISHLIST BUTTON (Card) ── */
.sf-wish-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  border: 1.5px solid rgba(196,96,122,0.22);
  background: transparent;
  cursor: pointer;
  transition: border-color 0.2s ease, background 0.2s ease, transform 0.15s ease;
  flex-shrink: 0;
}

.sf-wish-btn:hover {
  border-color: #c4607a;
  background: rgba(254,240,245,0.6);
  transform: scale(1.1);
}

.sf-wish-btn:active { transform: scale(0.9); }

.sf-wish-btn svg {
  width: 20px; height: 20px;
  color: rgba(168,79,106,0.4);
  transition: fill 0.25s ease, color 0.25s ease, transform 0.2s ease;
}

.sf-wish-btn.wished { border-color: #c4607a; background: rgba(254,240,245,0.6); }
.sf-wish-btn.wished svg { fill: #c4607a; color: #c4607a; }
.sf-wish-btn.wish-pop svg { transform: scale(1.4); }


/* ══════════════════════════════════
   TOAST, BUBBLES & DRAWER STYLES
══════════════════════════════════ */

.sf-toast {
  position: fixed;
  bottom: 32px;
  left: 50%;
  transform: translateX(-50%) translateY(80px);
  z-index: 99999;
  display: flex;
  align-items: center;
  gap: 10px;
  background: #1a1a1a;
  color: #fff;
  border-radius: 50px;
  padding: 12px 20px;
  font-size: 13px;
  font-weight: 400;
  box-shadow: 0 8px 32px rgba(0,0,0,0.25);
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.4s ease;
  opacity: 0;
  white-space: nowrap;
  pointer-events: none;
  font-family: 'DM Sans', sans-serif;
}

.sf-toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }
.sf-toast.success { background: #1a1a1a; }
.sf-toast.error   { background: #c0392b; }
.sf-toast.wish    { background: linear-gradient(135deg, #c4607a, #a84f6a); }

.sf-toast-icon { font-size: 16px; line-height: 1; }

.sf-cart-bubble {
  position: fixed; top: 24px; right: 24px; z-index: 99998;
  display: flex; align-items: center; gap: 8px;
  background: #fff; border-radius: 50px; padding: 10px 16px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.12); font-size: 13px; font-weight: 500;
  color: #1a1a1a; cursor: pointer; opacity: 1; transform: translateY(0);
  transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.2s ease, border-color 0.2s ease;
  border: 1px solid rgba(196,96,122,0.18); text-decoration: none; font-family: 'DM Sans', sans-serif;
}

.sf-cart-bubble:hover { background: linear-gradient(135deg, #d4926e, #c4607a); color: #fff; border-color: transparent; }

.sf-cart-count {
  display: inline-flex; align-items: center; justify-content: center;
  width: 20px; height: 20px; border-radius: 50%; background: linear-gradient(135deg, #d4926e, #c4607a);
  color: #fff; font-size: 10px; font-weight: 700; transition: background 0.2s ease;
}

.sf-cart-bubble:hover .sf-cart-count { background: #fff; color: #c4607a; }

.sf-wish-bubble {
  position: fixed; top: 72px; right: 24px; z-index: 99997;
  display: flex; align-items: center; gap: 8px;
  background: #fff; border-radius: 50px; padding: 10px 16px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.12); font-size: 13px; font-weight: 500;
  color: #1a1a1a; cursor: pointer; border: 1px solid rgba(196,96,122,0.18);
  transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.2s ease, border-color 0.2s ease;
  opacity: 1; transform: translateY(0); font-family: 'DM Sans', sans-serif;
}

.sf-wish-bubble:hover { background: rgba(254,240,245,0.6); border-color: #c4607a; }

.sf-wish-bubble-count {
  display: inline-flex; align-items: center; justify-content: center;
  min-width: 20px; height: 20px; border-radius: 50px;
  background: linear-gradient(135deg, #d4926e, #c4607a);
  color: #fff; font-size: 10px; font-weight: 700; padding: 0 5px;
  transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.sf-wish-bubble-count.bump { transform: scale(1.4); }

/* Drawer */
.sf-wishlist-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.35); z-index: 100000;
  opacity: 0; pointer-events: none; transition: opacity 0.35s ease; backdrop-filter: blur(4px);
}

.sf-wishlist-overlay.open { opacity: 1; pointer-events: all; }

.sf-wishlist-drawer {
  position: fixed; top: 0; right: 0; height: 100%; width: min(400px, 100vw);
  background: #fff; z-index: 100001; padding: 32px 24px;
  box-shadow: -8px 0 40px rgba(0,0,0,0.12); transform: translateX(100%);
  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  overflow-y: auto; display: flex; flex-direction: column;
}

.sf-wishlist-drawer.open { transform: translateX(0); }

.sf-drawer-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
.sf-drawer-title { font-family: 'Playfair Display', serif; font-size: 24px; font-weight: 700; color: #1a1a1a; }

.sf-drawer-close {
  display: flex; align-items: center; justify-content: center;
  width: 36px; height: 36px; border-radius: 50%; border: 1px solid #e8e0d8;
  background: transparent; cursor: pointer; font-size: 18px; color: rgba(63,36,23,0.5);
  transition: border-color 0.2s ease, color 0.2s ease;
}

.sf-drawer-close:hover { border-color: #c0392b; color: #c0392b; }

.sf-drawer-empty {
  flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 12px; color: rgba(30,17,24,0.48); font-size: 14px; text-align: center;
}

.sf-drawer-empty-icon { font-size: 48px; }

.sf-wish-item { display: flex; align-items: center; gap: 14px; padding: 16px 0; border-bottom: 1px solid rgba(196,96,122,0.14); }

.sf-wish-item-img {
  width: 64px; height: 64px; border-radius: 12px; object-fit: cover;
  background: #f5f2ee; flex-shrink: 0;
}

.sf-wish-item-img-placeholder {
  width: 64px; height: 64px; border-radius: 12px;
  background: linear-gradient(135deg, #fce4ec, #f5e6d3);
  flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 24px;
}

.sf-wish-item-info { flex: 1; }
.sf-wish-item-name { font-family: 'Playfair Display', serif; font-size: 15px; font-weight: 700; color: #1a1a1a; margin: 0 0 2px; }
.sf-wish-item-price { font-size: 13px; color: rgba(30,17,24,0.48); margin: 0 0 8px; font-weight: 500; }
.sf-wish-item-actions { display: flex; gap: 8px; }

.sf-wish-add-btn {
  font-size: 11px; font-weight: 500; padding: 6px 14px; border-radius: 999px;
  border: none; background: linear-gradient(135deg, #d4926e, #c4607a); color: #fff; cursor: pointer;
  transition: transform 0.2s ease, box-shadow 0.2s ease; font-family: 'DM Sans', sans-serif;
}

.sf-wish-add-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(196,96,122,0.28); }

.sf-wish-remove-btn {
  font-size: 11px; font-weight: 500; padding: 6px 10px; border-radius: 999px;
  border: 1px solid rgba(196,96,122,0.22); background: transparent; color: rgba(30,17,24,0.48);
  cursor: pointer; transition: border-color 0.2s ease, color 0.2s ease; font-family: 'DM Sans', sans-serif;
}

.sf-wish-remove-btn:hover { border-color: #c0392b; color: #c0392b; }

</style>

<!-- TOAST -->
<div class="sf-toast" id="sfToast" role="status" aria-live="polite">
  <span class="sf-toast-icon" id="sfToastIcon"></span>
  <span id="sfToastMsg"></span>
</div>

{% comment %} <!-- CART BUBBLE -->
<a href="/cart" class="sf-cart-bubble" id="sfCartBubble" aria-label="View cart">
  🛒 Cart
  <span class="sf-cart-count" id="sfCartCount">0</span>
</a>

<!-- WISHLIST BUBBLE -->
<button class="sf-wish-bubble" id="sfWishBubble" onclick="SfWish.openDrawer()" aria-label="View wishlist">
  💗 Wishlist
  <span class="sf-wish-bubble-count" id="sfWishBubbleCount">0</span>
</button> {% endcomment %}

<!-- WISHLIST OVERLAY + DRAWER -->
<div class="sf-wishlist-overlay" id="sfWishOverlay"></div>
<div class="sf-wishlist-drawer" id="sfWishDrawer" role="dialog" aria-modal="true" aria-label="Wishlist">
  <div class="sf-drawer-header">
    <p class="sf-drawer-title">💗 Wishlist</p>
    <button class="sf-drawer-close" id="sfDrawerClose" aria-label="Close wishlist">✕</button>
  </div>
  <div id="sfWishList"></div>
</div>

<div class="sf-glow" aria-hidden="true"></div>

<div class="sf-page">
  <div class="sf-container">
    
    <!-- ── Header ── -->
    <div class="sf-header" id="sf-header">
      <p class="sf-eyebrow">Flavor Discovery</p>
      <h1 class="sf-title">Find Your <em>Perfect Flavor</em></h1>
      <p class="sf-subtitle">Explore by profile, vibe, or product type. Find the flavor that fits your session.</p>
    </div>

    <!-- ── Dynamic Filter Pills ── -->
    <div class="sf-filters" id="sf-filters">
      <button class="sf-pill active" data-filter="all">All Flavors</button>
    </div>

    <!-- ── Product Grid ── -->
    <div id="sfEmptyJS" class="sf-empty" style="display:none; text-align:center; padding:80px 20px; font-family:'Playfair Display', serif; font-style:italic; font-size:24px; color:var(--sun-muted);">
      No flavors found matching this selection 🍦
    </div>
    <div class="sf-grid" id="sf-grid">
      {%- for block in section.blocks -%}
        {%- assign bg = block.settings.bg_color | default: '#f5f2ee' -%}
        <a
          class="sf-card"
          href="{{ block.settings.link | default: '#' }}"
          data-tags="{{ block.settings.tags | handleize }}"
          {{ block.shopify_attributes }}
          aria-label="View {{ block.settings.title }}"
        >
          <div class="sf-card__img-wrap" style="background: linear-gradient(135deg, {{ bg }} 0%, {{ bg | color_darken: 10 }} 100%);">
            
            {%- if block.settings.image_back != blank -%}
              <!-- Dual Image Stack (Hover Reveal) -->
              <div class="sf-card__img-stack">
                <img class="sf-img-back" src="{{ block.settings.image_back | img_url: '500x' }}" alt="{{ block.settings.title | escape }} secondary" draggable="false">
                <img class="sf-img-front" src="{{ block.settings.image | img_url: '500x' }}" alt="{{ block.settings.title | escape }}" draggable="false">
              </div>
            {%- elsif block.settings.image != blank -%}
              <!-- Single Image (Default) -->
              <img class="sf-card__img" src="{{ block.settings.image | img_url: '500x' }}" alt="{{ block.settings.title | escape }}" draggable="false">
            {%- else -%}
              <div style="font-size: 60px; opacity: 0.5;">🍦</div>
            {%- endif -%}

            <span class="sf-card__vibe">{{ block.settings.vibe }}</span>
          </div>
          
          <div class="sf-card__content">
            <h3 class="sf-card__title">{{ block.settings.title }}</h3>
            <div class="sf-card__tags">
              {%- assign tag_list = block.settings.tags | split: ',' -%}
              {%- for tag in tag_list -%}
                <span class="sf-card__tag">{{ tag | strip }}</span>
              {%- endfor -%}
            </div>
            <p class="sf-card__price">{{ block.settings.price }}</p>
            
            <div class="sf-card__actions">
              <button 
                class="sf-add-btn" 
                data-variant-id="{{ block.settings.variant_id }}"
                data-product-name="{{ block.settings.title }}"
                onclick="event.preventDefault(); event.stopPropagation(); SfCart.add(this)">
                <div class="neo-spinner"></div>
                <svg class="neo-btn-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
                <span class="neo-btn-text">Add to Cart</span>
              </button>

              <button 
                class="sf-wish-btn" 
                aria-label="Add to wishlist"
                data-variant-id="{{ block.settings.variant_id }}"
                data-product-name="{{ block.settings.title }}"
                data-product-price="{{ block.settings.price }}"
                data-product-image="{{ block.settings.image | img_url: '200x' }}"
                data-product-emoji="{{ block.settings.emoji | default: '🍩' }}"
                onclick="event.preventDefault(); event.stopPropagation(); SfWish.toggle(this)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
              </button>
            </div>

          </div>
        </a>
      {%- endfor -%}
    </div>

  </div>
</div>

<script>
(function() {

  /* ════════════════════════════════════════
     FIX: Move fixed elements to body to prevent theme clipping
  ════════════════════════════════════════ */
  document.querySelectorAll('.sf-toast, .sf-cart-bubble, .sf-wish-bubble, .sf-wishlist-overlay, .sf-wishlist-drawer').forEach(el => {
    document.body.appendChild(el);
  });

  /* ════════════════════════════════════════
     TOAST
  ════════════════════════════════════════ */
  const Toast = {
    _timer: null,
    show(msg, icon, type) {
      const el  = document.getElementById('sfToast');
      const txt = document.getElementById('sfToastMsg');
      const ico = document.getElementById('sfToastIcon');
      el.className  = 'sf-toast ' + (type || '');
      txt.textContent = msg;
      ico.textContent = icon || '';
      el.classList.add('show');
      clearTimeout(this._timer);
      this._timer = setTimeout(() => el.classList.remove('show'), 3000);
    }
  };

  /* ════════════════════════════════════════
     CART BUBBLE
  ════════════════════════════════════════ */
  const CartBubble = {
    bubble: document.getElementById('sfCartBubble'),
    count:  document.getElementById('sfCartCount'),
    init() {
      fetch('/cart.js').then(r => r.json()).then(d => this.update(d.item_count)).catch(() => {});
    },
    update(n) {
      /* update theme header cart count if it exists */
      fetch('/?section_id=cart-icon-bubble&t=' + Date.now())
        .then(r => r.text())
        .then(html => {
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
          const newContent = doc.getElementById('cart-icon-bubble') || doc.querySelector('.shopify-section') || doc.body;
          const oldBubble = document.getElementById('cart-icon-bubble');
          if (newContent && oldBubble) {
            const newInner = newContent.innerHTML;
            if (newInner) oldBubble.innerHTML = newInner;
          }
        })
        .catch(() => {});

      if (this.count) this.count.textContent = n;
      document.querySelectorAll('.cart-count-bubble span[aria-hidden="true"]').forEach(el => el.textContent = n);
    }
  };

  /* ════════════════════════════════════════
     WISH BUBBLE
  ════════════════════════════════════════ */
  const WishBubble = {
    el:    document.getElementById('sfWishBubble'),
    count: document.getElementById('sfWishBubbleCount'),
    update(n) {
      this.count.textContent = n;
      this.count.classList.remove('bump');
      void this.count.offsetWidth; 
      this.count.classList.add('bump');
      setTimeout(() => this.count.classList.remove('bump'), 300);
    }
  };

  /* ════════════════════════════════════════
     ADD TO CART
  ════════════════════════════════════════ */
  const SfCart = {
    add(btn) {
      const variantId   = btn.dataset.variantId;
      const productName = btn.dataset.productName || 'Product';

      if (!variantId || variantId === '') {
        Toast.show('Variant not configured yet', '⚠️', 'error');
        return;
      }

      btn.disabled = true;
      btn.classList.add('loading');

      fetch('/cart/add.js', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ id: parseInt(variantId, 10), quantity: 1 })
      })
      .then(res => {
        if (!res.ok) return res.json().then(e => { throw new Error(e.description || 'Error'); });
        return res.json();
      })
      .then(() => {
        btn.classList.remove('loading');
        btn.classList.add('added');
        btn.querySelector('.neo-btn-icon').outerHTML = '<svg class="neo-btn-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>';
        btn.querySelector('.neo-btn-text').textContent = 'Added!';

        Toast.show(productName + ' added to cart', '🛒', 'success');

        fetch('/cart.js').then(r => r.json()).then(d => CartBubble.update(d.item_count));
        document.dispatchEvent(new CustomEvent('cart:refresh'));

        setTimeout(() => {
          btn.disabled = false;
          btn.classList.remove('added');
          btn.querySelector('.neo-btn-text').textContent = 'Add to Cart';
          btn.querySelector('.neo-btn-icon').outerHTML = '<svg class="neo-btn-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>';
        }, 2500);
      })
      .catch(err => {
        btn.disabled = false;
        btn.classList.remove('loading');
        Toast.show(err.message || 'Could not add to cart', '❌', 'error');
      });
    }
  };
  window.SfCart = SfCart;

  /* ════════════════════════════════════════
     WISHLIST (localStorage)
  ════════════════════════════════════════ */
  const WISH_KEY = 'sundaze_wishlist_v1';

  const SfWish = {
    _load() {
      try { return JSON.parse(localStorage.getItem(WISH_KEY) || '[]'); }
      catch { return []; }
    },
    _save(list) {
      localStorage.setItem(WISH_KEY, JSON.stringify(list));
    },
    _has(id) {
      return this._load().some(i => i.id === id);
    },

    toggle(btn) {
      const id    = btn.dataset.variantId;
      const name  = btn.dataset.productName  || 'Product';
      const price = btn.dataset.productPrice || '';
      const img   = btn.dataset.productImage || '';
      const emoji = btn.dataset.productEmoji || '🍩';

      if (!id || id === '') {
        Toast.show('Variant not configured yet', '⚠️', 'error');
        return;
      }

      const list = this._load();
      const idx  = list.findIndex(i => i.id === id);

      if (idx === -1) {
        list.push({ id, name, price, img, emoji });
        this._save(list);
        this._setWished(btn, true);
        Toast.show(name + ' wishlisted', '💗', 'wish');
      } else {
        list.splice(idx, 1);
        this._save(list);
        this._setWished(btn, false);
        Toast.show('Removed from wishlist', '🤍', '');
      }

      WishBubble.update(this._load().length);
      this._renderDrawer();
    },

    _setWished(btn, wished) {
      if (wished) {
        btn.classList.add('wished');
      } else {
        btn.classList.remove('wished');
      }
      btn.classList.add('wish-pop');
      setTimeout(() => btn.classList.remove('wish-pop'), 250);
    },

    initButtons() {
      document.querySelectorAll('.sf-wish-btn').forEach(btn => {
        const id = btn.dataset.variantId;
        if (id && this._has(id)) btn.classList.add('wished');
      });
    },

    openDrawer() {
      this._renderDrawer();
      document.getElementById('sfWishOverlay').classList.add('open');
      document.getElementById('sfWishDrawer').classList.add('open');
      document.body.style.overflow = 'hidden';
    },
    closeDrawer() {
      document.getElementById('sfWishOverlay').classList.remove('open');
      document.getElementById('sfWishDrawer').classList.remove('open');
      document.body.style.overflow = '';
    },

    _renderDrawer() {
      const list = this._load();
      const container = document.getElementById('sfWishList');

      if (list.length === 0) {
        container.innerHTML = `
          <div class="sf-drawer-empty">
            <div class="sf-drawer-empty-icon">🤍</div>
            <p>Your wishlist is empty</p>
            <p style="font-size:12px;opacity:0.6">Tap the heart on any product to save it here</p>
          </div>`;
        return;
      }

      container.innerHTML = list.map(item => `
        <div class="sf-wish-item" data-wish-id="${item.id}">
          ${item.img
            ? `<img class="sf-wish-item-img" src="${item.img}" alt="${item.name}">`
            : `<div class="sf-wish-item-img-placeholder">${item.emoji}</div>`
          }
          <div class="sf-wish-item-info">
            <p class="sf-wish-item-name">${item.name}</p>
            <p class="sf-wish-item-price">${item.price}</p>
            <div class="sf-wish-item-actions">
              <button class="sf-wish-add-btn" onclick="SfWish._addFromDrawer('${item.id}', '${item.name}', this)">Add to cart</button>
              <button class="sf-wish-remove-btn" onclick="SfWish._removeFromDrawer('${item.id}')">Remove</button>
            </div>
          </div>
        </div>
      `).join('');
    },

    _addFromDrawer(id, name, btn) {
      if (!id) return;
      btn.textContent = 'Adding…';
      btn.disabled = true;

      fetch('/cart/add.js', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ id: parseInt(id, 10), quantity: 1 })
      })
      .then(res => {
        if (!res.ok) throw new Error();
        return res.json();
      })
      .then(() => {
        btn.textContent = '✓ Added!';
        Toast.show(name + ' added to cart', '🛒', 'success');
        fetch('/cart.js').then(r => r.json()).then(d => CartBubble.update(d.item_count));
        document.dispatchEvent(new CustomEvent('cart:refresh'));
        setTimeout(() => { btn.textContent = 'Add to cart'; btn.disabled = false; }, 2000);
      })
      .catch(() => {
        btn.textContent = 'Error';
        btn.disabled = false;
      });
    },

    _removeFromDrawer(id) {
      const list = this._load().filter(i => i.id !== id);
      this._save(list);

      document.querySelectorAll(`.sf-wish-btn[data-variant-id="${id}"]`).forEach(b => {
        b.classList.remove('wished');
      });

      WishBubble.update(list.length);
      this._renderDrawer();
    }
  };
  window.SfWish = SfWish;

  /* ════════════════════════════════════════
     FILTERS
  ════════════════════════════════════════ */
  const grid = document.getElementById('sf-grid');
  const filtersWrap = document.getElementById('sf-filters');
  const cards = Array.from(grid.querySelectorAll('.sf-card'));
  const allTags = new Set();

  cards.forEach(card => {
    const tagsString = card.dataset.tags;
    if (tagsString) {
      tagsString.split('-').forEach(tag => {
        if (tag.trim() !== '') allTags.add(tag.trim());
      });
    }
  });

  allTags.forEach(tag => {
    const btn = document.createElement('button');
    btn.className = 'sf-pill';
    btn.dataset.filter = tag;
    btn.textContent = tag.charAt(0).toUpperCase() + tag.slice(1);
    filtersWrap.appendChild(btn);
  });

  const pills = filtersWrap.querySelectorAll('.sf-pill');

  function filterCards(filterValue) {
    pills.forEach(p => p.classList.toggle('active', p.dataset.filter === filterValue));
    let visibleCount = 0;
    cards.forEach(card => {
      const cardTags = card.dataset.tags;
      const show = filterValue === 'all' || (cardTags && cardTags.includes(filterValue));
      if (show) {
        visibleCount++;
        card.classList.remove('is-hidden');
        card.style.opacity = '0';
        card.style.transform = 'scale(0.95) translateY(20px)';
        setTimeout(() => {
          card.style.opacity = '1';
          card.style.transform = 'scale(1) translateY(0)';
        }, 50);
      } else {
        card.classList.add('is-hidden');
      }
    });

    const emptyJS = document.getElementById('sfEmptyJS');
    if (emptyJS) {
      emptyJS.style.display = visibleCount === 0 ? 'block' : 'none';
    }
  }

  pills.forEach(pill => {
    pill.addEventListener('click', () => filterCards(pill.dataset.filter));
  });

  /* ════════════════════════════════════════
     INTERSECTION OBSERVER
  ════════════════════════════════════════ */
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.sf-header, .sf-filters, .sf-card').forEach(el => observer.observe(el));

  /* ════════════════════════════════════════
     DRAWER CLOSE EVENTS
  ════════════════════════════════════════ */
  document.getElementById('sfDrawerClose').addEventListener('click', () => SfWish.closeDrawer());
  document.getElementById('sfWishOverlay').addEventListener('click', () => SfWish.closeDrawer());
  document.addEventListener('keydown', e => { if (e.key === 'Escape') SfWish.closeDrawer(); });

  /* ════════════════════════════════════════
     INIT
  ════════════════════════════════════════ */
  CartBubble.init();
  SfWish.initButtons();
  WishBubble.update(SfWish._load().length);

})();
</script>

