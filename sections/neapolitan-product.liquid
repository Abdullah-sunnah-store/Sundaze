<style>
  .neo-toast {
    position: fixed; bottom: 32px; left: 50%;
    transform: translateX(-50%) translateY(80px);
    z-index: 9999; display: flex; align-items: center; gap: 10px;
    background: #1a1a1a; color: #fff; border-radius: 50px; padding: 12px 20px;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px; font-weight: 500; letter-spacing: 0.04em;
    box-shadow: 0 8px 32px rgba(0,0,0,0.25);
    transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1), opacity 0.4s ease;
    opacity: 0; white-space: nowrap; pointer-events: none;
  }
  .neo-toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }
  .neo-toast.error { background: #c0392b; }
  .neo-toast.wish  { background: linear-gradient(135deg, #e8a0bf, #c77dff); }
  .neo-toast-icon  { font-size: 16px; line-height: 1; }

  .neo-cart-bubble {
    position: fixed; top: 118px; right: 24px; z-index: 9998;
    display: flex; align-items: center; gap: 8px;
    background: #fff; border-radius: 50px; padding: 10px 16px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    font-family: 'DM Sans', sans-serif;
    font-size: 13px; font-weight: 500; color: #1a1a1a;
    cursor: pointer; opacity: 0; transform: translateY(-16px);
    transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
    border: 1px solid #e8e0d8; text-decoration: none;
  }
  .neo-cart-bubble.show { opacity: 1; transform: translateY(0); }
  .neo-cart-bubble:hover { background: #1a1a1a; color: #fff; border-color: #1a1a1a; }
  .neo-cart-count {
    display: inline-flex; align-items: center; justify-content: center;
    width: 20px; height: 20px; border-radius: 50%;
    background: #1a1a1a; color: #fff; font-size: 10px; font-weight: 600;
    font-family: 'DM Sans', sans-serif;
  }
  .neo-cart-bubble:hover .neo-cart-count { background: #e8a0bf; color: #1a1a1a; }

  .neo-wish-bubble {
    position: fixed; top: 166px; right: 24px; z-index: 9997;
    display: flex; align-items: center; gap: 8px;
    background: #fff; border-radius: 50px; padding: 10px 16px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    font-family: 'DM Sans', sans-serif;
    font-size: 13px; font-weight: 500; color: #1a1a1a;
    cursor: pointer; border: 1px solid #f0d6e8;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .neo-wish-bubble:hover { background: #fef0f5; border-color: #e8a0bf; }
  .neo-wish-bubble-count {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 20px; height: 20px; border-radius: 50px;
    background: linear-gradient(135deg, #e8a0bf, #c77dff);
    color: #fff; font-size: 10px; font-weight: 600;
    font-family: 'DM Sans', sans-serif;
    padding: 0 5px;
    transition: transform 0.2s cubic-bezier(0.34,1.56,0.64,1);
  }
  .neo-wish-bubble-count.bump { transform: scale(1.4); }

  @media (max-width: 640px) {
    .neo-wish-bubble { top: 105px; right: 2px; }
    .neo-cart-bubble { top: 62px;  right: 2px; }
  }

  .neo-wishlist-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.35);
    z-index: 10000; opacity: 0; pointer-events: none;
    transition: opacity 0.35s ease; backdrop-filter: blur(4px);
  }
  .neo-wishlist-overlay.open { opacity: 1; pointer-events: all; }
  .neo-wishlist-drawer {
    position: fixed; top: 0; right: 0; height: 100%;
    width: min(400px,100vw); background: #fff; z-index: 10001;
    padding: 32px 24px; box-shadow: -8px 0 40px rgba(0,0,0,0.12);
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.25,0.46,0.45,0.94);
    overflow-y: auto; display: flex; flex-direction: column;
    font-family: 'DM Sans', sans-serif;
  }
  .neo-wishlist-drawer.open { transform: translateX(0); }
  .neo-drawer-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
  .neo-drawer-title {
    font-family: 'Playfair Display', serif;
    font-size: 22px; font-weight: 700; color: #1a1a1a;
    letter-spacing: -.01em; margin: 0;
  }
  .neo-drawer-close {
    display: flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: 50%;
    border: 1px solid #e8e0d8; background: transparent;
    cursor: pointer; font-size: 18px; color: rgba(63,36,23,0.5);
    transition: border-color 0.2s, color 0.2s;
    font-family: 'DM Sans', sans-serif;
  }
  .neo-drawer-close:hover { border-color: #c0392b; color: #c0392b; }
  .neo-drawer-empty {
    flex: 1; display: flex; flex-direction: column; align-items: center;
    justify-content: center; gap: 12px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    color: rgba(107,66,38,0.4); font-size: 14px; text-align: center;
  }
  .neo-drawer-empty-icon { font-size: 48px; }
  .neo-wish-item { display: flex; align-items: center; gap: 14px; padding: 16px 0; border-bottom: 1px solid #f0ebe4; }
  .neo-wish-item-img { width: 64px; height: 64px; border-radius: 12px; object-fit: cover; background: #f5f2ee; flex-shrink: 0; }
  .neo-wish-item-img-placeholder { width: 64px; height: 64px; border-radius: 12px; background: linear-gradient(135deg,#fce4ec,#f5e6d3); flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 24px; }
  .neo-wish-item-info { flex: 1; }
  .neo-wish-item-name {
    font-family: 'Playfair Display', serif;
    font-size: 14px; font-weight: 700; color: #1a1a1a; margin: 0 0 2px;
  }
  .neo-wish-item-price {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px; font-weight: 300;
    color: rgba(107,66,38,0.6); margin: 0 0 8px;
  }
  .neo-wish-item-actions { display: flex; gap: 8px; }
  .neo-wish-add-btn {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px; font-weight: 500;
    letter-spacing: 0.08em; text-transform: uppercase;
    padding: 6px 14px; border-radius: 50px; border: none;
    background: #1a1a1a; color: #fff; cursor: pointer;
  }
  .neo-wish-add-btn:hover { background: #333; }
  .neo-wish-remove-btn {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px; font-weight: 500;
    letter-spacing: 0.04em;
    padding: 6px 10px; border-radius: 50px;
    border: 1px solid #e8e0d8; background: transparent;
    color: rgba(107,66,38,0.6); cursor: pointer;
  }
  .neo-wish-remove-btn:hover { border-color: #c0392b; color: #c0392b; }
</style>


<!-- ════════════════════════════════════════════════════════════
     ALL JAVASCRIPT (unified — bucket hero + product page)
════════════════════════════════════════════════════════════ -->
<script>
(function () {

  /* ── TOAST ── */
  var Toast = {
    _t: null,
    show: function (msg, icon, type) {
      var el  = document.getElementById('neoToast');
      var txt = document.getElementById('neoToastMsg');
      var ico = document.getElementById('neoToastIcon');
      if (!el || !txt || !ico) return;
      el.className    = 'neo-toast ' + (type || '');
      txt.textContent = msg;
      ico.textContent = icon || '';
      el.classList.add('show');
      clearTimeout(this._t);
      this._t = setTimeout(function () { el.classList.remove('show'); }, 3000);
    }
  };

  /* ── CART BUBBLE ── */
  var CartBubble = {
    bubble: document.getElementById('neoCartBubble'),
    count:  document.getElementById('neoCartCount'),
    init: function () {
      if (!this.bubble) return;
      fetch('/cart.js').then(function (r) { return r.json(); }).then(function (d) { CartBubble.update(d.item_count); }).catch(function () {});
    },
    update: function (n) {
      /* update theme header cart count if it exists */
      fetch('/?section_id=cart-icon-bubble')
        .then(function (r) { return r.text(); })
        .then(function (html) {
          var parser = new DOMParser();
          var doc = parser.parseFromString(html, 'text/html');
          var newContent = doc.getElementById('cart-icon-bubble') || doc.querySelector('.shopify-section') || doc.body;
          var oldBubble = document.getElementById('cart-icon-bubble');
          if (newContent && oldBubble) {
            oldBubble.innerHTML = newContent.innerHTML;
          }
        })
        .catch(function () {});

      if (!this.count || !this.bubble) return;
      this.count.textContent = n;
      if (n > 0) this.bubble.classList.add('show');
    }
  };

  /* ── WISHLIST BUBBLE ── */
  var WishBubble = {
    el:    document.getElementById('neoWishBubble'),
    count: document.getElementById('neoWishBubbleCount'),
    update: function (n) {
      if (!this.el || !this.count) return;
      this.count.textContent = n;
      this.count.classList.remove('bump');
      void this.count.offsetWidth;
      this.count.classList.add('bump');
      setTimeout(function () { if (WishBubble.count) WishBubble.count.classList.remove('bump'); }, 300);
    }
  };

  /* ── CART ADD (product page buttons) ── */
  var NeoCart = {
    add: function (btn) {
      var variantId   = btn.dataset.variantId;
      var productName = btn.dataset.productName || 'Product';
      if (!variantId || variantId === '') {
        Toast.show('Variant not configured yet', '⚠️', 'error');
        return;
      }
      btn.disabled = true;
      btn.classList.add('loading');
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: parseInt(variantId, 10), quantity: 1 })
      })
      .then(function (res) {
        if (!res.ok) return res.json().then(function (e) { throw new Error(e.description || 'Error'); });
        return res.json();
      })
      .then(function () {
        btn.classList.remove('loading');
        btn.classList.add('added');
        btn.querySelector('.neo-btn-text').textContent = 'Added!';
        Toast.show(productName + ' added to cart', '🛒', '');
        fetch('/cart.js').then(function (r) { return r.json(); }).then(function (d) { CartBubble.update(d.item_count); });
        document.dispatchEvent(new CustomEvent('cart:refresh'));
        setTimeout(function () {
          btn.disabled = false;
          btn.classList.remove('added');
          btn.querySelector('.neo-btn-text').textContent = btn.dataset.originalText || 'Add to cart';
        }, 2500);
      })
      .catch(function (err) {
        btn.disabled = false;
        btn.classList.remove('loading');
        Toast.show(err.message || 'Could not add to cart', '❌', 'error');
      });
    }
  };
  window.NeoCart = NeoCart;

  /* ── WISHLIST ── */
  var WISH_KEY = 'sundaze_wishlist_v1';
  var NeoWish = {
    _load: function () { try { return JSON.parse(localStorage.getItem(WISH_KEY) || '[]'); } catch (e) { return []; } },
    _save: function (list) { localStorage.setItem(WISH_KEY, JSON.stringify(list)); },
    _has:  function (id) { return this._load().some(function (i) { return i.id === id; }); },
    toggle: function (btn) {
      var id    = btn.dataset.variantId;
      var name  = btn.dataset.productName  || 'Product';
      var price = btn.dataset.productPrice || '';
      var img   = btn.dataset.productImage || '';
      var emoji = btn.dataset.productEmoji || '🍩';
      if (!id || id === '') { Toast.show('Variant not configured yet', '⚠️', 'error'); return; }
      var list = this._load();
      var idx  = list.findIndex(function (i) { return i.id === id; });
      if (idx === -1) {
        list.push({ id: id, name: name, price: price, img: img, emoji: emoji });
        this._save(list);
        this._setWished(btn, true);
        Toast.show(name + ' wishlisted', '💗', 'wish');
      } else {
        list.splice(idx, 1);
        this._save(list);
        this._setWished(btn, false);
        Toast.show('Removed from wishlist', '🤍', '');
      }
      WishBubble.update(this._load().length);
      this._renderDrawer();
    },
    _setWished: function (btn, wished) {
      if (wished) btn.classList.add('wished'); else btn.classList.remove('wished');
      btn.classList.add('wish-pop');
      setTimeout(function () { btn.classList.remove('wish-pop'); }, 250);
    },
    initButtons: function () {
      var self = this;
      document.querySelectorAll('.neo-wish-btn').forEach(function (btn) {
        if (btn.dataset.variantId && self._has(btn.dataset.variantId)) btn.classList.add('wished');
      });
    },
    openDrawer: function () {
      var overlay = document.getElementById('neoWishOverlay');
      var drawer = document.getElementById('neoWishDrawer');
      if (!overlay || !drawer) return;
      this._renderDrawer();
      overlay.classList.add('open');
      drawer.classList.add('open');
      document.body.style.overflow = 'hidden';
    },
    closeDrawer: function () {
      var overlay = document.getElementById('neoWishOverlay');
      var drawer = document.getElementById('neoWishDrawer');
      if (!overlay || !drawer) return;
      overlay.classList.remove('open');
      drawer.classList.remove('open');
      document.body.style.overflow = '';
    },
    _renderDrawer: function () {
      var list      = this._load();
      var container = document.getElementById('neoWishList');
      if (!container) return;
      if (list.length === 0) {
        container.innerHTML = '<div class="neo-drawer-empty"><div class="neo-drawer-empty-icon">🤍</div><p>Your wishlist is empty</p><p style="font-size:12px;opacity:.6">Tap the heart on any product to save it here</p></div>';
        return;
      }
      container.innerHTML = list.map(function (item) {
        return (
          '<div class="neo-wish-item" data-wish-id="' + item.id + '">' +
            (item.img
              ? '<img class="neo-wish-item-img" src="' + item.img + '" alt="' + item.name + '">'
              : '<div class="neo-wish-item-img-placeholder">' + item.emoji + '</div>') +
            '<div class="neo-wish-item-info">' +
              '<p class="neo-wish-item-name">' + item.name + '</p>' +
              '<p class="neo-wish-item-price">' + item.price + '</p>' +
              '<div class="neo-wish-item-actions">' +
                '<button class="neo-wish-add-btn" onclick="NeoWish._addFromDrawer(\'' + item.id + '\',\'' + item.name + '\',this)">Add to cart</button>' +
                '<button class="neo-wish-remove-btn" onclick="NeoWish._removeFromDrawer(\'' + item.id + '\')">Remove</button>' +
              '</div>' +
            '</div>' +
          '</div>'
        );
      }).join('');
    },
    _addFromDrawer: function (id, name, btn) {
      if (!id) return;
      btn.textContent = 'Adding…'; btn.disabled = true;
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: parseInt(id, 10), quantity: 1 })
      })
      .then(function (res) { if (!res.ok) throw new Error(); return res.json(); })
      .then(function () {
        btn.textContent = '✓ Added!';
        Toast.show(name + ' added to cart', '🛒', '');
        fetch('/cart.js').then(function (r) { return r.json(); }).then(function (d) { CartBubble.update(d.item_count); });
        document.dispatchEvent(new CustomEvent('cart:refresh'));
        setTimeout(function () { btn.textContent = 'Add to cart'; btn.disabled = false; }, 2000);
      })
      .catch(function () { btn.textContent = 'Error'; btn.disabled = false; });
    },
    _removeFromDrawer: function (id) {
      var list = this._load().filter(function (i) { return i.id !== id; });
      this._save(list);
      document.querySelectorAll('.neo-wish-btn[data-variant-id="' + id + '"]').forEach(function (b) { b.classList.remove('wished'); });
      WishBubble.update(list.length);
      this._renderDrawer();
    }
  };
  window.NeoWish = NeoWish;

  /* ── ACCORDION (product page) ── */
  function neoToggleAccordion(btn) {
    var body   = btn.nextElementSibling;
    var isOpen = btn.classList.contains('open');
    if (isOpen) { btn.classList.remove('open'); body.classList.remove('open'); }
    else         { btn.classList.add('open');    body.classList.add('open');    }
  }
  window.neoToggleAccordion = neoToggleAccordion;

  /* ── ACCORDION (bucket hero right column) ── */
  document.querySelectorAll('#neo-combined-{{ section.id }} [data-nbp-acc]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var acc    = btn.closest('.nbp-acc');
      var isOpen = acc.classList.contains('nbp-acc--open');
      var icon   = btn.querySelector('.nbp-acc__icon');
      /* toggle only this accordion — others stay as they are */
      if (isOpen) {
        acc.classList.remove('nbp-acc--open');
        if (icon) icon.classList.remove('nbp-acc__icon--open');
      } else {
        acc.classList.add('nbp-acc--open');
        if (icon) icon.classList.add('nbp-acc__icon--open');
      }
    });
  });

  /* ── BUCKET HERO — FLAVOR SELECTOR ── */
  var sid         = '{{ section.id }}';
  var vidInput    = document.getElementById('nbp-vid-'    + sid);
  var priceEl     = document.getElementById('nbp-price-'  + sid);
  var subEl       = document.getElementById('nbp-sub-'    + sid);
  var descEl      = document.getElementById('nbp-desc-'   + sid);
  var labelEl     = document.getElementById('nbp-label-'  + sid);
  var pill1El     = document.getElementById('nbp-pill1-'  + sid);
  var pill2El     = document.getElementById('nbp-pill2-'  + sid);
  var jarsEl      = document.getElementById('nbp-jars-'   + sid);
  var accDescEl   = document.getElementById('nbp-acc-desc-'   + sid);
  var accFlavorEl = document.getElementById('nbp-acc-flavor-' + sid);
  var accSpecsEl  = document.getElementById('nbp-acc-specs-'  + sid);
  var accHighlightEl = document.getElementById('nbp-acc-highlight-' + sid);
  var optBtns     = document.querySelectorAll('#neo-combined-' + sid + ' [data-nbp-opt]');

  var productImages = {
    nugtella:   '{{ section.settings.nugtella_product.featured_image | image_url: width: 600 }}',
    strawberry: '{{ section.settings.strawberry_product.featured_image | image_url: width: 600 }}',
    vanilla:    '{{ section.settings.vanilla_product.featured_image | image_url: width: 600 }}'
  };
  var bucketImageMixed = '{{ section.settings.bucket_image_mixed | image_url: width: 900 }}';

  function makeImg(src, alt, cls) {
    if (!src) return '';
    return '<img src="' + src + '" alt="' + (alt || '') + '" class="' + cls + '" loading="lazy">';
  }

  function renderJars(btn) {
    var mode   = btn.dataset.mode;
    var imgSrc = btn.dataset.image || '';
    if (!jarsEl) return;
    jarsEl.innerHTML = '';
    if (mode === 'mixed') {
      if (bucketImageMixed) {
        jarsEl.innerHTML = makeImg(bucketImageMixed, 'Mixed Bucket', 'nbp-jar nbp-jar--single');
      } else {
        jarsEl.innerHTML =
          makeImg(productImages.nugtella,   'Nugtella',             'nbp-jar nbp-jar--l') +
          makeImg(productImages.strawberry, 'Strawberry Shortcake', 'nbp-jar nbp-jar--c') +
          makeImg(productImages.vanilla,    'Vanilla',              'nbp-jar nbp-jar--r');
      }
    } else {
      if (imgSrc) jarsEl.innerHTML = makeImg(imgSrc, btn.dataset.label, 'nbp-jar nbp-jar--single');
    }
  }

  optBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      optBtns.forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      if (vidInput    && btn.dataset.variant)    vidInput.value          = btn.dataset.variant;
      if (priceEl     && btn.dataset.price)       priceEl.textContent     = btn.dataset.price;
      if (subEl       && btn.dataset.sub)         subEl.textContent       = btn.dataset.sub;
      if (descEl      && btn.dataset.desc)        descEl.textContent      = btn.dataset.desc;
      if (labelEl     && btn.dataset.label)       labelEl.textContent     = btn.dataset.label;
      if (pill1El     && btn.dataset.pill)        pill1El.textContent     = btn.dataset.pill;
      if (pill2El     && btn.dataset.pill2)       pill2El.textContent     = btn.dataset.pill2;
      
      if (accDescEl)   accDescEl.textContent   = btn.dataset.accDesc   || '';
      if (accFlavorEl) accFlavorEl.textContent = btn.dataset.accFlavor || '';

      if (accSpecsEl) {
        accSpecsEl.innerHTML = btn.dataset.accSpecs || '';
      }
      if (accHighlightEl) {
        accHighlightEl.textContent = btn.dataset.accHighlight || '';
      }

      /* ── SWAP HASH HOLES IMAGES ── */
      var newHasholes = btn.dataset.hasholesImg;
      if (newHasholes) {
        var miniImg = document.getElementById('nbp-hasholes-mini-' + sid);
        var featImg = document.getElementById('nbp-hasholes-feat-' + sid);
        if (miniImg && miniImg.tagName === 'IMG') miniImg.src = newHasholes;
        if (featImg && featImg.tagName === 'IMG') featImg.src = newHasholes;
      }

      /* ── SWAP BUCKET ICON ── */
      var newBucket = btn.dataset.bucketImg;
      if (newBucket) {
        var bucketImg = document.getElementById('nbp-bucket-icon-' + sid);
        if (bucketImg && bucketImg.tagName === 'IMG') bucketImg.src = newBucket;
      }

      /* ── SWAP WISHLIST DATA ── */
      var mainWish = document.getElementById('nbp-wish-' + sid);
      if (mainWish) {
        mainWish.dataset.variantId    = btn.dataset.variant || '';
        mainWish.dataset.productName  = btn.dataset.pill || '';
        mainWish.dataset.productPrice = btn.dataset.price || '';
        mainWish.dataset.productImage = btn.dataset.image || '';
        
        if (NeoWish._has(mainWish.dataset.variantId)) {
          mainWish.classList.add('wished');
          mainWish.textContent = '♥';
          mainWish.style.color = '#ec4f9a';
          mainWish.style.borderColor = '#ec4f9a';
        } else {
          mainWish.classList.remove('wished');
          mainWish.textContent = '♡';
          mainWish.style.color = '';
          mainWish.style.borderColor = '';
        }
      }

      renderJars(btn);
    });
  });

  /* ── BUCKET HERO — ASYNC ATC ── */
  var heroForm = document.querySelector('#neo-combined-' + sid + ' [data-nbp-form]');
  if (heroForm) {
    heroForm.addEventListener('submit', function (e) {
      e.preventDefault();
      var btn  = heroForm.querySelector('[type="submit"]');
      var orig = btn.innerHTML;
      btn.textContent = 'Adding…';
      btn.disabled    = true;
      fetch('/cart/add.js', { method: 'POST', body: new FormData(heroForm) })
        .then(function (r) {
          if (!r.ok) throw new Error('cart error');
          btn.innerHTML = '<span class="nbp-atc__check">✓</span> Added!';
          btn.style.background = '#2a7a4b';
          Toast.show('Added to cart', '🛒', '');
          fetch('/cart.js').then(function (r2) { return r2.json(); }).then(function (d) { CartBubble.update(d.item_count); });
          document.dispatchEvent(new CustomEvent('cart:refresh'));
          setTimeout(function () {
            btn.innerHTML        = orig;
            btn.style.background = '';
            btn.disabled         = false;
          }, 1800);
        })
        .catch(function () {
          HTMLFormElement.prototype.submit.call(heroForm);
        });
    });
  }

  /* ── BUCKET HERO — WISH BUTTON (plain heart toggle) ── */
  document.querySelectorAll('#neo-combined-' + sid + ' .nbp-wish').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var wished          = btn.dataset.wished === '1';
      btn.dataset.wished  = wished ? '0' : '1';
      btn.textContent     = wished ? '♡' : '♥';
      btn.style.color     = wished ? '' : '#ec4f9a';
      btn.style.borderColor = wished ? '' : '#ec4f9a';
    });
  });

  /* ── LIVE VIEWERS — BUCKET HERO ── */
  var BucketLive = {
    badge:   document.getElementById('nbpBucketLiveBadge'),
    countEl: document.getElementById('nbpBucketLiveCount'),
    wsUrl:   'wss://sundaze-live-viewers.mamunhossain-services.workers.dev',
    _fallbackTimer: null,
    init: function () {
      if (!this.badge) return;
      this.connectWebSocket();
    },
    connectWebSocket: function () {
      var self = this;
      try {
        var ws = new WebSocket(this.wsUrl);
        ws.onopen    = function () { self.badge.classList.add('nbp-live-visible'); clearInterval(self._fallbackTimer); };
        ws.onmessage = function (event) {
          try { var d = JSON.parse(event.data); if (d.type === 'count') self.updateCount(d.count); } catch (ex) {}
        };
        ws.onerror = function () { self.fallbackSimulation(); };
        ws.onclose = function () { self.fallbackSimulation(); };
      } catch (ex) { this.fallbackSimulation(); }
    },
    updateCount: function (count) {
      if (count > 0 && this.countEl) { this.countEl.textContent = count; this.badge.classList.add('nbp-live-visible'); }
    },
    fallbackSimulation: function () {
      if (this._fallbackTimer) return;
      var self = this;
      this.badge.classList.add('nbp-live-visible');
      var v = Math.floor(Math.random() * 24) + 14;
      this.updateCount(v);
      this._fallbackTimer = setInterval(function () {
        v = Math.max(8, v + Math.floor(Math.random() * 5) - 2);
        self.updateCount(v);
      }, 3500);
    }
  };

  /* ── LIVE VIEWERS — PRODUCT HERO ── */
  var ProdLive = {
    badge:   document.getElementById('neoProdLiveBadge'),
    countEl: document.getElementById('neoProdLiveCount'),
    wsUrl:   'wss://sundaze-live-viewers.mamunhossain-services.workers.dev',
    _fallbackTimer: null,
    init: function () {
      if (!this.badge) return;
      this.connectWebSocket();
    },
    connectWebSocket: function () {
      var self = this;
      try {
        var ws = new WebSocket(this.wsUrl);
        ws.onopen    = function () { self.badge.classList.add('visible'); clearInterval(self._fallbackTimer); };
        ws.onmessage = function (event) {
          try { var d = JSON.parse(event.data); if (d.type === 'count') self.updateCount(d.count); } catch (ex) {}
        };
        ws.onerror = function () { self.fallbackSimulation(); };
        ws.onclose = function () { self.fallbackSimulation(); };
      } catch (ex) { this.fallbackSimulation(); }
    },
    updateCount: function (count) {
      if (count > 0 && this.countEl) { this.countEl.textContent = count; this.badge.classList.add('visible'); }
    },
    fallbackSimulation: function () {
      if (this._fallbackTimer) return;
      var self = this;
      this.badge.classList.add('visible');
      var v = Math.floor(Math.random() * 24) + 14;
      this.updateCount(v);
      this._fallbackTimer = setInterval(function () {
        v = Math.max(8, v + Math.floor(Math.random() * 5) - 2);
        self.updateCount(v);
      }, 3500);
    }
  };

  /* ── SCROLL REVEAL ── */
  var observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) e.target.classList.add('visible');
    });
  }, { threshold: 0.08 });

  document.querySelectorAll(
    '#neo-combined-' + sid + ' .neo-card, ' +
    '#neo-combined-' + sid + ' .neo-section, ' +
    '#neo-combined-' + sid + ' .neo-animate, ' +
    '#neo-combined-' + sid + ' .neo-left, ' +
    '#neo-combined-' + sid + ' .neo-right'
  ).forEach(function (el) { observer.observe(el); });

  /* ── WISHLIST DRAWER EVENTS ── */
  var closeBtn = document.getElementById('neoDrawerClose');
  if (closeBtn) closeBtn.addEventListener('click', function () { NeoWish.closeDrawer(); });
  var overlayEl = document.getElementById('neoWishOverlay');
  if (overlayEl) overlayEl.addEventListener('click', function () { NeoWish.closeDrawer(); });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') NeoWish.closeDrawer(); });

  /* ── CART REFRESH LISTENER ── */
  document.addEventListener('cart:refresh', function () {
    /* intentionally empty — cart count updated directly after each ATC call */
  });

  /* ── INIT ── */
  document.querySelectorAll('.neo-add-btn').forEach(function (btn) {
    var textEl = btn.querySelector('.neo-btn-text');
    if (textEl) btn.dataset.originalText = textEl.textContent;
  });

  CartBubble.init();
  NeoWish.initButtons();
  if (WishBubble.el) WishBubble.update(NeoWish._load().length);
  BucketLive.init();
  ProdLive.init();

})();
</script>


