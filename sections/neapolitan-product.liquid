{% comment %}
  Combined Neapolitan Product Page
  ─ TOP:    Neapolitan Bucket hero card (flavor selector, jars, live viewers, feature card, bottom pills)
  ─ BELOW:  Original Neapolitan Product Page (single hash holes sections)
  ─ FONTS:  Playfair Display (headings) + DM Sans (body) — matches Hash Holes FAQ page
{% endcomment %}

<!-- ════════════════════════════════════════════════════════════
     SHARED STYLES (Playfair Display + DM Sans fonts + variant pill bar)
════════════════════════════════════════════════════════════ -->
<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600&display=swap');

  /* ── BUCKET HERO CARD ── */
  .nbp-shell {
    background: #fff;
    border-radius: 28px;
    max-width: 1400px;
    margin: 0 auto 32px;
    width: 100%;
    box-shadow: 0 20px 70px rgba(0,0,0,.09);
    overflow: hidden;
    font-family: 'DM Sans', sans-serif;
    color: #111;
  }

  .nbp-grid {
    display: grid;
    grid-template-columns: 1fr 620px 1fr;
    min-height: 700px;
  }

  /* LEFT */
  .nbp-left { padding: 44px 0 44px 44px; display: flex; flex-direction: column; }

  .nbp-title { margin: 0 0 18px; line-height:1; letter-spacing: -.03em; }
  .nbp-title__top {
    display: block;
    font-size: clamp(48px,4.4vw,68px);
    font-weight: 900;
    font-family: 'Playfair Display', serif;
    color: #111;
  }
  .nbp-title__gradient {
    display: block;
    font-size: clamp(48px,4.4vw,68px);
    font-weight: 900;
    font-family: 'Playfair Display', serif;
    font-style: italic;
    background: linear-gradient(90deg,#ec4f9a 0%,#f099bd 30%,#b57938 72%,#2a1b14 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .nbp-flavor-sub {
    font-size: 15px;
    font-weight: 500;
    font-family: 'DM Sans', sans-serif;
    color: #555;
    margin: 0 0 18px;
    letter-spacing: 0.04em;
  }
  .nbp-price {
    font-size: 36px;
    font-weight: 700;
    font-family: 'Playfair Display', serif;
    letter-spacing: -.03em;
    color: #111;
    margin-bottom: 16px;
  }
  .nbp-desc {
    font-size: 14px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    color: #444;
    line-height: 1.82;
    margin-bottom: 26px;
    max-width: 280px;
  }
  .nbp-choose-label {
    font-size: 11px;
    font-weight: 500;
    font-family: 'DM Sans', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(107,66,38,0.6);
    margin-bottom: 12px;
  }

  .nbp-options { display: flex; flex-wrap: wrap; gap: 9px; margin-bottom: 26px; }
  .nbp-opt {
    border: 1.5px solid #d8d8d8;
    background: #fff;
    color: #111;
    border-radius: 999px;
    padding: 11px 18px;
    font-size: 13px;
    font-weight: 500;
    font-family: 'DM Sans', sans-serif;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: border-color .15s, background .15s, color .15s, box-shadow .15s;
    line-height: 1.25;
    text-align: center;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    white-space: normal;
    max-width: 140px;
  }
  .nbp-opt:hover { border-color: #999; }
  .nbp-opt.active {
    background: #111;
    color: #fff;
    border-color: #111;
    box-shadow: 0 6px 18px rgba(0,0,0,.22);
  }

  .nbp-actions { display: flex; align-items: center; gap: 12px; margin-bottom: 28px; }
  .nbp-atc {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: #111;
    color: #fff;
    border: none;
    border-radius: 999px;
    padding: 17px 28px;
    font-size: 13px;
    font-weight: 500;
    font-family: 'DM Sans', sans-serif;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background .15s, transform .1s;
    white-space: nowrap;
  }
  .nbp-atc:hover { background: #333; transform: translateY(-1px); }
  .nbp-atc__check {
    width: 22px;
    height: 22px;
    background: rgba(255,255,255,.18);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 600;
    flex-shrink: 0;
  }
  .nbp-wish {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    border: 1.5px solid #e0e0e0;
    background: #fff;
    font-size: 22px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color .15s, color .15s;
    color: #888;
    flex-shrink: 0;
  }
  .nbp-wish:hover { border-color: #ec4f9a; color: #ec4f9a; }

  .nbp-mini-card {
    display: flex;
    align-items: center;
    gap: 14px;
    border: 1.5px solid #f5c8d8;
    border-radius: 20px;
    padding: 13px 15px;
    background: #fff8fa;
    max-width: 340px;
    margin-top: auto;
  }
  .nbp-mini-card__img { width: 70px; height: 70px; object-fit: cover; border-radius: 50%; flex-shrink: 0; }
  .nbp-mini-card__text { flex: 1; min-width: 0; }
  .nbp-mini-card__text strong {
    display: block;
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    color: #7c431b;
    font-size: 15px;
    letter-spacing: -.01em;
    line-height: 1.1;
  }
  .nbp-mini-card__text b {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    color: #cf4d8a;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 3px;
  }
  .nbp-mini-card__text small {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    color: #6b5a50;
    font-size: 11.5px;
    margin-top: 4px;
  }

  .nbp-dot-grid {
    background: radial-gradient(circle, #ead4a9 0%, #c69959 100%);
    border-radius: 50%;
    display: grid;
    grid-template-columns: repeat(4,1fr);
    flex-shrink: 0;
  }
  .nbp-dot-grid span { background: #ee9abe; border-radius: 50%; display: block; aspect-ratio: 1; }
  .nbp-dot-grid--sm { width: 66px; height: 66px; gap: 4px; padding: 9px; border: 5px solid #f4e3c4; }
  .nbp-dot-grid--lg { width: 80px; height: 80px; gap: 4px; padding: 10px; border: 5px solid #f4e3c4; }

  /* CENTER */
  .nbp-center { padding: 32px 28px; display: flex; flex-direction: column; }
  .nbp-hero-card {
    flex: 1;
    border-radius: 40px;
    padding: 30px 30px 24px;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    min-height: 580px;
    background:
      radial-gradient(circle at 10% 14%, rgba(255,213,166,.92), transparent 32%),
      radial-gradient(circle at 76% 16%, rgba(255,177,215,.88), transparent 36%),
      radial-gradient(circle at 52% 90%, rgba(255,237,179,.92), transparent 40%),
      linear-gradient(135deg, #ffe9c9 0%, #ffc7dc 48%, #fff0bf 100%);
  }

  .nbp-hero-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    position: relative;
    z-index: 3;
  }
  .nbp-selected-pill {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: rgba(255,255,255,.86);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 13px 20px;
    border-radius: 999px;
    box-shadow: 0 8px 24px rgba(0,0,0,.08);
    font-size: 13px;
    font-weight: 500;
    font-family: 'DM Sans', sans-serif;
    letter-spacing: 0.04em;
    color: #111;
    white-space: nowrap;
  }
  .nbp-selected-pill__check {
    width: 24px;
    height: 24px;
    background: #ddaa61;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    color: #fff;
    font-weight: 600;
    flex-shrink: 0;
  }

  .nbp-live-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.9);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 50px;
    padding: 8px 14px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    font-size: 12px;
    font-weight: 500;
    font-family: 'DM Sans', sans-serif;
    color: #1a1a1a;
    width: fit-content;
    margin-top: 12px;
    opacity: 0;
    transform: translateY(-8px);
    transition: opacity 0.4s ease, transform 0.4s ease;
    position: relative;
    z-index: 4;
  }
  .nbp-live-badge.nbp-live-visible { opacity: 1; transform: translateY(0); }
  .nbp-live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #10b981;
    flex-shrink: 0;
    box-shadow: 0 0 0 0 rgba(16,185,129,0.7);
    animation: nbp-pulse-dot 1.5s infinite ease-in-out;
  }
  @keyframes nbp-pulse-dot {
    0%   { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16,185,129,0.7); }
    70%  { transform: scale(1);    box-shadow: 0 0 0 6px rgba(16,185,129,0); }
    100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16,185,129,0); }
  }

  .nbp-jars {
    flex: 1;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    position: relative;
    z-index: 2;
    padding-top: 16px;
    padding-bottom: 8px;
    min-height: 320px;
  }
  .nbp-jar { height: auto; object-fit: contain; filter: drop-shadow(0 20px 18px rgba(81,45,22,.18)); transition: opacity .3s, transform .3s; }
  .nbp-jar--l { height: clamp(180px,22vw,280px); }
  .nbp-jar--c { z-index: 2; height: clamp(200px,24vw,300px); position: relative; transform: translateY(-16px); }
  .nbp-jar--r { height: clamp(180px,22vw,280px); }
  .nbp-jar--single { width: 100%; max-width: 100%; height: 100%; max-height: 320px; object-fit: contain; transform: translateY(-8px); }

  .nbp-feat-card {
    background: rgba(255,248,236,.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 20px;
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
    box-shadow: 0 8px 28px rgba(0,0,0,.07);
    border: 1px solid rgba(255,220,180,.5);
    max-width: 380px;
    margin: 14px auto;
    position: relative;
    z-index: 3;
  }
  .nbp-feat-card__img { width: 68px; height: 68px; object-fit: cover; border-radius: 50%; flex-shrink: 0; }
  .nbp-feat-card__text { flex: 1; min-width: 0; }
  .nbp-feat-card__text strong {
    display: block;
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    color: #7c431b;
    font-size: 15px;
    letter-spacing: -.01em;
    line-height: 1.1;
  }
  .nbp-feat-card__text b {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    color: #cf4d8a;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 3px;
  }
  .nbp-feat-card__text small {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    color: #6b5244;
    font-size: 11px;
    margin-top: 3px;
  }
  .nbp-feat-card__divider { width: 1px; height: 48px; background: rgba(160,100,50,.25); flex-shrink: 0; display: block !important; }
  .nbp-feat-card__bucket { display: flex !important; align-items: center; justify-content: center; flex-shrink: 0; color: #9d6638; }
  .nbp-feat-card__bucket-img { width: 54px; height: 54px; object-fit: contain; }
  .nbp-bucket-svg { width: 54px; height: 54px; }

  .nbp-bottom-pills {
    display: flex;
    gap: 14px;
    justify-content: center;
    margin-top: 18px;
    position: relative;
    z-index: 3;
    flex-wrap: nowrap;
  }
  .nbp-pill {
    background: rgba(255,255,255,.86);
    padding: 14px 24px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 500;
    font-family: 'DM Sans', sans-serif;
    letter-spacing: 0.08em;
    box-shadow: 0 12px 28px rgba(0,0,0,.07);
    color: #111;
    white-space: nowrap;
  }

  /* RIGHT */
  .nbp-right { padding: 48px 40px 48px 0; display: flex; flex-direction: column; justify-content: flex-start; }
  .nbp-acc { border-bottom: 1px solid #e8e8e8; }
  .nbp-acc__btn {
    width: 100%;
    border: none;
    background: transparent;
    padding: 22px 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 18px;
    font-weight: 700;
    font-family: 'Playfair Display', serif;
    cursor: pointer;
    color: #3f2417;
    letter-spacing: -.01em;
    text-align: left;
    transition: color .15s;
  }
  .nbp-acc__btn:hover { color: #6b4226; }
  .nbp-acc__icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    transition: transform 0.3s ease;
    color: #999;
  }
  .nbp-acc__icon--open { transform: rotate(180deg); }
  /* Smooth slide — replaces display:none/block */
  .nbp-acc__panel {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height 0.35s ease, opacity 0.3s ease;
    padding: 0;
  }
  .nbp-acc--open .nbp-acc__panel {
    max-height: 600px;
    opacity: 1;
    padding: 0 0 22px;
  }
  .nbp-acc__panel p {
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    font-size: 14px;
    line-height: 1.82;
    color: rgba(107,66,38,0.8);
  }
  .nbp-acc__panel ul { list-style: none; padding: 0; margin: 0; }
  .nbp-acc__panel li {
    position: relative;
    padding-left: 20px;
    margin-bottom: 12px;
    font-size: 14px;
    font-weight: 300;
    font-family: 'DM Sans', sans-serif;
    color: rgba(63,36,23,0.8);
    line-height: 1.6;
  }
  .nbp-acc__panel li::before {
    content: '';
    width: 6px;
    height: 6px;
    background: #d39a59;
    border-radius: 50%;
    position: absolute;
    left: 0;
    top: 7px;
  }
  .nbp-acc__highlight {
    font-family: 'DM Sans', sans-serif;
    color: #d94e8f;
    font-weight: 500;
    letter-spacing: 0.04em;
    margin-top: 16px;
    font-size: 13px;
  }

  /* RESPONSIVE */
  @media screen and (max-width: 1200px) {
    .nbp-grid { grid-template-columns: 300px 1fr 280px; }
    .nbp-left  { padding: 36px 28px 36px 32px; }
    .nbp-right { padding: 36px 28px; }
  }
  @media screen and (max-width: 960px) {
    .nbp-grid { grid-template-columns: 1fr; }
    .nbp-center { order: 1; }
    .nbp-left  { order: 2; border-bottom: 1px solid #f0ebe4; }
    .nbp-right { order: 3; border-top: 1px solid #f0ebe4; }
    .nbp-desc  { max-width: 100%; }
    .nbp-mini-card { max-width: 100%; }
  }
  @media screen and (max-width: 600px) {
    .nbp-jar--l, .nbp-jar--r { height: 130px; }
    .nbp-jar--c { height: 150px; transform: translateY(-12px); }
    .nbp-jar--single { max-height: 200px; max-width: 100%; width: 100%; }
    .nbp-hero-card { border-radius: 28px; padding: 20px 18px; min-height: auto; }
    .nbp-jars    { min-height: 200px; padding-top: 8px; }
    .nbp-bottom-pills { flex-wrap: wrap; gap: 10px; margin-top: 14px; }
    .nbp-pill { padding: 12px 16px; font-size: 11px; }
    .nbp-live-badge { font-size: 11px; padding: 7px 12px; }
  }
</style>


<!-- ════════════════════════════════════════════════════════════
     SECTION WRAPPER (wraps bucket hero + product page)
════════════════════════════════════════════════════════════ -->
<section id="neo-combined-{{ section.id }}">

  <!-- ════════════════════════════════
       PART 1 — BUCKET HERO CARD
  ════════════════════════════════ -->
  <div style="background: {{ section.settings.bg_color | default: '#f7ece2' }}; padding: 32px 16px 10px;">

    <div class="nbp-shell">
      <div class="nbp-grid">

        <!-- LEFT -->
        <div class="nbp-left">

          <h1 class="nbp-title">
            <span class="nbp-title__top">{{ section.settings.title_top | default: 'Neapolitan' }}</span>
            <span class="nbp-title__gradient">{{ section.settings.title_gradient | default: 'Bucket' }}</span>
          </h1>

          <p class="nbp-flavor-sub" id="nbp-sub-{{ section.id }}">
            {{ section.settings.flavor_line | default: 'Vanilla • Strawberry Shortcake • Nugtella' }}
          </p>

          <div class="nbp-price" id="nbp-price-{{ section.id }}">
            {% if section.settings.mixed_product != blank %}
              {{ section.settings.mixed_product.price | money }}
            {% else %}
              {{ section.settings.price_fallback | default: '$45.00' }}
            {% endif %}
          </div>

          <p class="nbp-desc" id="nbp-desc-{{ section.id }}">
            {{ section.settings.description }}
          </p>

          <p class="nbp-choose-label">Choose Your Bucket</p>

          <div class="nbp-options">

            {% if section.settings.nugtella_product != blank %}
              <button type="button" class="nbp-opt" data-nbp-opt
                data-variant="{{ section.settings.nugtella_product.selected_or_first_available_variant.id }}"
                data-price="{{ section.settings.nugtella_product.price | money }}"
                data-sub="Chocolate • Hazelnut • Indulgent"
                data-desc="{{ section.settings.nugtella_desc | default: section.settings.description | escape }}"
                data-label="Nugtella Selected"
                data-pill="🍫 Nugtella"
                data-pill2="⬡ Single Flavor"
                data-acc-desc="{{ section.settings.nugtella_acc_desc | escape }}"
                data-acc-flavor="{{ section.settings.nugtella_acc_flavor | escape }}"
                data-acc-specs="{{ section.settings.nugtella_acc_specs | escape }}"
                data-acc-highlight="{{ section.settings.nugtella_acc_highlight | escape }}"
                data-image="{{ section.settings.bucket_image_nugtella | image_url: width: 900 | default: section.settings.nugtella_product.featured_image | image_url: width: 900 }}"
                data-mode="single"
                data-hasholes-img="{{ section.settings.hasholes_image_nugtella | image_url: width: 160 }}"
                data-bucket-img="{{ section.settings.bucket_icon_nugtella | image_url: width: 140 }}">
                Nugtella
              </button>
            {% endif %}

            {% if section.settings.strawberry_product != blank %}
              <button type="button" class="nbp-opt" data-nbp-opt
                data-variant="{{ section.settings.strawberry_product.selected_or_first_available_variant.id }}"
                data-price="{{ section.settings.strawberry_product.price | money }}"
                data-sub="Sweet • Berry • Cake"
                data-desc="{{ section.settings.strawberry_desc | default: section.settings.description | escape }}"
                data-label="Strawberry Shortcake Selected"
                data-pill="🍓 Strawberry Shortcake"
                data-pill2="⬡ Single Flavor"
                data-acc-desc="{{ section.settings.strawberry_acc_desc | escape }}"
                data-acc-flavor="{{ section.settings.strawberry_acc_flavor | escape }}"
                data-acc-specs="{{ section.settings.strawberry_acc_specs | escape }}"
                data-acc-highlight="{{ section.settings.strawberry_acc_highlight | escape }}"
                data-image="{{ section.settings.bucket_image_strawberry | image_url: width: 900 | default: section.settings.strawberry_product.featured_image | image_url: width: 900 }}"
                data-mode="single"
                data-hasholes-img="{{ section.settings.hasholes_image_strawberry | image_url: width: 160 }}"
                data-bucket-img="{{ section.settings.bucket_icon_strawberry | image_url: width: 140 }}">
                Strawberry Shortcake
              </button>
            {% endif %}

            {% if section.settings.vanilla_product != blank %}
              <button type="button" class="nbp-opt" data-nbp-opt
                data-variant="{{ section.settings.vanilla_product.selected_or_first_available_variant.id }}"
                data-price="{{ section.settings.vanilla_product.price | money }}"
                data-sub="Creamy • Smooth • Classic"
                data-desc="{{ section.settings.vanilla_desc | default: section.settings.description | escape }}"
                data-label="Vanilla Selected"
                data-pill="🍦 Vanilla"
                data-pill2="⬡ Single Flavor"
                data-acc-desc="{{ section.settings.vanilla_acc_desc | escape }}"
                data-acc-flavor="{{ section.settings.vanilla_acc_flavor | escape }}"
                data-acc-specs="{{ section.settings.vanilla_acc_specs | escape }}"
                data-acc-highlight="{{ section.settings.vanilla_acc_highlight | escape }}"
                data-image="{{ section.settings.bucket_image_vanilla | image_url: width: 900 | default: section.settings.vanilla_product.featured_image | image_url: width: 900 }}"
                data-mode="single"
                data-hasholes-img="{{ section.settings.hasholes_image_vanilla | image_url: width: 160 }}"
                data-bucket-img="{{ section.settings.bucket_icon_vanilla | image_url: width: 140 }}">
                Vanilla
              </button>
            {% endif %}

            {% if section.settings.mixed_product != blank %}
              <button type="button" class="nbp-opt active" data-nbp-opt
                data-variant="{{ section.settings.mixed_product.selected_or_first_available_variant.id }}"
                data-price="{{ section.settings.mixed_product.price | money }}"
                data-sub="{{ section.settings.flavor_line | default: 'Vanilla • Strawberry Shortcake • Nugtella' }}"
                data-desc="{{ section.settings.description | escape }}"
                data-label="Mixed Bucket Selected"
                data-pill="🍨 Neapolitan Collection"
                data-pill2="⬡ 3 Flavor Bundle"
                data-acc-desc="{{ section.settings.mixed_acc_desc | escape }}"
                data-acc-flavor="{{ section.settings.mixed_acc_flavor | escape }}"
                data-acc-specs="{{ section.settings.mixed_acc_specs | escape }}"
