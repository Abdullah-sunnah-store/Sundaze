      height: 84px;
    }

    .cart-quantity-decrease,
    .cart-quantity-increase {
      width: 34px;
    }

    .cart-quantity-number {
      width: 30px;
      font-size: 13px;
    }
    .cart-product-content-top{
      display:block;
    }
  }

  /* Inline loader — sized to fit inside icon buttons */
  /* NOTE: display:block !important overrides Dawn base.css `div:empty { display:none }` */
  .loader {
    display: block !important;
    width: 20px;
    aspect-ratio: 1;
    border-radius: 50%;
    animation: l11 2s infinite;
    flex-shrink: 0;
  }

  /* Context overrides */
  .cart-delete-btn .loader {
    width: 18px;
