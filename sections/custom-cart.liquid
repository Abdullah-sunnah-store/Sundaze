<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.css"
/>

<script src="https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.js"></script>
{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600&display=swap');

  /* ─── Design Tokens ─── */
  :root {
    --sun-rose:   #c4607a;
    --sun-mauve:  #a84f6a;
    --sun-blush:  #e8a0b4;
    --sun-peach:  #d4926e;
    --sun-ink:    #1e1118;
    --sun-text:   rgba(30,17,24,0.80);
    --sun-muted:  rgba(30,17,24,0.44);
    --sun-line:   rgba(196,96,122,0.14);
    --sun-surface:#fdf7f8;
    --sun-white:  #ffffff;
    --brand-color: var(--sun-rose);
    --heading-text-color: var(--sun-ink);
    --paragraph-text-color: var(--sun-text);
    --radius-sm: 8px;
    --radius-md: 14px;
    --radius-lg: 24px;
    --radius-pill: 50px;
    --shadow-sm: 0 2px 12px rgba(196,96,122,0.10);
    --shadow-md: 0 6px 28px rgba(196,96,122,0.16);
    --shadow-lg: 0 12px 48px rgba(196,96,122,0.22);
    --transition: 0.22s ease;
  }

  /* ─── Global ─── */
  .cart-section *,
  .cart-section *::before,
  .cart-section *::after {
    box-sizing: border-box;
  }

  .cart-section {
    font-family: 'DM Sans', sans-serif;
    color: var(--sun-text);
    background: var(--sun-surface);
    min-height: 60vh;
    padding: 48px 20px 80px;
  }

  /* ─── Section heading ─── */
  .section-heading-wrapper {
    margin-bottom: 28px;
  }

  .section-heading {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 4vw, 46px);
    font-weight: 700;
    font-style: italic;
    color: var(--sun-ink);
    margin: 0;
    line-height: 1.15;
  }

  .section-heading strong {
    background: linear-gradient(135deg, var(--sun-peach) 0%, var(--sun-rose) 55%, var(--sun-mauve) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: 900;
  }

  /* ─── Cart wrapper (two-column grid) ─── */
  .cart-wrapper {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 40px;
    max-width: 1280px;
    margin: 0 auto;
    align-items: start;
  }

  .cart-wrapper.empty-cart-centered {
    grid-template-columns: 1fr;
    justify-items: center;
  }

  /* ─── Left column ─── */
  .cart-product-content-area {
    min-width: 0;
  }

  .cart-product-content-area.full-width {
    width: 100%;
    max-width: 680px;
    margin: 0 auto;
  }

  .cart-product-content-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  /* ─── "products:" sub-label ─── */
  .cart-product-wrapper-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--sun-rose);
    margin: 0 0 18px;
  }

  /* ─── Product list ─── */
  .cart-product-items {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .cart-product-item {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 20px;
    background: var(--sun-white);
    border: 1.5px solid var(--sun-line);
    border-radius: var(--radius-md);
    padding: 18px;
    transition: box-shadow var(--transition), border-color var(--transition);
  }

  .cart-product-item:hover {
    box-shadow: var(--shadow-sm);
    border-color: rgba(196,96,122,0.28);
  }

  /* ─── Product image ─── */
  .cart-product-img {
    width: 110px;
    height: 130px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--sun-surface);
    border: 1px solid var(--sun-line);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cart-product-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ─── Product content area ─── */
  .cart-product-content {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .cart-product-title {
    margin: 0;
    font-family: 'Playfair Display', serif;
    font-size: clamp(15px, 1.8vw, 18px);
    font-weight: 700;
    line-height: 1.3;
  }

  .cart-product-title a {
    color: var(--sun-ink);
    text-decoration: none;
    transition: color var(--transition);
  }

  .cart-product-title a:hover {
    color: var(--sun-rose);
  }

  .cart-product-varient p {
    margin: 0;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.06em;
    color: var(--sun-muted);
  }

  /* ─── Product bottom (price + controls) ─── */
  .cart-product-btm {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: auto;
    padding-top: 10px;
    border-top: 1px solid var(--sun-line);
  }

  .cart-product-price {
    margin: 0;
    font-size: 17px;
    font-weight: 600;
    color: var(--sun-rose);
  }

  .cart-product-price strong {
    font-weight: 600;
  }

  /* ─── Delete + quantity row ─── */
  .dlt-btn-with-cart-quantity {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .cart-delete-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: background var(--transition);
  }

  .cart-delete-btn:hover {
    background: rgba(196,96,122,0.10);
  }

  .cart-delete-btn svg path {
    fill: var(--sun-muted);
    transition: fill var(--transition);
  }

  .cart-delete-btn:hover svg path {
    fill: var(--sun-rose);
  }

  .cart-delete-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* ─── Quantity controls ─── */
  .cart-quantity-wrap {
    display: inline-flex;
    align-items: center;
    background: rgba(255,255,255,0.80);
    border: 1.5px solid rgba(196,96,122,0.26);
    border-radius: var(--radius-pill);
    overflow: hidden;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    box-shadow: var(--shadow-sm);
    height: 44px;
  }

  .cart-quantity-decrease,
  .cart-quantity-increase {
    width: 44px;
    height: 100%;
    background: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background var(--transition);
    flex-shrink: 0;
    padding: 0;
  }

  .cart-quantity-decrease:hover,
  .cart-quantity-increase:hover {
    background: rgba(196,96,122,0.10);
  }

  .cart-quantity-decrease:disabled,
  .cart-quantity-increase:disabled {
    cursor: not-allowed;
    opacity: 0.4;
  }

  .cart-quantity-decrease.disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .cart-quantity-number {
    width: 40px;
    text-align: center;
    border: none;
    background: transparent;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: var(--sun-ink);
    -moz-appearance: textfield;
    padding: 0;
  }

  .cart-quantity-number::-webkit-inner-spin-button,
  .cart-quantity-number::-webkit-outer-spin-button {
    -webkit-appearance: none;
  }

  /* ─── Spinners ─── */
  .spinner {
    width: 20px;
    height: 20px;
    border: 2.5px solid rgba(196,96,122,0.20);
    border-top-color: var(--sun-rose);
    border-radius: 50%;
    animation: sun-spin 0.8s linear infinite;
    display: block;
    margin: 0 auto;
  }

  .main-spinner {
    width: 50px;
    height: 50px;
    border: 4px solid rgba(196,96,122,0.15);
    border-top-color: var(--sun-rose);
    border-radius: 50%;
    animation: sun-spin 0.8s linear infinite;
    margin: 0 auto;
  }

  @keyframes sun-spin {
    to { transform: rotate(360deg); }
  }

  .cart-delete-btn .spinner { width: 18px; height: 18px; }
  .cart-quantity-wrap .spinner { width: 22px; height: 22px; }

  /* ─── Loading overlay ─── */
  .cart-loading-overlay {
    position: absolute;
    inset: 0;
    background: rgba(253,247,248,0.75);
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .cart-loading-content {
    text-align: center;
    background: var(--sun-white);
    padding: 32px 52px;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--sun-line);
  }

  .cart-loading-content p {
    margin-top: 16px;
    font-weight: 600;
    font-size: 14px;
    color: var(--sun-ink);
    letter-spacing: 0.04em;
  }

  /* ─── Order summary panel ─── */
  .cart-product-summary-content {
    position: sticky;
    top: 20px;
  }

  .cart-product-summary {
    background: var(--sun-white);
    border: 1.5px solid var(--sun-line);
    border-radius: var(--radius-md);
    padding: 28px 24px;
    box-shadow: var(--shadow-sm);
  }

  .cart-product-summary-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: var(--sun-rose);
    margin: 0 0 20px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--sun-line);
  }

  .cart-product-summary-items {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cart-product-summary-item {
    padding: 14px 0;
    border-bottom: 1px solid var(--sun-line);
  }

  .cart-product-summary-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  /* ─── Order list (item breakdown) ─── */
  .cart-product-summary-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .cart-product-summary-list li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8px;
    font-size: 13px;
    color: var(--sun-text);
  }

  .cart-product-summary-list.order-list li p:first-child {
    font-weight: 400;
    color: var(--sun-muted);
    flex: 1;
  }

  .cart-product-summary-list.order-list li p:last-child {
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    white-space: nowrap;
  }

  .cart-product-summary-list li .price {
    font-weight: 600;
    color: var(--sun-ink);
  }

  /* Total price row */
  .total-price-list li {
    font-size: 15px;
  }

  .total-price-list li p:first-child strong {
    color: var(--sun-ink);
  }

  .total-price-list li .price {
    color: var(--sun-rose);
    font-size: 18px;
  }

  /* ─── Discount field ─── */
  .cart-product-discount {
    display: flex;
    gap: 8px;
    margin-bottom: 14px;
  }

  .cart-product-discount-field {
    flex: 1;
    height: 44px;
    padding: 0 14px;
    border: 1.5px solid rgba(196,96,122,0.28);
    border-radius: var(--radius-pill);
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: var(--sun-ink);
    background: var(--sun-surface);
    outline: none;
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .cart-product-discount-field::placeholder {
    color: var(--sun-muted);
  }

  .cart-product-discount-field:focus {
    border-color: var(--sun-rose);
    box-shadow: 0 0 0 3px rgba(196,96,122,0.12);
  }

  /* ─── Buttons ─── */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border: none;
    border-radius: var(--radius-pill);
    cursor: pointer;
    text-decoration: none;
    padding: 13px 28px;
    transition: transform var(--transition), box-shadow var(--transition), opacity var(--transition);
    position: relative;
    overflow: hidden;
  }

  .primary-btn {
    background: linear-gradient(135deg, var(--sun-peach) 0%, var(--sun-rose) 55%, var(--sun-mauve) 100%);
    color: #fff;
    box-shadow: 0 4px 18px rgba(196,96,122,0.28);
  }

  .primary-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(196,96,122,0.38);
  }

  .primary-btn:active {
    transform: translateY(0);
    box-shadow: 0 2px 10px rgba(196,96,122,0.20);
  }

  .primary-btn:disabled {
    opacity: 0.55;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .secondary-btn {
    background: transparent;
    color: var(--sun-rose);
    border: 1.5px solid var(--sun-rose);
    box-shadow: none;
  }

  .secondary-btn:hover {
    background: var(--sun-rose);
    color: #fff;
    box-shadow: 0 4px 14px rgba(196,96,122,0.28);
    transform: translateY(-1px);
  }

  /* ─── Checkout button ─── */
  .cart-checkout-btn {
    margin-top: 20px;
  }

  .cart-checkout-btn .btn {
    width: 100%;
    justify-content: center;
    height: 52px;
    font-size: 13px;
    letter-spacing: 0.18em;
  }

  /* ─── Empty state ─── */
  .cart-empty-state-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 20px;
    text-align: center;
    margin: 20px 0;
  }

  .cart-empty-icon {
    font-size: 64px;
    color: var(--sun-blush);
    margin-bottom: 24px;
    line-height: 1;
  }

  .cart-empty-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(20px, 3vw, 28px);
    font-weight: 700;
    font-style: italic;
    color: var(--sun-ink);
    margin: 0 0 12px;
  }

  .cart-empty-text {
    font-size: 15px;
    font-weight: 300;
    color: var(--sun-muted);
    max-width: 460px;
    margin: 0 auto 30px;
    line-height: 1.7;
  }

  .cart-empty-btn .btn {
    min-width: 200px;
  }

  /* ─── Recommendations Section ─── */
  .cart-recommendations-section {
    max-width: 1280px;
    margin: 60px auto 0;
    padding: 0 20px;
  }

  .cart-recommendations-slider {
    padding: 20px 0 60px;
    position: relative;
  }

  /* ─── sdz-card (mirrors collection page exactly) ─── */
  .sdz-card {
    background: #fff;
    border-radius: 28px;
    overflow: hidden;
    box-shadow: 0 12px 32px rgba(0,0,0,0.06);
    border: 1px solid rgba(255,255,255,0.8);
    opacity: 1;
    transform: scale(1) translateY(0);
    transition: opacity 0.5s ease, transform 0.5s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    cursor: pointer;
    text-decoration: none;
    color: var(--sun-ink);
    position: relative;
    height: 100%;
  }

  .sdz-card:hover {
    box-shadow: 0 20px 52px rgba(0,0,0,0.13);
    transform: scale(1.025) translateY(-5px);
  }

  /* Image area */
  .sdz-card__img-wrap {
    position: relative;
    height: 240px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 28px 28px 0 0;
    background: linear-gradient(135deg, #fce4ec 0%, #f8bbd0 100%);
  }

  /* Dual-image stack */
  .sdz-img-stack {
    position: relative;
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    perspective: 1000px;
  }

  .sdz-img-front,
  .sdz-img-back {
    grid-area: 1 / 1;
    width: 78%;
    height: auto;
    max-height: 210px;
    object-fit: contain;
    filter: drop-shadow(0 14px 14px rgba(0,0,0,0.14));
    transition: transform 0.48s cubic-bezier(0.25, 0.8, 0.25, 1), opacity 0.38s ease;
    transform-origin: bottom center;
  }

  .sdz-img-front { z-index: 2; }
  .sdz-img-back  { z-index: 1; opacity: 0; }

  .sdz-card:hover .sdz-img-front {
    transform: rotate(-13deg) scale(0.93) translateX(-8px);
  }
  .sdz-card:hover .sdz-img-back {
    opacity: 1;
    transform: rotate(13deg) scale(0.93) translateX(8px);
  }

  .sdz-card--zoom-only:hover .sdz-img-front {
    transform: scale(1.08) !important;
  }
  .sdz-card--zoom-only:hover .sdz-img-back {
    opacity: 0 !important;
    transform: none !important;
  }

  /* Badge */
  .sdz-card__badge {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 10;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .sdz-badge {
    display: inline-block;
    padding: 5px 12px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(4px);
    color: var(--sun-mauve);
    box-shadow: 0 3px 8px rgba(0,0,0,0.1);
    font-family: 'DM Sans', sans-serif;
  }

  .sdz-badge--sale {
    background: linear-gradient(135deg, var(--sun-peach) 0%, var(--sun-rose) 55%, var(--sun-mauve) 100%);
    color: #fff;
  }

  /* Card content */
  .sdz-card__content {
    padding: 18px 20px 22px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .sdz-card__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(15px, 1.8vw, 19px);
    font-weight: 700;
    line-height: 1.25;
    color: var(--sun-ink);
    margin: 0;
    transition: color 0.25s;
  }

  .sdz-card:hover .sdz-card__title {
    color: var(--sun-rose);
  }

  .sdz-card__price-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .sdz-card__price {
    font-size: 16px;
    font-weight: 500;
    color: var(--sun-ink);
    font-family: 'DM Sans', sans-serif;
    letter-spacing: 0.02em;
  }

  .sdz-card__price--compare {
    font-size: 13px;
    font-weight: 300;
    color: var(--sun-muted);
    text-decoration: line-through;
    font-family: 'DM Sans', sans-serif;
  }

  /* Add-to-cart button (identical to collection page) */
  .sdz-add-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: linear-gradient(135deg, var(--sun-peach) 0%, var(--sun-rose) 55%, var(--sun-mauve) 100%);
    color: #fff;
    border: none;
    border-radius: 50px;
    padding: 12px 22px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    font-family: 'DM Sans', sans-serif;
    width: 100%;
    margin-top: auto;
    text-decoration: none;
    box-shadow: 0 4px 18px rgba(196,96,122,0.26);
  }

  .sdz-add-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(196,96,122,0.36);
  }
  .sdz-add-btn:active:not(:disabled) { transform: scale(0.97); }
  .sdz-add-btn:disabled { opacity: 0.65; cursor: not-allowed; }

  .sdz-add-btn .sdz-spinner {
    display: none;
    width: 14px; height: 14px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: sdz-spin 0.7s linear infinite;
  }
  .sdz-add-btn.loading .sdz-spinner  { display: block; }
  .sdz-add-btn.loading .sdz-btn-icon,
  .sdz-add-btn.loading .sdz-btn-text { display: none; }

  @keyframes sdz-spin { to { transform: rotate(360deg); } }

  /* Swiper nav arrows */
  .cart-rec-slider-outer {
    position: relative;
    padding: 0 44px;
  }

  .cart-rec-nav-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--sun-white);
    border: 1.5px solid var(--sun-line);
    color: var(--sun-rose);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: var(--shadow-sm);
    transition: background var(--transition), box-shadow var(--transition), transform var(--transition);
    padding: 0;
  }

  .cart-rec-nav-btn:hover {
    background: var(--sun-rose);
    color: #fff;
    box-shadow: var(--shadow-md);
    transform: translateY(-50%) scale(1.08);
  }

  .cart-rec-nav-btn.swiper-button-disabled {
    opacity: 0.35;
    pointer-events: none;
  }

  .cart-rec-button-prev {
    left: 0;
  }

