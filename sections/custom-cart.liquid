      margin-bottom: 16px;
    }

    .cart-empty-btn .btn {
      width: 100%;
    }

    /* Recommendations section */
    .cart-recommendations-section {
      padding: 0 0px;
      margin-top: 40px;
    }

    .cart-recommendations-section .section-heading {
      font-size: clamp(20px, 6vw, 26px);
    }

    .sdz-card__content {
      padding: 14px 14px 16px;
    }

    .sdz-card__title {
      font-size: 14px;
    }

    .sdz-card__price {
      font-size: 14px;
    }

    .sdz-add-btn {
      padding: 10px 14px;
      font-size: 11px;
    }

    .sdz-card__img-wrap {
      height: 190px;
    }
    .cart-product-content-top {
    display: block;
}
  }

  /* Very small phones */
  @media screen and (max-width: 380px) {
    .cart-product-item {
      grid-template-columns: 70px 1fr;
