            Dubai
            <span class="sdz-hero-title-accent" style="background:linear-gradient(90deg,#2e7d32 0%,#66bb6a 100%);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;">Drip</span>
          </h2>
          <p class="sdz-hero-tagline" style="color:#2e7d32;">Rich · Smooth · Luxurious</p>
          <p class="sdz-hero-price" style="color:#2e7d32;">{{ section.settings.p4_price }}</p>
          <p class="sdz-hero-desc">A bold hybrid THCA flower with a rich, smooth profile and a refined finish. Leans sweet and creamy with subtle notes of chocolate and a smooth dessert-style finish, giving it a premium feel. Ideal for kicking back and enjoying a slow, flavorful session.</p>
          <p class="sdz-hero-compliance">Contains less than 0.3% Delta-9 THC.<br>Federally legal under the 2018 Farm Bill.<br>For use by persons 21+ only.</p>
          <div class="sdz-hero-actions">
            <button class="sdz-add-btn" style="background:#1b5e20;" data-variant-id="{{ section.settings.p4_variant_id }}" data-product-name="Dubai Drip" onclick="SdzCart.add(this)">
              <div class="sdz-btn-spinner"></div>
              <svg class="sdz-btn-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              <span class="sdz-btn-text">Add to cart</span>
            </button>
            <button class="sdz-wish-btn" aria-label="Add to wishlist" data-variant-id="{{ section.settings.p4_variant_id }}" data-product-name="Dubai Drip" data-product-price="{{ section.settings.p4_price }}" data-product-image="{{ section.settings.p4_image | img_url: '200x' }}" data-product-emoji="🍫" onclick="SdzWish.toggle(this)">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            </button>
          </div>
          <button class="sdz-view-wishlist" onclick="SdzWish.openDrawer()">♡ View wishlist</button>
        </div>

        <div class="sdz-hero-center">
          <div class="sdz-center-inner" style="background:linear-gradient(180deg,#f1f8e9 0%,#a5d6a7 50%,#43a047 100%);">
            <div class="sdz-center-arch" style="background:rgba(255,255,255,0.15);"></div>
            <div class="sdz-badge-brand">
              <div class="sdz-badge-brand-avatar" style="background:linear-gradient(135deg,#81c784,#1b5e20);">S</div>
              <div class="sdz-badge-brand-text">
                <span class="sdz-badge-brand-name">Sundaze</span>
                <span class="sdz-badge-brand-sub">Premium THCA Hemp</span>
              </div>
            </div>
            {% if section.settings.p4_image != blank %}
              <img class="sdz-product-img" src="{{ section.settings.p4_image | img_url: '800x' }}" alt="Dubai Drip" draggable="false" style="filter:drop-shadow(0 24px 36px rgba(27,94,32,0.30));">
            {% endif %}
            <div class="sdz-badge-thca">
              <div class="sdz-badge-thca-icon" style="background:linear-gradient(135deg,#f1f8e9,#a5d6a7);">🍫</div>
              <div>
                <span class="sdz-badge-thca-pct">Hybrid THCA</span>
                <span class="sdz-badge-thca-sub">Rich · Bold · Refined</span>
              </div>
            </div>
            <div class="sdz-badge-terp">
              <div class="sdz-badge-terp-icon" style="background:linear-gradient(135deg,#f1f8e9,#a5d6a7);">✨</div>
              <div>
                <span class="sdz-badge-terp-title">Luxury Dessert Profile</span>
                <span class="sdz-badge-terp-sub">Chocolate, Cream, Sweet</span>
              </div>
            </div>
            <div class="sdz-scroll-ind">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
            </div>
          </div>
        </div>

        <div class="sdz-hero-right sdz-animate">
          <div class="sdz-acc-item" style="border-color:#c8e6c9;"><button class="sdz-acc-btn" onclick="sdzToggleAcc(this)">Description<svg class="sdz-acc-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg></button><div class="sdz-acc-body"><div class="sdz-acc-content">A bold, premium THCA flower with rich chocolate-cream notes and a slow, refined burn. The luxury pick of the Sundaze lineup.</div></div></div>
          <div class="sdz-acc-item" style="border-color:#c8e6c9;"><button class="sdz-acc-btn" onclick="sdzToggleAcc(this)">Flavor Notes<svg class="sdz-acc-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg></button><div class="sdz-acc-body"><div class="sdz-acc-content">Subtle chocolate and sweet cream with a dessert-style finish. Smooth, slow, and flavorful from start to finish.</div></div></div>
          <div class="sdz-acc-item" style="border-color:#c8e6c9;"><button class="sdz-acc-btn open" onclick="sdzToggleAcc(this)">Product Specs<svg class="sdz-acc-chev open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg></button>
            <div class="sdz-acc-body open"><div class="sdz-acc-content">
              <div class="sdz-spec-row"><span class="sdz-spec-icon">⚖️</span><span class="sdz-spec-label">Net Weight:</span><span class="sdz-spec-val">3.5 Grams</span></div>
              <div class="sdz-spec-row"><span class="sdz-spec-icon">🌿</span><span class="sdz-spec-label">Strain:</span><span class="sdz-spec-val">Hybrid</span></div>
              <div class="sdz-spec-row"><span class="sdz-spec-icon">🍫</span><span class="sdz-spec-label">Profile:</span><span class="sdz-spec-val">Rich Chocolate</span></div>
              <div class="sdz-spec-row"><span class="sdz-spec-icon">✅</span><span class="sdz-spec-label">Delta-9:</span><span class="sdz-spec-val">&lt; 0.3% THC</span></div>
              <div class="sdz-spec-row"><span class="sdz-spec-icon">🏠</span><span class="sdz-spec-label">Cultivation:</span><span class="sdz-spec-val">Indoor Grown</span></div>
              <div class="sdz-spec-row"><span class="sdz-spec-icon">🛡️</span><span class="sdz-spec-label">Lab Tested:</span><span class="sdz-spec-val">Third-Party Verified</span></div>
            </div></div>
          </div>
          <div class="sdz-acc-item" style="border-color:#c8e6c9;"><button class="sdz-acc-btn" onclick="sdzToggleAcc(this)">Collection<svg class="sdz-acc-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg></button><div class="sdz-acc-body"><div class="sdz-acc-content">Part of the Sundaze 3.5G Premium collection.</div></div></div>
        </div>
      </div>
    </div>

    <p class="sdz-compliance">21+ only. Follow all local laws and regulations. Contains less than 0.3% Delta-9 THC.</p>

  </div>
</div>
</div>

<script>
(function() {
  /* ── TOAST ── */
  const Toast = {
    _t: null,
    show(msg, icon, type) {
      const el = document.getElementById('sdzToast');
      const txt = document.getElementById('sdzToastMsg');
      const ico = document.getElementById('sdzToastIcon');
      if (!el || !txt || !ico) return;
      txt.textContent = msg;
      ico.textContent = icon || '';
      el.className = 'sdz-toast' + (type ? ' t-' + type : '');
      el.classList.add('show');
      clearTimeout(this._t);
      this._t = setTimeout(() => el.classList.remove('show'), 3000);
    }
  };

  /* ── CART BUBBLE ── */
  const CartBubble = {
    el: document.getElementById('sdzCartBubble'),
    ct: document.getElementById('sdzCartCount'),
    init() { 
      if(!this.el) return; 
      fetch('/cart.js').then(r=>r.json()).then(d=>this.update(d.item_count)).catch(()=>{}); 
    },
    update(n) { 
      /* update theme header cart count if it exists */
      fetch('/?section_id=cart-icon-bubble&t=' + Date.now())
        .then(r => r.text())
        .then(html => {
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
          const newContent = doc.getElementById('cart-icon-bubble') || doc.querySelector('.shopify-section') || doc.body;
          const oldBubble = document.getElementById('cart-icon-bubble');
          if (newContent && oldBubble) {
            const newInner = newContent.innerHTML;
            if (newInner) oldBubble.innerHTML = newInner;
          }
        })
        .catch(() => {});

      document.querySelectorAll('.cart-count-bubble span[aria-hidden="true"]').forEach(el => el.textContent = n);

      if(!this.ct || !this.el) return; 
      this.ct.textContent = n; 
      if (n > 0) this.el.classList.add('show'); 
    }
  };

  /* ── WISH BUBBLE ── */
  const WishBubble = {
    el: document.getElementById('sdzWishBubble'),
    ct: document.getElementById('sdzWishCount'),
    update(n) {
      /* Update any wishlist count elements found on the page (global sync) */
      document.querySelectorAll('#sdzWishCount, #sfWishBubbleCount, #nbpWishCount, .wishlist-count').forEach(el => {
        el.textContent = n;
      });
      if(!this.el || !this.ct) return;
      this.ct.textContent = n;
      this.ct.classList.remove('bump');
      void this.ct.offsetWidth;
      this.ct.classList.add('bump');
      setTimeout(() => { if(this.ct) this.ct.classList.remove('bump'); }, 300);
    }
  };

  /* ── CART ── */
  const SdzCart = {
    add(btn) {
      const vid = btn.dataset.variantId;
      const name = btn.dataset.productName || 'Product';
      if (!vid || vid === '' || vid.includes('section.settings')) {
        Toast.show('Variant not configured yet', '⚠️', 'error'); return;
      }
      btn.disabled = true; btn.classList.add('loading');
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: parseInt(vid, 10), quantity: 1 })
      })
      .then(res => { if (!res.ok) return res.json().then(e => { throw new Error(e.description || 'Error'); }); return res.json(); })
      .then(() => {
        btn.classList.remove('loading'); btn.classList.add('added');
        btn.querySelector('.sdz-btn-text').textContent = 'Added!';
        Toast.show(name + ' added to cart', '🛒', 'success');
        fetch('/cart.js').then(r=>r.json()).then(d=>CartBubble.update(d.item_count));
        document.dispatchEvent(new CustomEvent('cart:refresh'));
        setTimeout(() => {
          btn.disabled = false; btn.classList.remove('added');
          btn.querySelector('.sdz-btn-text').textContent = 'Add to cart';
        }, 2500);
      })
      .catch(err => { btn.disabled = false; btn.classList.remove('loading'); Toast.show(err.message || 'Could not add to cart', '❌', 'error'); });
    }
  };
  window.SdzCart = SdzCart;

  /* ── WISHLIST ── */
  const WISH_KEY = 'sundaze_wishlist_v1';
  const SdzWish = {
    _load() { try { return JSON.parse(localStorage.getItem(WISH_KEY) || '[]'); } catch { return []; } },
    _save(l) { localStorage.setItem(WISH_KEY, JSON.stringify(l)); },
    _has(id) { 
      if (!id) return false;
      return this._load().some(i => String(i.id) === String(id)); 
    },
    toggle(btn) {
      const id = btn.dataset.variantId;
      const name = btn.dataset.productName || 'Product';
      if (!id || id === '' || id.includes('section.settings')) { Toast.show('Variant not configured yet', '⚠️', 'error'); return; }
      const list = this._load(); const idx = list.findIndex(i => String(i.id) === String(id));
      if (idx === -1) {
        list.push({ id, name, price: btn.dataset.productPrice || '', img: btn.dataset.productImage || '', emoji: btn.dataset.productEmoji || '🍬' });
        this._save(list); this._setWished(btn, true); Toast.show(name + ' wishlisted', '💗', 'wish');
      } else {
        list.splice(idx, 1); this._save(list); this._setWished(btn, false); Toast.show('Removed from wishlist', '🤍', '');
      }
      WishBubble.update(this._load().length); this._renderDrawer();
    },
    _setWished(btn, w) {
      btn.classList.toggle('wished', w);
      btn.classList.add('pop');
      setTimeout(() => btn.classList.remove('pop'), 250);
    },
    initButtons() {
      document.querySelectorAll('.sdz-wish-btn').forEach(btn => {
        const id = btn.dataset.variantId;
        if (id && this._has(id)) btn.classList.add('wished');
      });
    },
    openDrawer() {
      this._renderDrawer();
      const overlay = document.getElementById('sdzOverlay');
      const drawer = document.getElementById('sdzDrawer');
      if (!overlay || !drawer) return;
      overlay.classList.add('open');
      drawer.classList.add('open');
      document.body.style.overflow = 'hidden';
    },
    closeDrawer() {
      const overlay = document.getElementById('sdzOverlay');
      const drawer = document.getElementById('sdzDrawer');
      if (!overlay || !drawer) return;
      overlay.classList.remove('open');
      drawer.classList.remove('open');
      document.body.style.overflow = '';
    },
    _renderDrawer() {
      const list = this._load();
      const c = document.getElementById('sdzWishList');
      if (!c) return;
      if (!list.length) {
        c.innerHTML = '<div class="sdz-drawer-empty"><div class="sdz-drawer-empty-icon">🤍</div><p>Your wishlist is empty</p><p style="font-size:12px;opacity:.6;margin-top:4px">Tap the heart on any product to save it here</p></div>';
        return;
      }
      c.innerHTML = list.map(item => `
        <div class="sdz-wish-item" data-wish-id="${item.id}">
          ${item.img && !item.img.includes('section.settings')
            ? `<img class="sdz-wish-item-img" src="${item.img}" alt="${item.name}">`
            : `<div class="sdz-wish-item-placeholder">${item.emoji}</div>`}
          <div class="sdz-wish-item-info">
            <p class="sdz-wish-item-name">${item.name}</p>
            <p class="sdz-wish-item-price">${item.price}</p>
            <div class="sdz-wish-item-actions">
              <button class="sdz-wadd-btn" onclick="SdzWish._addFromDrawer('${item.id}','${item.name}',this)">Add to cart</button>
              <button class="sdz-wrem-btn" onclick="SdzWish._removeFromDrawer('${item.id}')">Remove</button>
            </div>
          </div>
        </div>`).join('');
    },
    _addFromDrawer(id, name, btn) {
      btn.textContent = 'Adding…'; btn.disabled = true;
      fetch('/cart/add.js', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({id:parseInt(id,10),quantity:1}) })
      .then(res => { if (!res.ok) throw new Error(); return res.json(); })
      .then(() => {
        btn.textContent = '✓ Added!';
        Toast.show(name + ' added to cart', '🛒', 'success');
        fetch('/cart.js').then(r=>r.json()).then(d=>CartBubble.update(d.item_count));
        document.dispatchEvent(new CustomEvent('cart:refresh'));
        setTimeout(() => { btn.textContent = 'Add to cart'; btn.disabled = false; }, 2000);
      })
      .catch(() => { btn.textContent = 'Error'; btn.disabled = false; });
    },
    _removeFromDrawer(id) {
      const list = this._load().filter(i => String(i.id) !== String(id));
      this._save(list);
      document.querySelectorAll(`.sdz-wish-btn[data-variant-id="${id}"]`).forEach(b => b.classList.remove('wished'));
      WishBubble.update(list.length);
      this._renderDrawer();
    }
  };
  window.SdzWish = SdzWish;

  document.addEventListener('click', function (e) {
    const wishBtn = e.target.closest('.sdz-wish-btn');
    if (wishBtn) {
      e.preventDefault();
      e.stopPropagation();
      SdzWish.toggle(wishBtn);
      return;
    }
  }, true);

  /* ── LIVE VIEWERS ── */
  const LiveViewers = {
    badge: document.getElementById('sdzLiveBadge'),
    countEl: document.getElementById('sdzLiveCount'),
    wsUrl: 'wss://sundaze-live-viewers.mamunhossain-services.workers.dev',
    _fallbackTimer: null,
    init() {
      if (!this.badge) return;
      this.connectWebSocket();
    },
    connectWebSocket() {
      const self = this;
      try {
        const ws = new WebSocket(this.wsUrl);
        ws.onopen = function() { self.badge.classList.add('sdz-live-visible'); clearInterval(self._fallbackTimer); };
        ws.onmessage = function(event) {
          try { const d = JSON.parse(event.data); if (d.type === 'count') self.updateCount(d.count); } catch(ex) {}
        };
        ws.onerror = function() { self.fallbackSimulation(); };
        ws.onclose = function() { self.fallbackSimulation(); };
      } catch(ex) { this.fallbackSimulation(); }
    },
    updateCount(count) {
      if (count > 0 && this.countEl) { 
        this.countEl.textContent = count; 
        this.badge.classList.add('sdz-live-visible'); 
      }
    },
    fallbackSimulation() {
      if (this._fallbackTimer) return;
      const self = this;
      this.badge.classList.add('sdz-live-visible');
      let v = Math.floor(Math.random() * 24) + 14;
      this.updateCount(v);
      this._fallbackTimer = setInterval(function() {
        v = Math.max(8, v + Math.floor(Math.random() * 5) - 2);
        self.updateCount(v);
      }, 3500);
    }
  };

  /* ── ACCORDION ── */
  function sdzToggleAcc(btn) {
    const body = btn.nextElementSibling;
    const chev = btn.querySelector('.sdz-acc-chev');
    const isOpen = btn.classList.contains('open');
    btn.classList.toggle('open', !isOpen);
    body.classList.toggle('open', !isOpen);
    chev.classList.toggle('open', !isOpen);
  }
  window.sdzToggleAcc = sdzToggleAcc;

  /* ── INTERSECTION OBSERVER ── */
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.06 });
  document.querySelectorAll('.sdz-hero-card, .sdz-section, .sdz-animate').forEach(el => obs.observe(el));

  /* ── DRAWER CLOSE ── */
  const closeBtn = document.getElementById('sdzDrawerClose');
  if (closeBtn) closeBtn.addEventListener('click', () => SdzWish.closeDrawer());
  const overlayEl = document.getElementById('sdzOverlay');
  if (overlayEl) overlayEl.addEventListener('click', () => SdzWish.closeDrawer());
  document.addEventListener('keydown', e => { if (e.key === 'Escape') SdzWish.closeDrawer(); });

  /* ── INIT ── */
  CartBubble.init();
  SdzWish.initButtons();
  if(WishBubble.el) WishBubble.update(SdzWish._load().length);
  LiveViewers.init();
})();
</script>

