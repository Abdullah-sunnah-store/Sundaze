    { "type": "text",         "id": "p2_variant_id", "label": "Shopify Variant ID" },
    { "type": "header", "content": "Product 3 — Frosty Shorty" },
    { "type": "image_picker", "id": "p3_image",      "label": "Product Image" },
    { "type": "text",         "id": "p3_price",      "label": "Price",              "default": "$45.00" },
    { "type": "text",         "id": "p3_variant_id", "label": "Shopify Variant ID" },
    { "type": "header", "content": "Product 4 — Dubai Drip" },
    { "type": "image_picker", "id": "p4_image",      "label": "Product Image" },
    { "type": "text",         "id": "p4_price",      "label": "Price",              "default": "$45.00" },
