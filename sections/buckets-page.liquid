              <div class="sdz-spec-row"><span class="sdz-spec-icon">🏠</span><span class="sdz-spec-label">Cultivation:</span><span class="sdz-spec-val">Indoor Grown</span></div>
              <div class="sdz-spec-row"><span class="sdz-spec-icon">🛡️</span><span class="sdz-spec-label">Lab Tested:</span><span class="sdz-spec-val">Third-Party Verified</span></div>
            </div></div>
          </div>
          <div class="sdz-acc-item" style="border-color:#ffcdd2;"><button class="sdz-acc-btn" onclick="sdzToggleAcc(this)">Collection<svg class="sdz-acc-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg></button><div class="sdz-acc-body"><div class="sdz-acc-content">Part of the Sundaze 3.5G Premium collection.</div></div></div>
