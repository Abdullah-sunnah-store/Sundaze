<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500&display=swap');

/* ── RESET & BASE ── */
.sdz-wrap * { box-sizing: border-box; margin: 0; padding: 0; }

.sdz-page {
  min-height: 100vh;
  width: 100%;
  background: linear-gradient(135deg, #faf8f5 0%, #f6f3ef 60%, #fef2f7 100%);
  font-family: 'DM Sans', sans-serif;
  position: relative;
  overflow-x: hidden;
}

.sdz-glow {
  pointer-events: none;
  position: fixed;
  right: 0; top: 0;
  height: 600px; width: 600px;
  opacity: 0.3;
  background: radial-gradient(circle at 80% 20%, #fce4ec 0%, #fff9c4 30%, #e0f7fa 60%, transparent 80%);
  z-index: 0;
}

.sdz-container {
  position: relative;
  max-width: 1360px;
  margin: 0 auto;
  padding: 24px 16px;
  z-index: 1;
}
@media (min-width: 640px) { .sdz-container { padding: 36px 28px; } }

/* ── TOAST ── */
.sdz-toast {
  position: fixed; bottom: 32px; left: 50%;
  transform: translateX(-50%) translateY(80px);
  z-index: 9999; display: flex; align-items: center; gap: 10px;
  background: #1a1a1a; color: #fff; border-radius: 50px;
  padding: 12px 20px; font-size: 13px; font-weight: 500;
  box-shadow: 0 8px 32px rgba(0,0,0,0.25);
  transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1), opacity 0.4s ease;
  opacity: 0; white-space: nowrap; pointer-events: none;
  font-family: 'DM Sans', sans-serif;
}
.sdz-toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }
.sdz-toast.t-error { background: #c0392b; }
.sdz-toast.t-wish  { background: linear-gradient(135deg, #e8a0bf, #c77dff); }

/* ── CART BUBBLE ── */
.sdz-cart-bubble {
  position: fixed; top: 24px; right: 24px; z-index: 9998;
  display: flex; align-items: center; gap: 8px;
  background: #fff; border-radius: 50px; padding: 10px 16px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.12); font-size: 13px; font-weight: 500;
  color: #1a1a1a; cursor: pointer; opacity: 0; transform: translateY(-16px);
  transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
  border: 1px solid #e8e0d8; text-decoration: none; font-family: 'DM Sans', sans-serif;
}
.sdz-cart-bubble.show { opacity: 1; transform: translateY(0); }
.sdz-cart-bubble:hover { background: #1a1a1a; color: #fff; border-color: #1a1a1a; }
.sdz-cart-count {
  display: inline-flex; align-items: center; justify-content: center;
  width: 20px; height: 20px; border-radius: 50%;
  background: #1a1a1a; color: #fff; font-size: 10px; font-weight: 500;
  transition: background 0.2s;
}
.sdz-cart-bubble:hover .sdz-cart-count { background: #e8a0bf; color: #1a1a1a; }

/* ── WISHLIST BUBBLE ── */
.sdz-wish-bubble {
  position: fixed; top: 72px; right: 24px; z-index: 9997;
  display: flex; align-items: center; gap: 8px; background: #fff;
  border-radius: 50px; padding: 10px 16px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.12); font-size: 13px; font-weight: 500;
  color: #1a1a1a; cursor: pointer; border: 1px solid #f0d6e8;
  transition: background 0.2s, border-color 0.2s; font-family: 'DM Sans', sans-serif;
}
.sdz-wish-bubble:hover { background: #fef0f5; border-color: #e8a0bf; }
.sdz-wish-count {
  display: inline-flex; align-items: center; justify-content: center;
  min-width: 20px; height: 20px; border-radius: 50px;
  background: linear-gradient(135deg, #e8a0bf, #c77dff); color: #fff;
  font-size: 10px; font-weight: 500; padding: 0 5px;
  transition: transform 0.2s cubic-bezier(0.34,1.56,0.64,1);
}
.sdz-wish-count.bump { transform: scale(1.4); }

/* ── WISHLIST DRAWER ── */
.sdz-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.35); z-index: 10000;
  opacity: 0; pointer-events: none; transition: opacity 0.35s ease; backdrop-filter: blur(4px);
}
.sdz-overlay.open { opacity: 1; pointer-events: all; }
.sdz-drawer {
  position: fixed; top: 0; right: 0; height: 100%; width: min(400px, 100vw);
  background: #fff; z-index: 10001; padding: 32px 24px;
  box-shadow: -8px 0 40px rgba(0,0,0,0.12);
  transform: translateX(100%); transition: transform 0.4s cubic-bezier(0.25,0.46,0.45,0.94);
  overflow-y: auto; display: flex; flex-direction: column; font-family: 'DM Sans', sans-serif;
}
.sdz-drawer.open { transform: translateX(0); }
.sdz-drawer-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
.sdz-drawer-title {
  font-family: 'Playfair Display', serif;
  font-size: 20px; font-weight: 700; color: #1a0a2e; letter-spacing: -0.01em;
}
.sdz-drawer-close {
  display: flex; align-items: center; justify-content: center;
  width: 36px; height: 36px; border-radius: 50%; border: 1px solid #e8e0d8;
  background: transparent; cursor: pointer; font-size: 18px; color: #999;
  transition: border-color 0.2s, color 0.2s;
}
.sdz-drawer-close:hover { border-color: #c0392b; color: #c0392b; }
.sdz-drawer-empty {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  justify-content: center; gap: 12px; color: rgba(107,66,38,0.4); font-size: 14px; text-align: center;
  font-weight: 300;
}
.sdz-drawer-empty-icon { font-size: 48px; }
.sdz-wish-item { display: flex; align-items: center; gap: 14px; padding: 16px 0; border-bottom: 1px solid #f0ebe4; }
.sdz-wish-item-img { width: 64px; height: 64px; border-radius: 12px; object-fit: cover; background: #f5f2ee; flex-shrink: 0; }
.sdz-wish-item-placeholder {
  width: 64px; height: 64px; border-radius: 12px;
  background: linear-gradient(135deg, #fce4ec, #f5e6d3);
  flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 24px;
}
.sdz-wish-item-info { flex: 1; }
.sdz-wish-item-name { font-size: 13px; font-weight: 500; color: #1a1a1a; margin: 0 0 2px; font-family: 'DM Sans', sans-serif; }
.sdz-wish-item-price { font-size: 12px; color: rgba(107,66,38,0.6); margin: 0 0 8px; font-weight: 300; }
.sdz-wish-item-actions { display: flex; gap: 8px; }
.sdz-wadd-btn {
  font-size: 11px; font-weight: 500; padding: 6px 14px; border-radius: 50px;
  border: none; background: #1a1a1a; color: #fff; cursor: pointer;
  transition: background 0.2s; font-family: 'DM Sans', sans-serif;
}
.sdz-wadd-btn:hover { background: #333; }
.sdz-wrem-btn {
  font-size: 11px; font-weight: 400; padding: 6px 10px; border-radius: 50px;
  border: 1px solid #e8e0d8; background: transparent; color: rgba(107,66,38,0.6);
  cursor: pointer; transition: border-color 0.2s, color 0.2s; font-family: 'DM Sans', sans-serif;
}
.sdz-wrem-btn:hover { border-color: #c0392b; color: #c0392b; }

/* ══════════════════════════════════
   HERO CARD
══════════════════════════════════ */
.sdz-hero-card {
  background: #fff;
  border-radius: 24px;
  border: 1px solid #ede5ed;
  overflow: hidden;
  box-shadow: 0 4px 6px rgba(0,0,0,0.02), 0 20px 60px rgba(0,0,0,0.06);
  opacity: 0; transform: translateY(16px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}
.sdz-hero-card.visible { opacity: 1; transform: translateY(0); }

.sdz-hero-nav {
  padding: 16px 28px;
  display: flex; align-items: center;
  border-bottom: 1px solid #f7f2f7;
}
.sdz-back {
  display: inline-flex; align-items: center; gap: 6px;
  font-size: 13px; font-weight: 400; color: #999; text-decoration: none;
  transition: color 0.2s; font-family: 'DM Sans', sans-serif;
}
.sdz-back:hover { color: #1a0a2e; }

.sdz-hero-grid {
  display: grid;
  grid-template-columns: 34% 40% 26%;
  min-height: 640px;
  align-items: stretch;
}
@media (max-width: 960px) {
  .sdz-hero-grid {
    display: flex;
    flex-direction: column;
  }
  .sdz-hero-center { order: 1; }
  .sdz-hero-left   { order: 2; }
  .sdz-hero-right  { order: 3; }
}

/* ─── LEFT COLUMN ─── */
.sdz-hero-left {
  padding: 44px 28px 44px 36px;
  display: flex; flex-direction: column; justify-content: center;
}

/* Product name — Playfair Display (matches FAQ h1 style) */
.sdz-hero-title {
  font-family: 'Playfair Display', serif;
  font-size: 56px;
  font-weight: 900;
  line-height: 1.0;
  color: #1a0a2e;
  letter-spacing: -0.02em;
}
.sdz-hero-title-accent {
  display: block;
  font-style: italic;
  background: linear-gradient(90deg, #e8357a 0%, #f06292 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* Tagline — DM Sans light, letter-spaced (matches FAQ eyebrow) */
.sdz-hero-tagline {
  font-family: 'DM Sans', sans-serif;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: #c4607a;
  margin-top: 14px;
}

.sdz-hero-price {
  font-family: 'Playfair Display', serif;
  font-size: 38px;
  font-weight: 700;
  color: #e8357a;
  margin-top: 18px;
  letter-spacing: -0.01em;
}

/* Body copy — DM Sans light, matches FAQ answer style */
.sdz-hero-desc {
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  font-weight: 300;
  line-height: 1.82;
  color: rgba(30,17,24,0.72);
  margin-top: 16px;
}

.sdz-hero-compliance {
  font-family: 'DM Sans', sans-serif;
  font-size: 10.5px;
  font-weight: 300;
  color: rgba(30,17,24,0.35);
  margin-top: 20px;
  line-height: 1.7;
  letter-spacing: 0.02em;
}

.sdz-hero-actions {
  display: flex; align-items: center; gap: 10px; margin-top: 26px;
}

.sdz-add-btn {
  display: inline-flex; align-items: center; gap: 8px;
  background: #c0194e;
  color: #fff; border: none; border-radius: 50px;
  padding: 14px 28px; font-size: 12px; font-weight: 500;
  letter-spacing: 0.10em; text-transform: uppercase;
  cursor: pointer;
  font-family: 'DM Sans', sans-serif;
  transition: background 0.2s, transform 0.1s;
  position: relative; overflow: hidden;
}
.sdz-add-btn:hover:not(:disabled) { filter: brightness(0.88); transform: scale(1.02); }
.sdz-add-btn:active:not(:disabled) { transform: scale(0.97); }
.sdz-add-btn:disabled { opacity: 0.7; cursor: not-allowed; }
.sdz-add-btn.loading { background: #888; }
.sdz-add-btn.added  { background: #2d7a2d; }
.sdz-btn-spinner {
  display: none; width: 14px; height: 14px;
  border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff;
  border-radius: 50%; animation: sdz-spin 0.7s linear infinite;
}
.sdz-add-btn.loading .sdz-btn-spinner { display: block; }
.sdz-add-btn.loading .sdz-btn-icon,
.sdz-add-btn.loading .sdz-btn-text { display: none; }
@keyframes sdz-spin { to { transform: rotate(360deg); } }

.sdz-wish-btn {
  width: 48px; height: 48px; border-radius: 50%;
  border: 1.5px solid #e8d0d8; background: #fff; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: border-color 0.2s, background 0.2s, transform 0.15s; flex-shrink: 0;
}
.sdz-wish-btn:hover { border-color: #e8357a; background: #fff0f5; transform: scale(1.1); }
.sdz-wish-btn:active { transform: scale(0.9); }
.sdz-wish-btn svg { width: 18px; height: 18px; color: #d0a0b0; transition: fill 0.2s, color 0.2s; }
.sdz-wish-btn.wished { border-color: #e8357a; background: #fff0f5; }
.sdz-wish-btn.wished svg { fill: #e8357a; color: #e8357a; }
.sdz-wish-btn.pop svg { transform: scale(1.4); }

.sdz-view-wishlist {
  display: inline-flex; align-items: center; gap: 5px; margin-top: 14px;
  font-size: 11px; font-weight: 400; letter-spacing: 0.10em;
  color: rgba(107,66,38,0.4);
  cursor: pointer; background: none; border: none;
  font-family: 'DM Sans', sans-serif; transition: color 0.2s;
}
.sdz-view-wishlist:hover { color: #e8357a; }

/* ─── CENTER COLUMN ─── */
.sdz-hero-center {
  position: relative;
  display: flex; align-items: stretch; justify-content: stretch;
  padding: 20px 14px;
  background: transparent !important;
}

.sdz-center-inner {
  position: relative;
  width: 100%;
  border-radius: 28px;
  overflow: hidden;
  display: flex; align-items: center; justify-content: center;
  min-height: 500px;
}

.sdz-center-arch {
  position: absolute;
  top: 5%; left: 8%; right: 8%; bottom: 0;
  border-radius: 50% 50% 0 0 / 30% 30% 0 0;
  background: rgba(255,255,255,0.15);
  z-index: 1;
}

.sdz-product-img {
  position: relative; z-index: 3;
  width: 82%; max-width: 320px; height: auto;
  object-fit: contain;
  filter: drop-shadow(0 24px 36px rgba(180,30,80,0.22));
  animation: sdz-float 3.5s ease-in-out infinite;
  user-select: none; -webkit-user-drag: none;
}
@keyframes sdz-float { 0%,100%{ transform: translateY(0); } 50%{ transform: translateY(-10px); } }

.sdz-badge-brand {
  position: absolute; top: 18px; right: 18px; z-index: 10;
  background: #fff; border-radius: 50px; padding: 7px 14px 7px 8px;
  display: flex; align-items: center; gap: 9px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.10);
}
.sdz-badge-brand-avatar {
  width: 34px; height: 34px; border-radius: 50%;
  background: linear-gradient(135deg, #f48fb1, #e8357a);
  display: flex; align-items: center; justify-content: center;
  font-family: 'Playfair Display', serif;
  font-size: 14px; font-weight: 700; color: #fff;
}
.sdz-badge-brand-text { display: flex; flex-direction: column; line-height: 1.2; }
.sdz-badge-brand-name { font-family: 'Playfair Display', serif; font-size: 13px; font-weight: 700; color: #1a0a2e; }
.sdz-badge-brand-sub  { font-family: 'DM Sans', sans-serif; font-size: 10px; color: #aaa; font-weight: 400; }

/* ── LIVE VIEWERS BADGE ── */
.sdz-live-badge {
  position: absolute; top: 18px; left: 18px; z-index: 10;
  display: flex; align-items: center; gap: 8px;
  background: rgba(255,255,255,0.9); backdrop-filter: blur(8px);
  border-radius: 50px; padding: 8px 14px; box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  font-family: 'DM Sans', sans-serif;
  font-size: 12px; font-weight: 500; color: #1a1a1a;
  opacity: 0; transform: translateY(-8px);
  transition: opacity 0.4s ease, transform 0.4s ease;
}
.sdz-live-badge.sdz-live-visible { opacity: 1; transform: translateY(0); }
.sdz-live-dot { 
  width: 8px; height: 8px; border-radius: 50%; background: #10b981; flex-shrink: 0; 
  box-shadow: 0 0 0 0 rgba(16,185,129,0.7); animation: sdz-pulse-dot 1.5s infinite ease-in-out; 
}
@keyframes sdz-pulse-dot {
  0%   { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16,185,129,0.7); }
  70%  { transform: scale(1);    box-shadow: 0 0 0 6px rgba(16,185,129,0); }
  100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16,185,129,0); }
}

@media (max-width: 960px) {
  .sdz-live-badge {
    top: 72px;
    left: auto;
    right: 18px;
  }
}

.sdz-badge-thca {
  position: absolute; bottom: 70px; left: 14px; z-index: 10;
  background: #fff; border-radius: 50px; padding: 9px 16px 9px 9px;
  display: flex; align-items: center; gap: 10px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.10);
}
.sdz-badge-thca-icon {
  width: 36px; height: 36px; border-radius: 50%;
  background: linear-gradient(135deg, #fce4ec, #f48fb1);
  display: flex; align-items: center; justify-content: center; font-size: 15px; flex-shrink: 0;
}
.sdz-badge-thca-pct  { font-family: 'Playfair Display', serif; font-size: 14px; font-weight: 700; color: #1a0a2e; display: block; line-height: 1.2; }
.sdz-badge-thca-sub  { font-family: 'DM Sans', sans-serif; font-size: 10px; color: #aaa; font-weight: 400; display: block; letter-spacing: 0.05em; }

.sdz-badge-terp {
  position: absolute; bottom: 18px; right: 12px; z-index: 10;
  background: #fff; border-radius: 16px; padding: 10px 14px;
  display: flex; align-items: center; gap: 10px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.10); min-width: 185px;
}
.sdz-badge-terp-icon {
  width: 32px; height: 32px; border-radius: 50%;
  background: linear-gradient(135deg, #fce4ec, #f48fb1);
  display: flex; align-items: center; justify-content: center; font-size: 14px; flex-shrink: 0;
}
.sdz-badge-terp-title { font-family: 'Playfair Display', serif; font-size: 12.5px; font-weight: 700; color: #1a0a2e; display: block; line-height: 1.3; }
.sdz-badge-terp-sub   { font-family: 'DM Sans', sans-serif; font-size: 10px; color: #aaa; font-weight: 400; display: block; letter-spacing: 0.04em; }

.sdz-scroll-ind {
  position: absolute; bottom: 8px; left: 50%; transform: translateX(-50%); z-index: 10;
  width: 28px; height: 28px; border-radius: 50%;
  background: rgba(255,255,255,0.88);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}
.sdz-scroll-ind svg { width: 13px; height: 13px; color: #c0194e; }

/* ─── RIGHT COLUMN ─── */
.sdz-hero-right {
  padding: 28px 22px 28px 20px;
  display: flex; flex-direction: column; justify-content: flex-start;
  border-left: 1px solid #f3ecf3;
}

.sdz-right-nav { display: flex; gap: 8px; margin-bottom: 22px; }
.sdz-nav-arrow {
  width: 36px; height: 36px; border-radius: 50%;
  border: 1.5px solid #e8e0e8; background: #fff;
  display: flex; align-items: center; justify-content: center; cursor: pointer;
  transition: border-color 0.2s, background 0.2s;
}
.sdz-nav-arrow:hover { border-color: #e8357a; background: #fff0f5; }
.sdz-nav-arrow svg { width: 14px; height: 14px; color: #666; }

/* Accordion — Playfair for question text, DM Sans for body */
.sdz-acc-item { border-bottom: 1.5px solid #fadadf; }
.sdz-acc-btn {
  width: 100%; display: flex; justify-content: space-between; align-items: center;
  padding: 14px 0; background: none; border: none; text-align: left;
  font-family: 'Playfair Display', serif;
  font-size: 15px; font-weight: 700; color: #1a0a2e; cursor: pointer;
  transition: color 0.2s;
}
.sdz-acc-btn:hover { color: #e8357a; }
.sdz-acc-chev { width: 16px; height: 16px; color: #d0a0b8; transition: transform 0.3s; flex-shrink: 0; }
.sdz-acc-chev.open { transform: rotate(180deg); color: #e8357a; }
.sdz-acc-body { overflow: hidden; max-height: 0; transition: max-height 0.35s ease, opacity 0.35s ease; opacity: 0; }
.sdz-acc-body.open { max-height: 500px; opacity: 1; }
.sdz-acc-content {
  padding-bottom: 14px;
  font-family: 'DM Sans', sans-serif;
  font-size: 13px; font-weight: 300; line-height: 1.75; color: rgba(30,17,24,0.65);
}

.sdz-spec-row {
  display: flex; align-items: baseline; gap: 6px;
  padding: 3px 0;
  font-family: 'DM Sans', sans-serif;
  font-size: 12.5px;
}
.sdz-spec-icon { font-size: 13px; width: 18px; text-align: center; flex-shrink: 0; }
.sdz-spec-label {
  color: #e8357a; font-weight: 500;
  min-width: 72px; flex-shrink: 0;
  letter-spacing: 0.02em;
}
.sdz-spec-val { color: #222; font-weight: 300; }

/* ══════════════════════════════════
   SECTION CARDS (products 2–4)
══════════════════════════════════ */
.sdz-section {
  margin-top: 24px;
  background: #fff;
  border-radius: 24px;
  border: 1px solid #ede5ed;
  overflow: hidden;
  box-shadow: 0 4px 6px rgba(0,0,0,0.02), 0 16px 40px rgba(0,0,0,0.05);
  opacity: 0; transform: translateY(24px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.sdz-section.visible { opacity: 1; transform: translateY(0); }
.sdz-section .sdz-hero-grid { min-height: 580px; }
.sdz-section .sdz-hero-title { font-size: 48px; }
@media (min-width: 1100px) { .sdz-section .sdz-hero-title { font-size: 52px; } }

/* ── COMPLIANCE FOOTER ── */
.sdz-compliance {
  margin-top: 32px; text-align: center;
  font-family: 'DM Sans', sans-serif;
  font-size: 10px; letter-spacing: 0.05em; color: rgba(107,66,38,0.3);
  font-weight: 300;
}

/* ── ANIMATE HELPER ── */
.sdz-animate { opacity: 0; transform: translateY(16px); transition: opacity 0.6s ease, transform 0.6s ease; }
.sdz-animate.visible { opacity: 1; transform: translateY(0); }
</style>

