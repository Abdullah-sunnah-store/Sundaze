{% comment %}
  Greatest Hits Product Carousel Section
  Place in: sections/greatest-hits-carousel.liquid
{% endcomment %}

<section class="greatest-hits" id="greatest-hits-{{ section.id }}">
  <div class="gh-starfield" aria-hidden="true"></div>

  <div class="gh-inner">
    <h2 class="gh-title">{{ section.settings.heading }}</h2>

    <div class="gh-carousel-wrapper">
      <button class="gh-btn gh-btn--prev" aria-label="Previous products">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M13 4L7 10L13 16" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>

      <div class="gh-track-overflow">
        <div class="gh-track">
          {% for block in section.blocks %}
            {% if block.type == 'product_card' %}
              <div class="gh-card" {{ block.shopify_attributes }}>
                <a class="gh-card__link" href="{{ block.settings.product_url | default: '#' }}">
                  <div class="gh-card__img-wrap">
                    {% if block.settings.product_image != blank %}
                      <img
                        class="gh-card__img"
                        src="{{ block.settings.product_image | image_url: width: 600 }}"
                        alt="{{ block.settings.product_title | escape }}"
                        width="600"
                        height="600"
                        loading="lazy"
                      >
                    {% else %}
                      <div class="gh-card__img gh-card__img--placeholder">
                        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                      </div>
                    {% endif %}
                    <div class="gh-card__shine"></div>
                    <div class="gh-card__glow"></div>
                  </div>
                  <div class="gh-card__info">
                    <span class="gh-card__meta">{{ block.settings.product_meta }}</span>
                    <span class="gh-card__name">{{ block.settings.product_title }}</span>
                  </div>
                </a>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <button class="gh-btn gh-btn--next" aria-label="Next products">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M7 4L13 10L7 16" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>

    <div class="gh-dots" aria-hidden="true"></div>
  </div>
</section>

<style>
  /* ─── Variables ─────────────────────────────────────── */
  #greatest-hits-{{ section.id }} {
    --gh-bg:        {{ section.settings.bg_color }};
    --gh-accent:    {{ section.settings.accent_color }};
    --gh-text:      {{ section.settings.text_color }};
    --gh-card-bg:   {{ section.settings.card_bg_color }};
    --gh-gap:       20px;
    --gh-cards-vis: {{ section.settings.cards_visible }};
    --gh-transition: 0.55s cubic-bezier(0.65, 0, 0.35, 1);
  }

  /* ─── Section shell ─────────────────────────────────── */
  .greatest-hits {
    position: relative;
    background: var(--gh-bg);
    padding: 70px 0 80px;
    overflow: hidden;
    
  }

  /* ─── Star field ────────────────────────────────────── */
  .gh-starfield {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      radial-gradient(1px 1px at 10% 20%, rgba(255,255,255,.55) 0%, transparent 100%),
      radial-gradient(1px 1px at 30% 50%, rgba(255,255,255,.40) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 55% 15%, rgba(255,255,255,.60) 0%, transparent 100%),
      radial-gradient(1px 1px at 75% 70%, rgba(255,255,255,.45) 0%, transparent 100%),
      radial-gradient(1px 1px at 90% 35%, rgba(255,255,255,.50) 0%, transparent 100%),
      radial-gradient(1px 1px at 15% 80%, rgba(255,255,255,.30) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 42% 88%, rgba(255,255,255,.55) 0%, transparent 100%),
      radial-gradient(1px 1px at 65% 45%, rgba(255,255,255,.35) 0%, transparent 100%),
      radial-gradient(1px 1px at 82% 10%, rgba(255,255,255,.50) 0%, transparent 100%),
      radial-gradient(2px 2px at 5%  5%,  rgba(255,255,255,.70) 0%, transparent 100%),
      radial-gradient(1px 1px at 22% 60%, rgba(255,255,255,.40) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 48% 30%, rgba(255,255,255,.55) 0%, transparent 100%),
      radial-gradient(1px 1px at 70% 92%, rgba(255,255,255,.30) 0%, transparent 100%),
      radial-gradient(1px 1px at 95% 75%, rgba(255,255,255,.45) 0%, transparent 100%);
  }

  .gh-inner {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ─── Title ─────────────────────────────────────────── */
  .gh-title {
    text-align: center;
    color: var(--gh-text);
    font-family: 'Barlow Condensed', 'Impact', 'Arial Black', sans-serif;
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 900;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0 0 48px;
    text-shadow: 0 0 40px rgba(255,255,255,.15);
    font-family: 'Barlow Condensed', 'Impact', sans-serif;
  }

  /* ─── Carousel wrapper ──────────────────────────────── */
  .gh-carousel-wrapper {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .gh-track-overflow {
    flex: 1;
    /* overflow-x clips the carousel slide; overflow-y must stay visible so
       the hover lift is never cut off at the top */
    overflow-x: hidden;
    overflow-y: visible;
    /* Extra top padding gives the lifted card room to breathe */
    padding-top: 18px;
    margin-top: -18px;
  }

  .gh-track {
    display: flex;
    gap: var(--gh-gap);
    transition: transform var(--gh-transition);
    will-change: transform;
    /* Mirror the padding so cards are visually flush at rest */
    padding-top: 0;
  }

  /* ─── Cards ─────────────────────────────────────────── */
  .gh-card {
    flex: 0 0 calc((100% - (var(--gh-cards-vis) - 1) * var(--gh-gap)) / var(--gh-cards-vis));
    min-width: 0;
    font-family: sans-serif;
  }

  .gh-card__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .gh-card__img-wrap {
    position: relative;
    aspect-ratio: 1 / 1;
    background: var(--gh-card-bg);
    border-radius: 14px;
    /* overflow hidden only clips the shine/img inside — NOT the lift transform */
    overflow: hidden;
    border: 1px solid rgba(255,255,255,.06);
    transition:
      transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.45s ease,
      border-color 0.45s ease;
  }

  .gh-card__link:hover .gh-card__img-wrap,
  .gh-card__link:focus-visible .gh-card__img-wrap {
    transform: translateY(-10px) scale(1.03);
    box-shadow:
      0 24px 60px rgba(0,0,0,.55),
      0 0 0 1px rgba(255,255,255,.18),
      0 0 60px -10px var(--gh-accent);
    border-color: rgba(255,255,255,.22);
  }

  /* Shine sweep on hover */
  .gh-card__shine {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      115deg,
      transparent 30%,
      rgba(255,255,255,.18) 50%,
      transparent 70%
    );
    transform: translateX(-120%);
    transition: transform 0.6s ease;
    pointer-events: none;
    border-radius: inherit;
  }
  .gh-card__link:hover .gh-card__shine {
    transform: translateX(120%);
  }

  /* Glow pulse on hover */
  .gh-card__glow {
    position: absolute;
    inset: -20%;
    background: radial-gradient(circle at 50% 110%, var(--gh-accent), transparent 65%);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }
  .gh-card__link:hover .gh-card__glow {
    opacity: 0.35;
  }

  .gh-card__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 12px;
    transition: transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
    display: block;
  }
  .gh-card__link:hover .gh-card__img {
    transform: scale(1.06);
  }

  .gh-card__img--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .gh-card__img--placeholder .placeholder-svg {
    width: 70%;
    height: 70%;
    opacity: .3;
  }

  /* ─── Card info ─────────────────────────────────────── */
  .gh-card__info {
    padding: 14px 4px 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .gh-card__meta {
    font-size: .72rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: rgba(255,255,255,.45);
    font-weight: 600;
  }
  .gh-card__name {
    font-size: clamp(.9rem, 1.4vw, 1.15rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: var(--gh-text);
    transition: color 0.3s ease;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .gh-card__link:hover .gh-card__name {
    color: var(--gh-accent);
  }

  /* ─── Nav buttons ───────────────────────────────────── */
  .gh-btn {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,.25);
    background: rgba(255,255,255,.08);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      background 0.3s ease,
      border-color 0.3s ease,
      transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    backdrop-filter: blur(6px);
  }
  .gh-btn:hover {
    background: rgba(255,255,255,.18);
    border-color: rgba(255,255,255,.55);
    transform: scale(1.12);
  }
  .gh-btn:active { transform: scale(0.94); }
  .gh-btn:disabled {
    opacity: .3;
    cursor: not-allowed;
    transform: none;
  }

  /* ─── Dots ──────────────────────────────────────────── */
  .gh-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 28px;
  }
  .gh-dot {
    width: 8px;
    height: 8px;
    border-radius: 4px;
    background: rgba(255,255,255,.25);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: width 0.3s ease, background 0.3s ease;
  }
  .gh-dot.is-active {
    width: 24px;
    background: var(--gh-accent);
  }

  /* ─── Responsive ────────────────────────────────────── */
  @media (max-width: 1024px) {
    #greatest-hits-{{ section.id }} { --gh-cards-vis: 3; }
  }
  @media (max-width: 768px) {
    #greatest-hits-{{ section.id }} { --gh-cards-vis: 2; }
    .gh-btn { width: 38px; height: 38px; }
    .gh-title { margin-bottom: 32px; }
  }
  @media (max-width: 480px) {
    #greatest-hits-{{ section.id }} {
      --gh-cards-vis: 1.2;
      --gh-gap: 14px;
    }
    .gh-carousel-wrapper { gap: 10px; }
  }
</style>

<script>
  (function () {
    const section   = document.getElementById('greatest-hits-{{ section.id }}');
    if (!section) return;

    const track     = section.querySelector('.gh-track');
    const cards     = Array.from(section.querySelectorAll('.gh-card'));
    const btnPrev   = section.querySelector('.gh-btn--prev');
    const btnNext   = section.querySelector('.gh-btn--next');
    const dotsWrap  = section.querySelector('.gh-dots');

    // Compute how many cards are visible at once
    function getVisible() {
      const style = getComputedStyle(section);
      return parseFloat(style.getPropertyValue('--gh-cards-vis')) || 4;
    }

    let current  = 0;
    let maxIndex = 0;
    let dots     = [];

    function buildDots() {
      dotsWrap.innerHTML = '';
      dots = [];
      maxIndex = Math.max(0, cards.length - Math.floor(getVisible()));
      for (let i = 0; i <= maxIndex; i++) {
        const d = document.createElement('button');
        d.className = 'gh-dot';
        d.setAttribute('aria-label', `Go to slide ${i + 1}`);
        d.addEventListener('click', () => goTo(i));
        dotsWrap.appendChild(d);
        dots.push(d);
      }
    }

    function updateTrack() {
      const cardWidth  = cards[0] ? cards[0].offsetWidth : 0;
      const gap        = parseFloat(getComputedStyle(section).getPropertyValue('--gh-gap')) || 20;
      const offset     = current * (cardWidth + gap);
      track.style.transform = `translateX(-${offset}px)`;
      btnPrev.disabled = current === 0;
      btnNext.disabled = current >= maxIndex;
      dots.forEach((d, i) => d.classList.toggle('is-active', i === current));
    }

    function goTo(index) {
      current = Math.max(0, Math.min(index, maxIndex));
      updateTrack();
    }

    btnPrev.addEventListener('click', () => goTo(current - 1));
    btnNext.addEventListener('click', () => goTo(current + 1));

    // Touch / swipe
    let touchStartX = null;
    track.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', e => {
      if (touchStartX === null) return;
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) goTo(diff > 0 ? current + 1 : current - 1);
      touchStartX = null;
    });

    // Init + re-init on resize
    function init() {
      buildDots();
      current = Math.min(current, maxIndex);
      updateTrack();
    }

    const ro = new ResizeObserver(init);
    ro.observe(section);
    init();
  })();
</script>

{% schema %}
{
  "name": "Greatest Hits Carousel",
  "tag": "section",
  "class": "greatest-hits-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "THE GREATEST HITS"
    },
    {
      "type": "range",
      "id": "cards_visible",
      "label": "Cards visible (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#0a0a0f"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background Color",
      "default": "#16161e"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent / Glow Color",
      "default": "#a3ff4f"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Product Image"
        },
        {
          "type": "text",
          "id": "product_meta",
          "label": "Meta / Subtitle (e.g. SATIVA / 5-PACK)",
          "default": "SATIVA / 5-PACK"
        },
        {
          "type": "text",
          "id": "product_title",
          "label": "Product Name",
          "default": "NYC DIESEL SATIVA JUICED..."
        },
        {
          "type": "url",
          "id": "product_url",
          "label": "Product Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Greatest Hits Carousel",
      "blocks": [
        {
          "type": "product_card",
          "settings": {
            "product_meta": "SATIVA / 5-PACK",
            "product_title": "NYC DIESEL SATIVA JUICED..."
          }
        },
        {
          "type": "product_card",
          "settings": {
            "product_meta": "YOUR FIRST SCRUB IN THE BATH",
            "product_title": "BUBBLE BATH INDICA JUICE..."
          }
        },
        {
          "type": "product_card",
          "settings": {
            "product_meta": "SATIVA / 5-PACK",
            "product_title": "EUPHORIA SATIVA FLOWER..."
          }
        },
        {
          "type": "product_card",
          "settings": {
            "product_meta": "HYBRID / 5-PACK",
            "product_title": "RODEO OG HYBRID JUICED..."
          }
        }
      ]
    }
  ]
}
{% endschema %}
