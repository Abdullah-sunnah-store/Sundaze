{% comment %}
  Neapolitan Bucket Product Page
  Matches reference design exactly:
  — Left:   Back link · title · flavor sub · price · desc · bucket selector · ATC · mini hash-holes card
  — Center: Hero card with gradient bg · selected pill · nav arrows · jars · frosted feature card · bottom pills
  — Right:  Description / Flavor Notes / Product Specs / Collection accordions
{% endcomment %}

<!-- ════════════════════════════════════════════════════════════
     BUCKET / SINGLE PILL BAR — shared navigation
════════════════════════════════════════════════════════════ -->
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap');

  .nbp-variant-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 20px;
    flex-wrap: wrap;
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
    padding: 14px 16px 8px;
  }

  .nbp-variant-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 28px;
    border-radius: 50px;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.03em;
    cursor: pointer;
    text-decoration: none;
    transition: transform 0.15s ease, box-shadow 0.2s ease, background 0.2s ease, color 0.2s ease;
    border: 2px solid transparent;
    font-family: 'Inter', sans-serif;
    line-height: 1;
  }

  .nbp-variant-pill--bucket {
    background: #1a1a1a;
    color: #ffffff;
    box-shadow: 0 6px 20px rgba(0,0,0,0.2);
  }
  .nbp-variant-pill--bucket:hover {
    background: #333;
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(0,0,0,0.28);
  }

  .nbp-variant-pill--single {
    background: #1a1a1a;
    color: #ffffff;
    border: 2px solid #1a1a1a;
    box-shadow: 0 4px 14px rgba(0,0,0,0.08);
  }
  .nbp-variant-pill--single:hover {
    background: #1a1a1a;
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(0,0,0,0.2);
  }

  .nbp-variant-pill--active {
    outline: 3px solid #1a1a1a;
    outline-offset: 3px;
    pointer-events: none;
  }

  .nbp-variant-pill--bucket.nbp-variant-pill--active {
    background: #1a1a1a;
    color: #fff;
    box-shadow: 0 6px 20px rgba(0,0,0,0.3);
  }

  .nbp-variant-pill--single.nbp-variant-pill--active {
    background: #1a1a1a;
    color: #fff;
    border-color: #1a1a1a;
    box-shadow: 0 6px 20px rgba(0,0,0,0.3);
  }

  .nbp-variant-pill:active { transform: scale(0.97) translateY(0); }

  .nbp-variant-pill__icon { font-size: 16px; line-height: 1; }
</style>

{%- assign _path      = request.path -%}
{%- assign _is_bucket = false -%}
{%- assign _is_single = false -%}
{%- if _path contains 'neapolitan-bucket'     -%}{%- assign _is_bucket = true -%}{%- endif -%}
{%- if _path contains 'hash-holes-collection' -%}{%- assign _is_single = true -%}{%- endif -%}

<section id="nbp-{{ section.id }}" class="nbp">
  {% comment %} <nav class="nbp-variant-bar" aria-label="View type">
    <a
      href="{{ section.settings.bucket_page_link }}"
      class="nbp-variant-pill nbp-variant-pill--bucket{% if _is_bucket %} nbp-variant-pill--active{% endif %}"
      {% if _is_bucket %}aria-current="page"{% endif %}>
      <span class="nbp-variant-pill__icon" aria-hidden="true">🪣</span>
      Bucket
    </a>
    <a
      href="{{ section.settings.single_page_link }}"
      class="nbp-variant-pill nbp-variant-pill--single{% if _is_single %} nbp-variant-pill--active{% endif %}"
      {% if _is_single %}aria-current="page"{% endif %}>
      <span class="nbp-variant-pill__icon" aria-hidden="true">🍩</span>
      Single
    </a>
  </nav> {% endcomment %}

  <div class="nbp-shell">
    <div class="nbp-grid">

      <!-- ══════════════════════════════
           LEFT COLUMN
      ══════════════════════════════ -->
      <div class="nbp-left">

        <h1 class="nbp-title">
          <span class="nbp-title__top">{{ section.settings.title_top | default: 'Neapolitan' }}</span>
          <span class="nbp-title__gradient">{{ section.settings.title_gradient | default: 'Bucket' }}</span>
        </h1>

        <p class="nbp-flavor-sub" id="nbp-sub-{{ section.id }}">
          {{ section.settings.flavor_line | default: 'Vanilla • Strawberry Shortcake • Nugtella' }}
        </p>

        <div class="nbp-price" id="nbp-price-{{ section.id }}">
          {% if section.settings.mixed_product != blank %}
            {{ section.settings.mixed_product.price | money }}
          {% else %}
            {{ section.settings.price_fallback | default: '$45.00' }}
          {% endif %}
        </div>

        <p class="nbp-desc" id="nbp-desc-{{ section.id }}">
          {{ section.settings.description }}
        </p>

        <p class="nbp-choose-label">Choose Your Bucket</p>

        <div class="nbp-options">

          {% if section.settings.nugtella_product != blank %}
            <button type="button" class="nbp-opt" data-nbp-opt
              data-variant="{{ section.settings.nugtella_product.selected_or_first_available_variant.id }}"
              data-price="{{ section.settings.nugtella_product.price | money }}"
              data-sub="Chocolate • Hazelnut • Indulgent"
              data-desc="{{ section.settings.nugtella_desc | default: section.settings.description | escape }}"
              data-label="Nugtella Selected"
              data-pill="🍫 Nugtella"
              data-pill2="⬡ Single Flavor"
              data-acc-desc="{{ section.settings.nugtella_acc_desc | escape }}"
              data-acc-flavor="{{ section.settings.nugtella_acc_flavor | escape }}"
              data-acc-specs="{{ section.settings.nugtella_acc_specs | escape }}"
              data-acc-highlight="{{ section.settings.nugtella_acc_highlight | escape }}"
              data-image="{{ section.settings.bucket_image_nugtella | image_url: width: 900 | default: section.settings.nugtella_product.featured_image | image_url: width: 900 }}"
              data-mode="single">
              Nugtella
            </button>
          {% endif %}

          {% if section.settings.strawberry_product != blank %}
            <button type="button" class="nbp-opt" data-nbp-opt
              data-variant="{{ section.settings.strawberry_product.selected_or_first_available_variant.id }}"
              data-price="{{ section.settings.strawberry_product.price | money }}"
              data-sub="Sweet • Berry • Cake"
              data-desc="{{ section.settings.strawberry_desc | default: section.settings.description | escape }}"
              data-label="Strawberry Shortcake Selected"
              data-pill="🍓 Strawberry Shortcake"
              data-pill2="⬡ Single Flavor"
              data-acc-desc="{{ section.settings.strawberry_acc_desc | escape }}"
              data-acc-flavor="{{ section.settings.strawberry_acc_flavor | escape }}"
              data-acc-specs="{{ section.settings.strawberry_acc_specs | escape }}"
              data-acc-highlight="{{ section.settings.strawberry_acc_highlight | escape }}"
              data-image="{{ section.settings.bucket_image_strawberry | image_url: width: 900 | default: section.settings.strawberry_product.featured_image | image_url: width: 900 }}"
              data-mode="single">
              Strawberry Shortcake
            </button>
          {% endif %}

          {% if section.settings.vanilla_product != blank %}
            <button type="button" class="nbp-opt" data-nbp-opt
              data-variant="{{ section.settings.vanilla_product.selected_or_first_available_variant.id }}"
              data-price="{{ section.settings.vanilla_product.price | money }}"
              data-sub="Creamy • Smooth • Classic"
              data-desc="{{ section.settings.vanilla_desc | default: section.settings.description | escape }}"
              data-label="Vanilla Selected"
              data-pill="🍦 Vanilla"
              data-pill2="⬡ Single Flavor"
              data-acc-desc="{{ section.settings.vanilla_acc_desc | escape }}"
              data-acc-flavor="{{ section.settings.vanilla_acc_flavor | escape }}"
              data-acc-specs="{{ section.settings.vanilla_acc_specs | escape }}"
              data-acc-highlight="{{ section.settings.vanilla_acc_highlight | escape }}"
              data-image="{{ section.settings.bucket_image_vanilla | image_url: width: 900 | default: section.settings.vanilla_product.featured_image | image_url: width: 900 }}"
              data-mode="single">
              Vanilla
            </button>
          {% endif %}

          {% if section.settings.mixed_product != blank %}
            <button type="button" class="nbp-opt active" data-nbp-opt
              data-variant="{{ section.settings.mixed_product.selected_or_first_available_variant.id }}"
              data-price="{{ section.settings.mixed_product.price | money }}"
              data-sub="{{ section.settings.flavor_line | default: 'Vanilla • Strawberry Shortcake • Nugtella' }}"
              data-desc="{{ section.settings.description | escape }}"
              data-label="Mixed Bucket Selected"
              data-pill="🍨 Neapolitan Collection"
              data-pill2="⬡ 3 Flavor Bundle"
              data-acc-desc="{{ section.settings.mixed_acc_desc | escape }}"
              data-acc-flavor="{{ section.settings.mixed_acc_flavor | escape }}"
              data-acc-specs="{{ section.settings.mixed_acc_specs | escape }}"
              data-acc-highlight="{{ section.settings.mixed_acc_highlight | escape }}"
              data-image=""
              data-mode="mixed">
              Mixed Bucket
            </button>
          {% endif %}

        </div><!-- /.nbp-options -->

        <div class="nbp-actions">
          <form method="post" action="/cart/add" data-nbp-form>
            <input type="hidden" name="quantity" value="1">
            <input type="hidden" name="id" id="nbp-vid-{{ section.id }}"
              value="{% if section.settings.mixed_product != blank %}{{ section.settings.mixed_product.selected_or_first_available_variant.id }}{% elsif section.settings.nugtella_product != blank %}{{ section.settings.nugtella_product.selected_or_first_available_variant.id }}{% endif %}">
            <button type="submit" class="nbp-atc">
              <span class="nbp-atc__check">✓</span> Add to cart
            </button>
          </form>
          <button type="button" class="nbp-wish nbp-wish-btn" id="nbp-wish-{{ section.id }}" aria-label="Add to wishlist"
            data-variant-id="{% if section.settings.mixed_product != blank %}{{ section.settings.mixed_product.selected_or_first_available_variant.id }}{% elsif section.settings.nugtella_product != blank %}{{ section.settings.nugtella_product.selected_or_first_available_variant.id }}{% endif %}"
            data-product-name="Mixed Bucket"
            data-product-price="{% if section.settings.mixed_product != blank %}{{ section.settings.mixed_product.price | money }}{% endif %}"
            data-product-image="{{ section.settings.bucket_image_mixed | image_url: width: 200 }}"
            data-product-emoji="🪣"
            onclick="NbpWish.toggle(this)">
            ♡
          </button>
        </div>

        <!-- Mini hash-holes card -->
        <div class="nbp-mini-card">
          {% if section.settings.hasholes_image != blank %}
            <img src="{{ section.settings.hasholes_image | image_url: width: 160 }}"
                 alt="12 Hash Holes" class="nbp-mini-card__img">
          {% else %}
            <div class="nbp-dot-grid nbp-dot-grid--sm">
              <span></span><span></span><span></span><span></span>
              <span></span><span></span><span></span><span></span>
              <span></span><span></span><span></span><span></span>
            </div>
          {% endif %}
          <div class="nbp-mini-card__text">
            <strong>12 HASH HOLES</strong>
            <b>INSIDE EVERY BUCKET</b>
            <small>Pre-roll Style • Ready to Enjoy</small>
          </div>
          
        </div>

      </div><!-- /.nbp-left -->


      <!-- ══════════════════════════════
           CENTER COLUMN — HERO CARD
      ══════════════════════════════ -->
      <div class="nbp-center">
        <div class="nbp-hero-card">

          <!-- Top row: selected pill + nav arrows -->
          <div class="nbp-hero-top">
            <div class="nbp-selected-pill">
              <span class="nbp-selected-pill__check" aria-hidden="true">✓</span>
              <span id="nbp-label-{{ section.id }}">Mixed Bucket Selected</span>
            </div>
          </div>

          <!-- ══ LIVE VIEWERS BADGE ══ -->
          <div class="nbp-live-badge" id="nbpLiveBadge">
            <span class="nbp-live-dot"></span>
            <span id="nbpLiveCount">0</span> viewing now
          </div>

          <!-- Jars display area -->
          <div class="nbp-jars" id="nbp-jars-{{ section.id }}">
            {% if section.settings.bucket_image_mixed != blank %}
              <img src="{{ section.settings.bucket_image_mixed | image_url: width: 900 }}"
                   alt="Mixed Bucket" class="nbp-jar nbp-jar--single" loading="lazy">
            {% else %}
              {% if section.settings.nugtella_product.featured_image != blank %}
                <img src="{{ section.settings.nugtella_product.featured_image | image_url: width: 600 }}"
                     alt="Nugtella" class="nbp-jar nbp-jar--l" loading="lazy">
              {% endif %}
              {% if section.settings.strawberry_product.featured_image != blank %}
                <img src="{{ section.settings.strawberry_product.featured_image | image_url: width: 600 }}"
                     alt="Strawberry Shortcake" class="nbp-jar nbp-jar--c" loading="lazy">
              {% endif %}
              {% if section.settings.vanilla_product.featured_image != blank %}
                <img src="{{ section.settings.vanilla_product.featured_image | image_url: width: 600 }}"
                     alt="Vanilla" class="nbp-jar nbp-jar--r" loading="lazy">
              {% endif %}
            {% endif %}
          </div><!-- /#nbp-jars -->

          <!-- Frosted feature card -->
          <div class="nbp-feat-card">
            {% if section.settings.hasholes_image != blank %}
              <img src="{{ section.settings.hasholes_image | image_url: width: 160 }}"
                   alt="12 Hash Holes" class="nbp-feat-card__img">
            {% else %}
              <div class="nbp-dot-grid nbp-dot-grid--lg">
                <span></span><span></span><span></span><span></span>
                <span></span><span></span><span></span><span></span>
                <span></span><span></span><span></span><span></span>
              </div>
            {% endif %}
            <div class="nbp-feat-card__text">
              <strong>12 HASH HOLES</strong>
              <b>INSIDE EVERY BUCKET</b>
              <small>Pre-roll Style • Ready to Enjoy</small>
            </div>
            <div class="nbp-feat-card__divider" aria-hidden="true"></div>
            <div class="nbp-feat-card__bucket" aria-hidden="true">
              {% if section.settings.bucket_icon != blank %}
                <img src="{{ section.settings.bucket_icon | image_url: width: 140 }}"
                     alt="" class="nbp-feat-card__bucket-img">
              {% else %}
                <svg viewBox="0 0 120 120" fill="none" aria-hidden="true" class="nbp-bucket-svg">
                  <path d="M35 40H85L78 98H42L35 40Z" stroke="currentColor" stroke-width="4" stroke-linejoin="round"/>
                  <path d="M42 40C43 24 77 24 78 40" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
                  <path d="M47 33H73" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
                  <path d="M49 70C57 60 70 60 75 72" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                  <path d="M52 78C59 73 67 73 73 79" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                </svg>
              {% endif %}
            </div>
          </div><!-- /.nbp-feat-card -->

          <!-- Bottom pills -->
          <div class="nbp-bottom-pills">
            <div class="nbp-pill" id="nbp-pill1-{{ section.id }}">🍦 Neapolitan Collection</div>
            <div class="nbp-pill" id="nbp-pill2-{{ section.id }}">⬡ 3 Flavor Bundle</div>
          </div>

        </div><!-- /.nbp-hero-card -->
      </div><!-- /.nbp-center -->


      <!-- ══════════════════════════════
           RIGHT COLUMN — ACCORDIONS
      ══════════════════════════════ -->
      <div class="nbp-right">

        <div class="nbp-acc">
          <button type="button" class="nbp-acc__btn" data-nbp-acc>
            Description <span class="nbp-acc__icon" aria-hidden="true">⌄</span>
          </button>
          <div class="nbp-acc__panel">
            <p id="nbp-acc-desc-{{ section.id }}">{{ section.settings.description }}</p>
          </div>
        </div>

        <div class="nbp-acc">
          <button type="button" class="nbp-acc__btn" data-nbp-acc>
            Flavor Notes <span class="nbp-acc__icon" aria-hidden="true">⌄</span>
          </button>
          <div class="nbp-acc__panel">
            <p id="nbp-acc-flavor-{{ section.id }}">{{ section.settings.flavor_notes }}</p>
          </div>
        </div>

        <div class="nbp-acc nbp-acc--open">
          <button type="button" class="nbp-acc__btn" data-nbp-acc>
            Product Specs <span class="nbp-acc__icon nbp-acc__icon--open" aria-hidden="true">⌄</span>
          </button>
          <div class="nbp-acc__panel" id="nbp-acc-specs-panel-{{ section.id }}">
            <div id="nbp-acc-specs-{{ section.id }}">
              {{ section.settings.mixed_acc_specs }}
            </div>
            <p class="nbp-acc__highlight" id="nbp-acc-highlight-{{ section.id }}">
              {{ section.settings.mixed_acc_highlight | default: '🍓 12 Hash Holes Inside Every Bucket' }}
            </p>
          </div>
        </div>

        <div class="nbp-acc">
          <button type="button" class="nbp-acc__btn" data-nbp-acc>
            Collection <span class="nbp-acc__icon" aria-hidden="true">⌄</span>
          </button>
          <div class="nbp-acc__panel">
            <p>Part of the Sundaze Neapolitan collection.</p>
          </div>
        </div>

      </div><!-- /.nbp-right -->

    </div><!-- /.nbp-grid -->
  </div><!-- /.nbp-shell -->


<!-- ════════════════════════════════════════════════════════════
     FLOATING BADGES — Cart & Wishlist
════════════════════════════════════════════════════════════ -->

{% comment %} <!-- Cart Badge -->
<a href="/cart" class="nbp-badge nbp-badge--cart" id="nbpCartBadge" aria-label="View cart">
  <span class="nbp-badge__icon" aria-hidden="true">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
      <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
    </svg>
  </span>
  <span class="nbp-badge__label">Cart</span>
  <span class="nbp-badge__count nbp-badge__count--dark" id="nbpCartCount">0</span>
</a>

<!-- Wishlist Badge -->
<button
  type="button"
  class="nbp-badge nbp-badge--wish"
  id="nbpWishBadge"
  onclick="NbpWish.openDrawer()"
  aria-label="View wishlist">
  <span class="nbp-badge__icon nbp-badge__icon--heart" aria-hidden="true">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none">
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
    </svg>
  </span>
  <span class="nbp-badge__label">Wishlist</span>
  <span class="nbp-badge__count nbp-badge__count--purple" id="nbpWishCount">0</span>
</button> {% endcomment %}

<!-- Toast notification -->
<div class="nbp-toast" id="nbpToast" role="status" aria-live="polite">
  <span class="nbp-toast__icon" id="nbpToastIcon"></span>
  <span id="nbpToastMsg"></span>
</div>

<!-- Wishlist Overlay -->
<div class="nbp-wish-overlay" id="nbpWishOverlay"></div>

<!-- Wishlist Drawer -->
<div class="nbp-wish-drawer" id="nbpWishDrawer" role="dialog" aria-modal="true" aria-label="Wishlist">
  <div class="nbp-wish-drawer__header">
    <p class="nbp-wish-drawer__title">
      <span aria-hidden="true">💗</span> Wishlist
    </p>
    <button type="button" class="nbp-wish-drawer__close" id="nbpWishClose" aria-label="Close wishlist">✕</button>
  </div>
  <div id="nbpWishList"></div>
</div>

</section>


<!-- ════════════════════════════════════════════════════════════
     INDIVIDUAL BUCKET CARDS
════════════════════════════════════════════════════════════ -->
<div class="nbc-wrap" id="nbc-{{ section.id }}">

  <!-- ── Nugtella ── -->
  {% if section.settings.nugtella_product != blank %}
  <div class="nbc-card nbc-card--nugtella" data-nbc-card>
    <div class="nbc-grid">

      <div class="nbc-left" data-nbc-animate>
        <span class="nbc-flavor-badge" style="background:linear-gradient(135deg,#3d1f0a,#6b3a1f);color:#f5d9b8;">🍫 Nugtella</span>
        <h2 class="nbc-title">
          <span class="nbc-title__word">Nugtella</span>
          <span class="nbc-title__word nbc-title__gradient" style="background-image:linear-gradient(90deg,#5D3A1A 0%,#a0622a 50%,#c8883c 100%);">Bucket</span>
        </h2>
        <p class="nbc-sub">Chocolate • Hazelnut • Indulgent</p>
        <p class="nbc-price">{{ section.settings.nugtella_product.price | money }}</p>
        <p class="nbc-desc">{{ section.settings.nugtella_desc }}</p>
        <div class="nbc-actions">
          <form method="post" action="/cart/add" data-nbc-form>
            <input type="hidden" name="quantity" value="1">
            <input type="hidden" name="id" value="{{ section.settings.nugtella_product.selected_or_first_available_variant.id }}">
            <button type="submit" class="nbc-atc">
              <span class="nbc-atc__check">✓</span> Add to cart
            </button>
          </form>
          <button type="button" class="nbc-wish" aria-label="Wishlist">♡</button>
        </div>
      </div>

      <div class="nbc-center">
        <div class="nbc-arch" style="background:linear-gradient(180deg,#d7ccc8 0%,#bcaaa4 50%,#a1887f 100%);"></div>
        {% if section.settings.bucket_image_nugtella != blank %}
          <img class="nbc-img" src="{{ section.settings.bucket_image_nugtella | image_url: width: 700 }}" alt="Nugtella Bucket" loading="lazy">
        {% elsif section.settings.nugtella_product.featured_image != blank %}
          <img class="nbc-img" src="{{ section.settings.nugtella_product.featured_image | image_url: width: 700 }}" alt="Nugtella Bucket" loading="lazy">
        {% endif %}
        <div class="nbc-orb nbc-orb--1"></div>
        <div class="nbc-orb nbc-orb--2" style="background:#5D3A1A;"></div>
      </div>

      <div class="nbc-right" data-nbc-animate>
        <div class="nbc-acc">
          <button type="button" class="nbc-acc__btn" data-nbc-acc>
            Description <span class="nbc-acc__icon" aria-hidden="true">⌄</span>
          </button>
          <div class="nbc-acc__panel">
            <p>{{ section.settings.nugtella_acc_desc | default: section.settings.nugtella_desc }}</p>
          </div>
        </div>
        <div class="nbc-acc">
          <button type="button" class="nbc-acc__btn" data-nbc-acc>
            Flavor Notes <span class="nbc-acc__icon" aria-hidden="true">⌄</span>
          </button>
          <div class="nbc-acc__panel">
            <p>{{ section.settings.nugtella_acc_flavor }}</p>
          </div>
        </div>
