<!-- ════════════════════════════════════════════════════════════
     ALL JAVASCRIPT
════════════════════════════════════════════════════════════ -->
<script>
(function () {

  /* ══════════════════════════════
     TOAST
  ══════════════════════════════ */
  var NbpToast = {
    _t: null,
    show: function (msg, icon, type) {
      var el  = document.getElementById('nbpToast');
      var txt = document.getElementById('nbpToastMsg');
      var ico = document.getElementById('nbpToastIcon');
      el.className    = 'nbp-toast nbp-toast--' + (type || '');
      txt.textContent = msg;
      ico.textContent = icon || '';
      el.classList.add('nbp-toast--show');
      clearTimeout(this._t);
      this._t = setTimeout(function () { el.classList.remove('nbp-toast--show'); }, 3000);
    }
  };

  /* ══════════════════════════════
     CART BADGE
  ══════════════════════════════ */
  var NbpCart = {
    badge: document.getElementById('nbpCartBadge'),
    count: document.getElementById('nbpCartCount'),
    init: function () {
      fetch('/cart.js')
        .then(function (r) { return r.json(); })
        .then(function (d) { NbpCart.update(d.item_count); })
        .catch(function () {});
    },
    update: function (n) {
      /* update theme header cart count if it exists */
      fetch('/?section_id=cart-icon-bubble&t=' + Date.now())
        .then(function (r) { return r.text(); })
        .then(function (html) {
          var parser = new DOMParser();
          var doc = parser.parseFromString(html, 'text/html');
          var newContent = doc.getElementById('cart-icon-bubble') || doc.querySelector('.shopify-section') || doc.body;
          var oldBubble = document.getElementById('cart-icon-bubble');
          if (newContent && oldBubble) {
            var newInner = newContent.innerHTML;
            if (newInner) oldBubble.innerHTML = newInner;
          }
        })
        .catch(function () {});

      document.querySelectorAll('[data-cart-count], .cart-count, .header__cart-count, #CartCount, .cart-count-bubble span[aria-hidden="true"]').forEach(function(el) {
        el.textContent = n;
      });
      if (this.count) {
        this.count.textContent = n;
        this.count.classList.remove('nbp-bump');
        void this.count.offsetWidth;
        this.count.classList.add('nbp-bump');
        setTimeout(function () { if (NbpCart.count) NbpCart.count.classList.remove('nbp-bump'); }, 350);
      }
      if (this.badge) this.badge.classList.add('nbp-badge--show');
    }
  };

  /* ══════════════════════════════
     WISHLIST (localStorage)
  ══════════════════════════════ */
  var WISH_KEY = 'sundaze_wishlist_v1';

  var NbpWish = {
    badge:   document.getElementById('nbpWishBadge'),
    countEl: document.getElementById('nbpWishCount'),
    overlay: document.getElementById('nbpWishOverlay'),
    drawer:  document.getElementById('nbpWishDrawer'),

    _load: function () {
      try { return JSON.parse(localStorage.getItem(WISH_KEY) || '[]'); }
      catch (e) { return []; }
    },
    _save: function (list) { localStorage.setItem(WISH_KEY, JSON.stringify(list)); },
    has: function (id) {
      return this._load().some(function (i) { return i.id === id; });
    },
    init: function () {
      if (this.badge) this.badge.classList.add('nbp-badge--show');
      this._syncCount();
      this._syncButtons();
    },
    _syncCount: function () {
      var n = this._load().length;
      if (this.countEl) {
        this.countEl.textContent = n;
        this.countEl.classList.remove('nbp-bump');
        void this.countEl.offsetWidth;
        this.countEl.classList.add('nbp-bump');
        setTimeout(function () { if (NbpWish.countEl) NbpWish.countEl.classList.remove('nbp-bump'); }, 350);
      }
    },
    _syncButtons: function () {
      document.querySelectorAll('[data-nbp-wish-btn]').forEach(function (btn) {
        var id = btn.dataset.variantId;
        if (id && NbpWish.has(id)) btn.classList.add('nbp-wished');
      });
    },
    toggle: function (btn) {
      var id    = btn.dataset.variantId;
      var name  = btn.dataset.productName  || 'Product';
      var price = btn.dataset.productPrice || '';
      var img   = btn.dataset.productImage || '';
      var emoji = btn.dataset.productEmoji || '🪣';
      if (!id) return;
      var list = this._load();
      var idx  = list.findIndex(function (i) { return i.id === id; });
      if (idx === -1) {
        list.push({ id: id, name: name, price: price, img: img, emoji: emoji });
        this._save(list);
        NbpToast.show(name + ' wishlisted', '💗', 'wish');
      } else {
        list.splice(idx, 1);
        this._save(list);
        NbpToast.show('Removed from wishlist', '🤍', '');
      }
      this._syncCount();
      this._syncButtons();
      this._renderDrawer();
    },
    openDrawer: function () {
      this._renderDrawer();
      this.overlay.classList.add('nbp-open');
      this.drawer.classList.add('nbp-open');
      document.body.style.overflow = 'hidden';
    },
    closeDrawer: function () {
      this.overlay.classList.remove('nbp-open');
      this.drawer.classList.remove('nbp-open');
      document.body.style.overflow = '';
    },
    _renderDrawer: function () {
      var list      = this._load();
      var container = document.getElementById('nbpWishList');
      if (!container) return;
      if (list.length === 0) {
        container.innerHTML =
          '<div class="nbp-wish-empty">' +
            '<div class="nbp-wish-empty__icon">🤍</div>' +
            '<p>Your wishlist is empty</p>' +
            '<p style="font-size:12px;opacity:.6">Tap a heart on any bucket to save it here</p>' +
          '</div>';
        return;
      }
      container.innerHTML = list.map(function (item) {
        return (
          '<div class="nbp-wish-item" data-wish-id="' + item.id + '">' +
            (item.img
              ? '<img class="nbp-wish-item__img" src="' + item.img + '" alt="' + item.name + '">'
              : '<div class="nbp-wish-item__placeholder">' + item.emoji + '</div>') +
            '<div class="nbp-wish-item__info">' +
              '<p class="nbp-wish-item__name">' + item.name + '</p>' +
              '<p class="nbp-wish-item__price">' + item.price + '</p>' +
              '<div class="nbp-wish-item__actions">' +
                '<button class="nbp-wish-item__add" onclick="NbpWish._addFromDrawer(\'' + item.id + '\',\'' + item.name + '\',this)">Add to cart</button>' +
                '<button class="nbp-wish-item__remove" onclick="NbpWish._removeFromDrawer(\'' + item.id + '\')">Remove</button>' +
              '</div>' +
            '</div>' +
          '</div>'
        );
      }).join('');
    },
    _addFromDrawer: function (id, name, btn) {
      btn.textContent = 'Adding…';
      btn.disabled    = true;
      fetch('/cart/add.js', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: parseInt(id, 10), quantity: 1 })
      })
      .then(function (r) { if (!r.ok) throw new Error(); return r.json(); })
      .then(function () {
        btn.textContent = '✓ Added!';
        NbpToast.show(name + ' added to cart', '🛒', 'added');
        fetch('/cart.js').then(function (r) { return r.json(); }).then(function (d) { NbpCart.update(d.item_count); });
        document.dispatchEvent(new CustomEvent('cart:refresh'));
        setTimeout(function () { btn.textContent = 'Add to cart'; btn.disabled = false; }, 2000);
      })
      .catch(function () { btn.textContent = 'Error'; btn.disabled = false; });
    },
    _removeFromDrawer: function (id) {
      var list = this._load().filter(function (i) { return i.id !== id; });
      this._save(list);
      this._syncCount();
      this._syncButtons();
      this._renderDrawer();
    }
  };

  window.NbpWish  = NbpWish;
  window.NbpToast = NbpToast;
  window.NbpCart  = NbpCart;

  /* ══════════════════════════════
     LIVE VIEWERS BADGE
  ══════════════════════════════ */
  var NbpLiveViewers = {
    badge:   document.getElementById('nbpLiveBadge'),
    countEl: document.getElementById('nbpLiveCount'),
    wsUrl:   'wss://sundaze-live-viewers.mamunhossain-services.workers.dev',
    _fallbackTimer: null,

    init: function () {
      if (!this.badge) return;
      this.connectWebSocket();
    },

    connectWebSocket: function () {
      try {
        var self = this;
        var ws   = new WebSocket(this.wsUrl);
        ws.onopen = function () {
          self.badge.classList.add('nbp-live-visible');
          clearInterval(self._fallbackTimer);
        };
        ws.onmessage = function (event) {
          try {
            var data = JSON.parse(event.data);
            if (data.type === 'count') self.updateCount(data.count);
          } catch (e) {}
        };
        ws.onerror = function () { self.fallbackSimulation(); };
        ws.onclose = function () { self.fallbackSimulation(); };
      } catch (e) {
        this.fallbackSimulation();
      }
    },

    updateCount: function (count) {
      if (count > 0 && this.countEl) {
        this.countEl.textContent = count;
        this.badge.classList.add('nbp-live-visible');
      }
    },

    fallbackSimulation: function () {
      if (this._fallbackTimer) return;
      var self = this;
      this.badge.classList.add('nbp-live-visible');
      var v = Math.floor(Math.random() * 24) + 14;
      this.updateCount(v);
      this._fallbackTimer = setInterval(function () {
        v = Math.max(8, v + Math.floor(Math.random() * 5) - 2);
        self.updateCount(v);
      }, 3500);
    }
  };

  /* ══════════════════════════════
     DRAWER CLOSE EVENTS
  ══════════════════════════════ */
  document.getElementById('nbpWishClose').addEventListener('click', function () { NbpWish.closeDrawer(); });
  document.getElementById('nbpWishOverlay').addEventListener('click', function () { NbpWish.closeDrawer(); });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') NbpWish.closeDrawer(); });

  /* ══════════════════════════════
     CART REFRESH LISTENER
  ══════════════════════════════ */
  document.addEventListener('cart:refresh', function () {
    /* cart count updated directly after each ATC — no fetch here to avoid conflicts */
  });

  /* ══════════════════════════════
     WISH HEART TOGGLE ON BUCKET CARDS
  ══════════════════════════════ */
  document.querySelectorAll('.nbc-wish').forEach(function (btn) {
    var card = btn.closest('.nbc-card');
    var nameEl = card ? card.querySelector('.nbc-title__word') : null;
    var priceEl = card ? card.querySelector('.nbc-price') : null;
    var imgEl = card ? card.querySelector('.nbc-img') : null;
    var formEl = card ? card.querySelector('[data-nbc-form]') : null;
    var variantId = formEl ? (formEl.querySelector('[name="id"]') || {}).value : '';
    var productName = nameEl ? nameEl.textContent.trim() : 'Bucket';
    var productPrice = priceEl ? priceEl.textContent.trim() : '';
    var productImg = imgEl ? imgEl.src : '';

    btn.dataset.variantId    = variantId;
    btn.dataset.productName  = productName + ' Bucket';
    btn.dataset.productPrice = productPrice;
    btn.dataset.productImage = productImg;
    btn.dataset.productEmoji = '🪣';

    if (variantId && NbpWish.has(variantId)) {
      btn.textContent       = '♥';
      btn.style.color       = '#ec4f9a';
      btn.style.borderColor = '#ec4f9a';
    }

    btn.addEventListener('click', function () {
      NbpWish.toggle(btn);
      var wished = NbpWish.has(btn.dataset.variantId);
      btn.textContent       = wished ? '♥' : '♡';
      btn.style.color       = wished ? '#ec4f9a' : '';
      btn.style.borderColor = wished ? '#ec4f9a' : '';
    });
  });

  /* ══════════════════════════════
     SCROLL REVEAL — BUCKET CARDS
  ══════════════════════════════ */
  var nbcObserver = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (!e.isIntersecting) return;
      var el = e.target;
      if (el.hasAttribute('data-nbc-card')) {
        el.classList.add('nbc-visible');
        el.querySelectorAll('[data-nbc-animate]').forEach(function (col) {
          col.classList.add('nbc-col-visible');
        });
      }
    });
  }, { threshold: 0.08 });

  document.querySelectorAll('[data-nbc-card]').forEach(function (card) {
    nbcObserver.observe(card);
  });

  /* ══════════════════════════════
     ACCORDIONS — BUCKET CARDS
  ══════════════════════════════ */
  document.querySelectorAll('#nbc-{{ section.id }} [data-nbc-acc]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var acc    = btn.closest('.nbc-acc');
      var isOpen = acc.classList.contains('nbc-acc--open');
      var icon   = btn.querySelector('.nbc-acc__icon');
      var card   = btn.closest('.nbc-card');
      card.querySelectorAll('.nbc-acc').forEach(function (a) {
        a.classList.remove('nbc-acc--open');
        var ic = a.querySelector('.nbc-acc__icon');
        if (ic) ic.classList.remove('nbc-acc__icon--open');
      });
      if (!isOpen) {
        acc.classList.add('nbc-acc--open');
        if (icon) icon.classList.add('nbc-acc__icon--open');
      }
    });
  });

  /* ══════════════════════════════
     MAIN SECTION LOGIC
  ══════════════════════════════ */
  var root = document.getElementById('nbp-{{ section.id }}');
  if (root && !root.dataset.nbpReady) {
    root.dataset.nbpReady = '1';

    var sid = '{{ section.id }}';
    var productImages = {
      nugtella:   '{{ section.settings.nugtella_product.featured_image | image_url: width: 600 }}',
      strawberry: '{{ section.settings.strawberry_product.featured_image | image_url: width: 600 }}',
      vanilla:    '{{ section.settings.vanilla_product.featured_image | image_url: width: 600 }}'
    };
    var bucketImageMixed = '{{ section.settings.bucket_image_mixed | image_url: width: 900 }}';

    var vidInput    = document.getElementById('nbp-vid-'    + sid);
    var priceEl     = document.getElementById('nbp-price-'  + sid);
    var subEl       = document.getElementById('nbp-sub-'    + sid);
    var descEl      = document.getElementById('nbp-desc-'   + sid);
    var labelEl     = document.getElementById('nbp-label-'  + sid);
    var pill1El     = document.getElementById('nbp-pill1-'  + sid);
    var pill2El     = document.getElementById('nbp-pill2-'  + sid);
    var jarsEl      = document.getElementById('nbp-jars-'   + sid);
    var accDescEl   = document.getElementById('nbp-acc-desc-'   + sid);
    var accFlavorEl = document.getElementById('nbp-acc-flavor-' + sid);
    var accSpecsEl  = document.getElementById('nbp-acc-specs-'  + sid);
    var accHighlightEl = document.getElementById('nbp-acc-highlight-' + sid);
    var optBtns     = root.querySelectorAll('[data-nbp-opt]');

    function makeImg(src, alt, cls) {
      if (!src) return '';
      return '<img src="' + src + '" alt="' + (alt || '') + '" class="' + cls + '" loading="lazy">';
    }

    function renderJars(btn) {
      var mode   = btn.dataset.mode;
      var imgSrc = btn.dataset.image || '';
      jarsEl.innerHTML = '';
      if (mode === 'mixed') {
        if (bucketImageMixed) {
          jarsEl.innerHTML = makeImg(bucketImageMixed, 'Mixed Bucket', 'nbp-jar nbp-jar--single');
        } else {
          jarsEl.innerHTML =
            makeImg(productImages.nugtella,   'Nugtella',             'nbp-jar nbp-jar--l') +
            makeImg(productImages.strawberry, 'Strawberry Shortcake', 'nbp-jar nbp-jar--c') +
            makeImg(productImages.vanilla,    'Vanilla',              'nbp-jar nbp-jar--r');
        }
      } else {
        var src = imgSrc || productImages[btn.dataset.flavor] || '';
        if (src) jarsEl.innerHTML = makeImg(src, btn.dataset.label, 'nbp-jar nbp-jar--single');
      }
    }

    /* Flavor selector */
    optBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        optBtns.forEach(function (b) { b.classList.remove('active'); });
        btn.classList.add('active');
        if (vidInput    && btn.dataset.variant)    vidInput.value          = btn.dataset.variant;
        if (priceEl     && btn.dataset.price)       priceEl.textContent     = btn.dataset.price;
        if (subEl       && btn.dataset.sub)         subEl.textContent       = btn.dataset.sub;
        if (descEl      && btn.dataset.desc)        descEl.textContent      = btn.dataset.desc;
        if (labelEl     && btn.dataset.label)       labelEl.textContent     = btn.dataset.label;
        if (pill1El     && btn.dataset.pill)        pill1El.textContent     = btn.dataset.pill;
        if (pill2El     && btn.dataset.pill2)       pill2El.textContent     = btn.dataset.pill2;

        if (accDescEl)   accDescEl.textContent   = btn.dataset.accDesc   || '';
        if (accFlavorEl) accFlavorEl.textContent = btn.dataset.accFlavor || '';

        if (accSpecsEl) {
          accSpecsEl.innerHTML = btn.dataset.accSpecs || '';
        }
        if (accHighlightEl) {
          accHighlightEl.textContent = btn.dataset.accHighlight || '';
        }

        renderJars(btn);
      });
    });

    /* Accordions — main section right column */
    root.querySelectorAll('[data-nbp-acc]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var acc    = btn.closest('.nbp-acc');
        var isOpen = acc.classList.contains('nbp-acc--open');
        var icon   = btn.querySelector('.nbp-acc__icon');
        root.querySelectorAll('.nbp-right .nbp-acc').forEach(function (a) {
          a.classList.remove('nbp-acc--open');
          var ic = a.querySelector('.nbp-acc__icon');
          if (ic) ic.classList.remove('nbp-acc__icon--open');
        });
        if (!isOpen) {
          acc.classList.add('nbp-acc--open');
          if (icon) icon.classList.add('nbp-acc__icon--open');
        }
      });
    });

    /* Async ATC — hero form */
    var heroForm = root.querySelector('[data-nbp-form]');
    if (heroForm) {
      heroForm.addEventListener('submit', function (e) {
        e.preventDefault();
        var btn  = heroForm.querySelector('[type="submit"]');
        var orig = btn.innerHTML;
        btn.textContent = 'Adding…';
        btn.disabled    = true;
        fetch('/cart/add.js', { method: 'POST', body: new FormData(heroForm) })
          .then(function (r) {
            if (!r.ok) throw new Error('cart error');
            btn.innerHTML = '<span class="nbp-atc__check">✓</span> Added!';
            btn.style.background = '#2a7a4b';
            NbpToast.show('Added to cart', '🛒', 'added');
            fetch('/cart.js').then(function (r2) { return r2.json(); }).then(function (d) { NbpCart.update(d.item_count); });
            document.dispatchEvent(new CustomEvent('cart:refresh'));
            setTimeout(function () {
              btn.innerHTML        = orig;
              btn.style.background = '';
              btn.disabled         = false;
            }, 1800);
          })
          .catch(function () {
            NbpToast.show('Could not add to cart', '❌', 'error');
            btn.innerHTML = orig;
            btn.disabled  = false;
          });
      });
    }

    /* Wishlist — hero .nbp-wish button, tracks selected flavor */
    var heroWishBtn = root.querySelector('.nbp-wish');
    if (heroWishBtn) {
      /* build product data from the currently active opt button */
      function getActiveOptData() {
        var active = root.querySelector('[data-nbp-opt].active');
        if (!active) return {};
        return {
          variantId:    active.dataset.variant   || '',
          productName:  active.dataset.label      || 'Bucket',
          productPrice: active.dataset.price      || '',
          productImage: active.dataset.image      || '',
          productEmoji: '🪣'
        };
      }

      function syncHeroWish() {
        var d = getActiveOptData();
        if (!d.variantId) return;
        var wished = NbpWish.has(d.variantId);
        heroWishBtn.textContent       = wished ? '♥' : '♡';
        heroWishBtn.style.color       = wished ? '#ec4f9a' : '';
        heroWishBtn.style.borderColor = wished ? '#ec4f9a' : '';
      }

      heroWishBtn.addEventListener('click', function () {
        var d = getActiveOptData();
        if (!d.variantId) {
          NbpToast.show('Select a flavor first', '⚠️', 'error');
          return;
        }
        /* temporarily set dataset attrs so NbpWish.toggle can read them */
        heroWishBtn.dataset.variantId    = d.variantId;
        heroWishBtn.dataset.productName  = d.productName;
        heroWishBtn.dataset.productPrice = d.productPrice;
        heroWishBtn.dataset.productImage = d.productImage;
        heroWishBtn.dataset.productEmoji = d.productEmoji;
        NbpWish.toggle(heroWishBtn);
        syncHeroWish();
      });

      /* re-sync heart state whenever flavor changes */
      optBtns.forEach(function (btn) {
        btn.addEventListener('click', function () {
          setTimeout(syncHeroWish, 0);
        });
      });

      syncHeroWish();
    }
  } /* end root block */

  /* ══════════════════════════════
     ASYNC ADD TO CART — BUCKET CARDS
  ══════════════════════════════ */
  document.querySelectorAll('#nbc-{{ section.id }} [data-nbc-form]').forEach(function (form) {
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var btn  = form.querySelector('[type="submit"]');
      var orig = btn.innerHTML;
      btn.textContent = 'Adding…';
      btn.disabled    = true;
      fetch('/cart/add.js', { method: 'POST', body: new FormData(form) })
        .then(function (r) {
          if (!r.ok) throw new Error();
          btn.innerHTML = '<span class="nbc-atc__check">✓</span> Added!';
          btn.style.background = '#2a7a4b';
          NbpToast.show('Added to cart', '🛒', 'added');
          fetch('/cart.js').then(function (r2) { return r2.json(); }).then(function (d) { NbpCart.update(d.item_count); });
          document.dispatchEvent(new CustomEvent('cart:refresh'));
          setTimeout(function () {
            btn.innerHTML        = orig;
            btn.style.background = '';
            btn.disabled         = false;
          }, 1800);
        })
        .catch(function () {
          NbpToast.show('Could not add to cart', '❌', 'error');
          btn.innerHTML = orig;
          btn.disabled  = false;
        });
    });
  });

  /* ══════════════════════════════
     INIT ALL
  ══════════════════════════════ */
  NbpCart.init();
  NbpWish.init();
  NbpLiveViewers.init();

})();
</script>


