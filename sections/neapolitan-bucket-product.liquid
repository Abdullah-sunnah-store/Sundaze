<style>

  /* ════════════════════════════════
     BADGE STYLES
  ════════════════════════════════ */
  .nbp-badge {
    position: fixed;
    right: 24px;
    z-index: 9000;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #fff;
    border: 1px solid #e8e0d8;
    border-radius: 999px;
    padding: 10px 16px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #1a1a1a;
    cursor: pointer;
    text-decoration: none;
    box-shadow: 0 8px 32px rgba(0,0,0,.10);
    transition: background .2s ease, border-color .2s ease, color .2s ease,
                transform .3s cubic-bezier(.34,1.56,.64,1), opacity .35s ease;
    opacity: 0;
    transform: translateY(-14px);
    pointer-events: none;
  }
  .nbp-badge.nbp-badge--show { opacity: 1; transform: translateY(0); pointer-events: auto; }
  .nbp-badge--cart { top: 124px; }
  .nbp-badge--wish { top: 172px; border-color: #f0d6e8; }

  @media (max-width: 640px) {
    .nbp-badge--wish { top: 105px; right: 2px; }
    .nbp-badge--cart { top: 62px;  right: 2px; }
  }

  .nbp-badge--cart:hover { background: #1a1a1a; border-color: #1a1a1a; color: #fff; }
  .nbp-badge--wish:hover { background: #fef0f5; border-color: #e8a0bf; }
  .nbp-badge__icon { display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .nbp-badge__icon--heart { color: #e8a0bf; }
  .nbp-badge__label { line-height: 1; }
  .nbp-badge__count {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 22px; height: 22px; border-radius: 999px;
    font-size: 11px; font-weight: 700; padding: 0 5px; line-height: 1; flex-shrink: 0;
    transition: transform .25s cubic-bezier(.34,1.56,.64,1);
  }
  .nbp-badge__count.nbp-bump { transform: scale(1.45); }
  .nbp-badge__count--dark { background: #1a1a1a; color: #fff; }
  .nbp-badge--cart:hover .nbp-badge__count--dark { background: #e8a0bf; color: #1a1a1a; }
  .nbp-badge__count--purple { background: linear-gradient(135deg, #e8a0bf, #c77dff); color: #fff; }

  /* ════════════════════════════════
     TOAST
  ════════════════════════════════ */
  .nbp-toast {
    position: fixed; bottom: 32px; left: 50%; z-index: 9999;
    display: inline-flex; align-items: center; gap: 9px;
    background: #1a1a1a; color: #fff; border-radius: 999px; padding: 12px 22px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    font-size: 13px; font-weight: 600; box-shadow: 0 8px 32px rgba(0,0,0,.22);
    white-space: nowrap; pointer-events: none; opacity: 0;
    transform: translateX(-50%) translateY(24px);
    transition: opacity .35s ease, transform .4s cubic-bezier(.34,1.56,.64,1);
  }
  .nbp-toast.nbp-toast--show { opacity: 1; transform: translateX(-50%) translateY(0); }
  .nbp-toast.nbp-toast--wish  { background: linear-gradient(135deg, #e8a0bf, #c77dff); }
  .nbp-toast.nbp-toast--error { background: #c0392b; }
  .nbp-toast.nbp-toast--added { background: #2d7a2d; }

  /* ════════════════════════════════
     WISHLIST OVERLAY + DRAWER
  ════════════════════════════════ */
  .nbp-wish-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,.32);
    backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
    z-index: 9100; opacity: 0; pointer-events: none; transition: opacity .3s ease;
  }
  .nbp-wish-overlay.nbp-open { opacity: 1; pointer-events: all; }
  .nbp-wish-drawer {
    position: fixed; top: 0; right: 0; height: 100%; width: min(400px, 100vw);
    background: #fff; z-index: 9200; padding: 32px 24px;
    box-shadow: -8px 0 40px rgba(0,0,0,.12); display: flex; flex-direction: column;
    overflow-y: auto; transform: translateX(100%);
    transition: transform .38s cubic-bezier(.25,.46,.45,.94);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }
  .nbp-wish-drawer.nbp-open { transform: translateX(0); }
  .nbp-wish-drawer__header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
  .nbp-wish-drawer__title { font-size: 20px; font-weight: 800; color: #1a1a1a; letter-spacing: -.02em; display: flex; align-items: center; gap: 8px; margin: 0; }
  .nbp-wish-drawer__close {
    width: 36px; height: 36px; border-radius: 50%; border: 1px solid #e8e0d8;
    background: transparent; cursor: pointer; font-size: 16px; color: #888;
    display: flex; align-items: center; justify-content: center;
    transition: border-color .2s, color .2s; font-family: inherit;
  }
  .nbp-wish-drawer__close:hover { border-color: #c0392b; color: #c0392b; }
  .nbp-wish-empty { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px; color: rgba(107,66,38,.45); font-size: 14px; text-align: center; }
  .nbp-wish-empty__icon { font-size: 48px; }
  .nbp-wish-item { display: flex; align-items: center; gap: 14px; padding: 14px 0; border-bottom: 1px solid #f0ebe4; }
  .nbp-wish-item__img { width: 64px; height: 64px; border-radius: 12px; object-fit: cover; background: #f5f2ee; flex-shrink: 0; }
  .nbp-wish-item__placeholder { width: 64px; height: 64px; border-radius: 12px; background: linear-gradient(135deg, #fce4ec, #f5e6d3); flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 26px; }
  .nbp-wish-item__info { flex: 1; min-width: 0; }
  .nbp-wish-item__name { font-size: 13px; font-weight: 700; color: #1a1a1a; margin: 0 0 2px; }
  .nbp-wish-item__price { font-size: 12px; color: rgba(107,66,38,.6); margin: 0 0 8px; }
  .nbp-wish-item__actions { display: flex; gap: 8px; }
  .nbp-wish-item__add { font-size: 11px; font-weight: 600; padding: 6px 14px; border-radius: 999px; border: none; background: #1a1a1a; color: #fff; cursor: pointer; transition: background .2s; font-family: inherit; }
  .nbp-wish-item__add:hover { background: #333; }
  .nbp-wish-item__remove { font-size: 11px; font-weight: 600; padding: 6px 10px; border-radius: 999px; border: 1px solid #e8e0d8; background: transparent; color: rgba(107,66,38,.6); cursor: pointer; transition: border-color .2s, color .2s; font-family: inherit; }
  .nbp-wish-item__remove:hover { border-color: #c0392b; color: #c0392b; }

  @media screen and (max-width: 480px) {
    .nbp-badge { right: 12px; padding: 9px 12px; font-size: 12px; }
    .nbp-badge--cart { top: 62px; }
    .nbp-badge--wish { top: 102px; }
  }

  /* ════════════════════════════════
     LIVE VIEWERS BADGE
  ════════════════════════════════ */
  #nbp-{{ section.id }} .nbp-live-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.9);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 50px;
    padding: 8px 14px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    font-size: 12px;
    font-weight: 600;
    color: #1a1a1a;
    width: fit-content;
    margin-top: 12px;
    opacity: 0;
    transform: translateY(-8px);
    transition: opacity 0.4s ease, transform 0.4s ease;
    position: relative;
    z-index: 4;
  }

  #nbp-{{ section.id }} .nbp-live-badge.nbp-live-visible {
    opacity: 1;
    transform: translateY(0);
  }

  #nbp-{{ section.id }} .nbp-live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #10b981;
    flex-shrink: 0;
    box-shadow: 0 0 0 0 rgba(16,185,129,0.7);
    animation: nbp-pulse-dot 1.5s infinite ease-in-out;
  }

  @keyframes nbp-pulse-dot {
    0%   { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16,185,129,0.7); }
    70%  { transform: scale(1);    box-shadow: 0 0 0 6px rgba(16,185,129,0); }
    100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16,185,129,0); }
  }

  /* ════════════════════════════════
     BUCKET CARD STYLES
  ════════════════════════════════ */
  .nbc-wrap {
    background: {{ section.settings.bg_color | default: '#f7ece2' }};
    padding: 0 16px 48px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    display: flex; flex-direction: column; gap: 32px;
    max-width: 1400px; margin: 0 auto;
  }
  .nbc-card {
    background: #fff; border-radius: 28px;
    box-shadow: 0 20px 70px rgba(0,0,0,.08); overflow: hidden;
    opacity: 0; transform: translateY(28px);
    transition: opacity .65s ease, transform .65s ease;
  }
  .nbc-card.nbc-visible { opacity: 1; transform: translateY(0); }
  .nbc-grid { display: grid; grid-template-columns: 1fr 460px 1fr; min-height: 580px; }

  .nbc-left {
    padding: 52px 32px 52px 48px; display: flex; flex-direction: column; justify-content: center;
    opacity: 0; transform: translateX(-18px);
    transition: opacity .6s ease .15s, transform .6s ease .15s;
  }
  .nbc-left.nbc-col-visible { opacity: 1; transform: translateX(0); }
  .nbc-flavor-badge { display: inline-flex; align-items: center; gap: 6px; border-radius: 999px; padding: 7px 16px; font-size: 12px; font-weight: 700; letter-spacing: .02em; width: fit-content; margin-bottom: 20px; }
  .nbc-title { margin: 0 0 14px; line-height: .9; letter-spacing: -.05em; }
  .nbc-title__word { display: block; font-size: clamp(40px, 3.8vw, 60px); font-weight: 800; color: #111; }
  .nbc-title__gradient { display: block; font-size: clamp(40px, 3.8vw, 60px); font-weight: 800; -webkit-background-clip: text; background-clip: text; color: transparent; }
  .nbc-sub { font-size: 14px; font-weight: 600; color: #777; margin: 0 0 14px; }
  .nbc-price { font-size: 32px; font-weight: 800; letter-spacing: -.04em; color: #111; margin: 0 0 14px; }
  .nbc-desc { font-size: 14px; color: #555; line-height: 1.6; margin: 0 0 28px; max-width: 270px; }
  .nbc-actions { display: flex; align-items: center; gap: 12px; }
  .nbc-atc {
    display: inline-flex; align-items: center; gap: 9px;
    background: #111; color: #fff; border: none; border-radius: 999px;
    padding: 16px 26px; font-size: 15px; font-weight: 800; cursor: pointer;
    font-family: inherit; letter-spacing: -.02em;
    transition: background .15s, transform .1s, box-shadow .15s;
    box-shadow: 0 6px 20px rgba(0,0,0,.18); white-space: nowrap;
  }
  .nbc-atc:hover { background: #333; transform: translateY(-1px); box-shadow: 0 10px 28px rgba(0,0,0,.22); }
  .nbc-atc:active { transform: translateY(0); }
  .nbc-atc--pink    { background: linear-gradient(135deg, #e8a0bf, #c2185b); }
  .nbc-atc--pink:hover { background: linear-gradient(135deg, #d48aa8, #a71549); }
  .nbc-atc--vanilla { background: linear-gradient(135deg, #c5824c, #8b5e2c); }
  .nbc-atc--vanilla:hover { background: linear-gradient(135deg, #b06e3a, #744e22); }
  .nbc-atc__check { width: 20px; height: 20px; background: rgba(255,255,255,.2); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 900; flex-shrink: 0; }
  .nbc-wish { width: 50px; height: 50px; border-radius: 50%; border: 1.5px solid #e0e0e0; background: #fff; font-size: 20px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: border-color .15s, color .15s; color: #999; flex-shrink: 0; }
  .nbc-wish:hover { border-color: #ec4f9a; color: #ec4f9a; }

  .nbc-center { position: relative; display: flex; align-items: center; justify-content: center; min-height: 400px; overflow: hidden; }
  .nbc-arch { position: absolute; inset: 24px; border-radius: 32px; z-index: 1; }
  .nbc-img { position: relative; z-index: 2; width: 88%; height: auto; max-height: 420px; object-fit: contain; filter: drop-shadow(0 22px 22px rgba(0,0,0,.16)); animation: nbcFloat 4s ease-in-out infinite; user-select: none; }
  @keyframes nbcFloat { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-9px); } }
  .nbc-orb { position: absolute; z-index: 3; border-radius: 50%; pointer-events: none; }
  .nbc-orb--1 { width: 10px; height: 10px; background: rgba(255,255,255,.85); top: 80px; left: 44px; box-shadow: 0 2px 8px rgba(0,0,0,.1); }
  .nbc-orb--2 { width: 7px; height: 7px; opacity: .45; bottom: 100px; right: 52px; }

  .nbc-right {
    padding: 52px 48px 52px 32px; display: flex; flex-direction: column; justify-content: center;
    opacity: 0; transform: translateX(18px);
    transition: opacity .6s ease .25s, transform .6s ease .25s;
